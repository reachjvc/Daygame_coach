LQ_UNREPAIRED_BLOCK_ABSOLUTE_THRESHOLD = 120
LQ_UNREPAIRED_BLOCK_RATIO_THRESHOLD = 0.35
LQ_UNREPAIRED_BLOCK_RATIO_MIN_COUNT = 80
ARTIFACT_UNREPAIRED_BLOCK_THRESHOLD = 30
LQ_TOTAL_BLOCK_ABSOLUTE_THRESHOLD = 130
LQ_TOTAL_BLOCK_RATIO_THRESHOLD = 0.33
LQ_TOTAL_BLOCK_RATIO_MIN_COUNT = 60
LQ_TOTAL_BLOCK_EXTREME_RATIO_THRESHOLD = 0.48
LQ_TOTAL_BLOCK_EXTREME_RATIO_MIN_COUNT = 25


