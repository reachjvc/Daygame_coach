# Ensure run-all lock is released on all exits.
trap 'release_run_all_lock' EXIT

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --list)
      warn_operator_mode_direct_use "--list"
      MODE="list"
      shift
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --status)
      warn_operator_mode_direct_use "--status"
      MODE="status"
      shift
      ;;
    --view)
      warn_operator_mode_direct_use "--view"
      MODE="view"
      shift
      ;;
    --approve)
      warn_operator_mode_direct_use "--approve"
