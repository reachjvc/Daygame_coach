    --stage=*)
      warn_operator_mode_direct_use "--stage"
      MODE="run_stage"
      STAGE="${1#--stage=}"
      shift
      ;;
    --from-stage)
      # Legacy alias for --run --from
      MODE="run_pipeline"
      START_STAGE="$2"
      shift 2
      ;;
    --from-stage=*)
      MODE="run_pipeline"
      START_STAGE="${1#--from-stage=}"
      shift
      ;;
    --source)
      [[ $# -lt 2 ]] && error "--source requires a name"
