build_auto_repair_retry_manifest() {
  local sub_id="$1"
  local attempt="$2"
  local manifest="$BATCHES_DIR/${sub_id}.txt"
  local label="$sub_id"
  if [[ -n "$VALIDATE_SOURCE" ]]; then
    label="${sub_id}.${VALIDATE_SOURCE}"
  fi

  local repair_worklist="$REPO_ROOT/data/validation/repair_worklists/${label}.repair-worklist.json"
  local fallback_manifest="$REPO_ROOT/data/validation/repair_worklists/${label}.repair-windowless-fallback.json"
  local out_manifest="$REPO_ROOT/data/validation/repair_worklists/${label}.auto-repair.attempt${attempt}.manifest.txt"
  local out_meta="$REPO_ROOT/data/validation/repair_worklists/${label}.auto-repair.attempt${attempt}.targets.json"

  python3 - "$manifest" "$repair_worklist" "$fallback_manifest" "$out_manifest" "$out_meta" "$sub_id" "$attempt" <<'PYEOF'
import json
import re
import sys
import time
from pathlib import Path

VIDEO_ID_RE = re.compile(r"\[([A-Za-z0-9_-]{11})\]")
RERUN_STAGE_ORDER = ["06b", "06e", "07"]

def stage_index(stage: str) -> int:
    try:
        return RERUN_STAGE_ORDER.index(stage)
    except ValueError:
        return 0

def worst_status(a: str | None, b: str | None) -> str | None:
    order = {"READY": 0, "REVIEW": 1, "BLOCKED": 2}
    if not a:
        return b
    if not b:
        return a
    return a if order.get(a, -1) >= order.get(b, -1) else b

def normalize_reason(raw: object) -> str | None:
    if not isinstance(raw, str):
        return None
    s = raw.strip()
    return s if s else None

def suggest_rerun_stage_from_reason(reason: str | None) -> str | None:
    if not reason:
        return None
    r = reason.lower()
    if "routing_mismatch" in r or "prompt_variant_mismatch" in r:
        return "07"
    if "misattribution" in r or "speaker" in r or "diar" in r:
        return "06b"
    if (
        "contamination_risk" in r
        or "transcript_quality" in r
        or "damage" in r
        or "other_quality" in r
        or "windowless" in r
    ):
        return "06e"
    return None

def suggest_rerun_stage_from_strategy(strategy: str | None) -> str | None:
    if not strategy:
        return None
    s = strategy.strip()
    if s in {"chunk_probe_reverify", "chunk_scan_reverify", "segment_sweep_reverify"}:
        return "06e"
    return None

def suggest_rerun_stage_from_stage_report_signal(*, check: str | None, signal_class: str | None, remediation_path: str | None) -> str | None:
    ck = (check or "").strip().lower()
    sc = (signal_class or "").strip().lower()
    rp = (remediation_path or "").strip().lower()
    if ck == "video_type_mismatch" or sc == "routing_mismatch" or "routing" in rp:
        return "07"
    if ck in {"stage07_validation_warnings", "stage07_transcript_artifact_risk"}:
        return "06e"
    if "contamination" in sc or "damage" in sc:
        return "06e"
    # Generic transcript_quality / transcript_review often comes from segment_text_modified,
    # which is too broad to force a full 06e rerun on its own.
    if "misattribution" in ck or "speaker" in ck or "diar" in ck:
        return "06b"
    return None

def enrich_target_from_stage_report(tgt: dict, artifacts: object) -> None:
    if not isinstance(artifacts, dict):
        return
    raw_path = artifacts.get("readiness_report")
    if not isinstance(raw_path, str) or not raw_path.strip():
        return
    if tgt.get("_stage_report_loaded"):
        return
    p = Path(raw_path.strip())
    if not p.is_absolute():
        p = Path.cwd() / p
    payload = load_json(p)
    tgt["_stage_report_loaded"] = True
    if not isinstance(payload, dict):
        return
    tgt["stage_report_reason_code"] = normalize_reason(payload.get("reason_code"))
    st = normalize_reason(payload.get("status"))
    if st:
        tgt["stage_report_status"] = st.upper()
    checks = payload.get("checks")
    if not isinstance(checks, list):
        return
    for row in checks:
        if not isinstance(row, dict):
            continue
        ck = normalize_reason(row.get("check"))
        sc = normalize_reason(row.get("signal_class"))
        rp = normalize_reason(row.get("remediation_path"))
        if ck:
            tgt["stage_report_checks"].add(ck)
        if sc:
            tgt["stage_report_signal_classes"].add(sc)
        if rp:
            tgt["stage_report_remediation_paths"].add(rp)

def choose_target_rerun_stage(target: dict) -> str:
    candidates: list[str] = []
    for ck in sorted(target.get("stage_report_checks") or []):
        stage = suggest_rerun_stage_from_stage_report_signal(
            check=ck,
            signal_class=None,
            remediation_path=None,
        )
        if stage:
            candidates.append(stage)
    for sc in sorted(target.get("stage_report_signal_classes") or []):
        stage = suggest_rerun_stage_from_stage_report_signal(
            check=None,
            signal_class=sc,
            remediation_path=None,
        )
        if stage:
            candidates.append(stage)
    for rp in sorted(target.get("stage_report_remediation_paths") or []):
        stage = suggest_rerun_stage_from_stage_report_signal(
            check=None,
            signal_class=None,
            remediation_path=rp,
        )
        if stage:
            candidates.append(stage)
    for reason in sorted(target.get("reasons") or []):
        stage = suggest_rerun_stage_from_reason(reason)
        if stage:
            candidates.append(stage)
    for strategy in sorted(target.get("fallback_strategies") or []):
        stage = suggest_rerun_stage_from_strategy(strategy)
        if stage:
            candidates.append(stage)
    if not candidates:
        if target.get("localized_repair") or target.get("windowless_auto_fallback"):
            return "06e"
        return "06b"
    candidates.sort(key=stage_index)
    return candidates[0]

manifest_path = Path(sys.argv[1])
repair_worklist_path = Path(sys.argv[2])
fallback_manifest_path = Path(sys.argv[3])
out_manifest_path = Path(sys.argv[4])
out_meta_path = Path(sys.argv[5])
sub_id = sys.argv[6]
attempt = sys.argv[7]

def load_json(path: Path):
    if not path.exists():
        return None
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None

repair = load_json(repair_worklist_path)
fallback = load_json(fallback_manifest_path)

localized_video_ids: set[str] = set()
targets_meta: dict[str, dict] = {}

def ensure_target(vid: str) -> dict:
    tgt = targets_meta.get(vid)
    if tgt is None:
        tgt = {
            "video_id": vid,
            "status": None,
            "source": None,
            "content_type": None,
            "reasons": set(),
            "localized_repair": False,
            "windowless_auto_fallback": False,
            "fallback_strategies": set(),
            "stage_report_checks": set(),
            "stage_report_signal_classes": set(),
            "stage_report_remediation_paths": set(),
            "stage_report_reason_code": None,
            "stage_report_status": None,
            "_stage_report_loaded": False,
        }
        targets_meta[vid] = tgt
    return tgt

if isinstance(repair, dict):
    rows = repair.get("segment_windows")
    if isinstance(rows, list):
        for row in rows:
            if not isinstance(row, dict):
                continue
            vid = row.get("video_id")
            status = str(row.get("status") or "").strip().upper()
            if not isinstance(vid, str):
                continue
            if status == "READY":
                continue
            localized_video_ids.add(vid)
            tgt = ensure_target(vid)
            tgt["localized_repair"] = True
            tgt["status"] = worst_status(tgt.get("status"), status)
            reason = normalize_reason(row.get("reason"))
            if reason:
                tgt["reasons"].add(reason)
            if isinstance(row.get("source"), str) and row.get("source").strip():
                tgt["source"] = row["source"].strip()
            if isinstance(row.get("content_type"), str) and row.get("content_type").strip():
                tgt["content_type"] = row["content_type"].strip()
    videos = repair.get("videos")
    if isinstance(videos, list):
        for row in videos:
            if not isinstance(row, dict):
                continue
            vid = row.get("video_id")
            status = str(row.get("status") or "").strip().upper()
            if not isinstance(vid, str):
                continue
            if status == "READY":
                continue
            # Include videos bucket too so a malformed/empty windows list does not hide a target.
            if status in {"REVIEW", "BLOCKED"}:
                localized_video_ids.add(vid)
                tgt = ensure_target(vid)
                tgt["localized_repair"] = True
                tgt["status"] = worst_status(tgt.get("status"), status)
                reason = normalize_reason(row.get("reason"))
                if reason:
                    tgt["reasons"].add(reason)
                if isinstance(row.get("source"), str) and row.get("source").strip():
                    tgt["source"] = row["source"].strip()
                if isinstance(row.get("content_type"), str) and row.get("content_type").strip():
                    tgt["content_type"] = row["content_type"].strip()
                enrich_target_from_stage_report(tgt, row.get("artifacts"))

fallback_auto_ids: set[str] = set()
fallback_manual_ids: set[str] = set()
fallback_excluded_preexisting_quarantine_ids: set[str] = set()
if isinstance(fallback, dict):
    tasks = fallback.get("tasks")
    if isinstance(tasks, list):
        for row in tasks:
            if not isinstance(row, dict):
                continue
            vid = row.get("video_id")
            strategy = str(row.get("strategy") or "").strip()
            status = str(row.get("status") or "").strip().upper()
            if not isinstance(vid, str):
                continue
            if status == "READY":
                continue
            reason = normalize_reason(row.get("reason"))
            if (reason or "").strip().lower() == "preexisting_quarantine":
                fallback_excluded_preexisting_quarantine_ids.add(vid)
                continue
            if strategy == "manual_full_video_review":
                fallback_manual_ids.add(vid)
            else:
                fallback_auto_ids.add(vid)
                tgt = ensure_target(vid)
                tgt["windowless_auto_fallback"] = True
                tgt["status"] = worst_status(tgt.get("status"), status)
                if strategy:
                    tgt["fallback_strategies"].add(strategy)
                if reason:
                    tgt["reasons"].add(reason)
                if isinstance(row.get("source"), str) and row.get("source").strip():
                    tgt["source"] = row["source"].strip()
                if isinstance(row.get("content_type"), str) and row.get("content_type").strip():
                    tgt["content_type"] = row["content_type"].strip()
                enrich_target_from_stage_report(tgt, row.get("artifacts"))

target_video_ids = localized_video_ids | fallback_auto_ids

selected_lines: list[str] = []
original_lines = manifest_path.read_text(encoding="utf-8").splitlines()
for raw in original_lines:
    line = raw.rstrip("\n")
    if not line.strip() or line.lstrip().startswith("#"):
        continue
    m = VIDEO_ID_RE.search(line)
    if not m:
        continue
    if m.group(1) in target_video_ids:
        selected_lines.append(line)

generated_at = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
out_manifest_written = False
line_by_vid: dict[str, str] = {}
for line in selected_lines:
    m = VIDEO_ID_RE.search(line)
    if m:
        line_by_vid[m.group(1)] = line
if selected_lines:
    out_manifest_path.parent.mkdir(parents=True, exist_ok=True)
    header = [
        f"# Auto-repair retry manifest for {sub_id}",
        f"# Attempt: {attempt}",
        f"# Generated: {generated_at}",
        f"# Videos: {len(selected_lines)}",
        "#",
        "# Source: repair-worklist + windowless fallback manifest (non-READY only)",
    ]
    out_manifest_path.write_text("\n".join(header + selected_lines) + "\n", encoding="utf-8")
    out_manifest_written = True

target_rows: list[dict] = []
stage_groups: dict[str, list[str]] = {}
for vid in sorted(target_video_ids):
    tgt = ensure_target(vid)
    final_stage = choose_target_rerun_stage(tgt)
    tgt["recommended_rerun_from_stage"] = final_stage
    if vid in line_by_vid:
        stage_groups.setdefault(final_stage, []).append(line_by_vid[vid])
    target_rows.append(
        {
            "video_id": vid,
            "status": tgt.get("status"),
            "source": tgt.get("source"),
            "content_type": tgt.get("content_type"),
            "localized_repair": bool(tgt.get("localized_repair")),
            "windowless_auto_fallback": bool(tgt.get("windowless_auto_fallback")),
            "reasons": sorted(str(x) for x in (tgt.get("reasons") or set())),
            "fallback_strategies": sorted(str(x) for x in (tgt.get("fallback_strategies") or set())),
            "stage_report_checks": sorted(str(x) for x in (tgt.get("stage_report_checks") or set())),
            "stage_report_signal_classes": sorted(str(x) for x in (tgt.get("stage_report_signal_classes") or set())),
            "stage_report_remediation_paths": sorted(str(x) for x in (tgt.get("stage_report_remediation_paths") or set())),
            "stage_report_reason_code": tgt.get("stage_report_reason_code"),
            "stage_report_status": tgt.get("stage_report_status"),
            "recommended_rerun_from_stage": final_stage,
        }
    )

stage_group_rows: list[dict] = []
base_name = out_meta_path.name
if base_name.endswith(".targets.json"):
    base_name = base_name[:-len(".targets.json")]
else:
    base_name = out_meta_path.stem
for stage in sorted(stage_groups.keys(), key=stage_index):
    group_lines = stage_groups.get(stage) or []
    if not group_lines:
        continue
    group_path = out_meta_path.parent / f"{base_name}.from-{stage}.manifest.txt"
    header = [
        f"# Auto-repair stage-group manifest for {sub_id}",
        f"# Attempt: {attempt}",
        f"# Rerun from stage: {stage}",
        f"# Generated: {generated_at}",
        f"# Videos: {len(group_lines)}",
    ]
    group_path.write_text("\n".join(header + ["#"] + group_lines) + "\n", encoding="utf-8")
    stage_group_rows.append(
        {
            "rerun_from_stage": stage,
            "video_count": len(group_lines),
            "manifest": str(group_path),
            "video_ids": sorted(
                [
                    row["video_id"]
                    for row in target_rows
                    if row.get("recommended_rerun_from_stage") == stage
                ]
            ),
        }
    )

manual_only_ids = sorted(fallback_manual_ids - target_video_ids)
meta = {
    "version": 1,
    "generated_at": generated_at,
    "sub_batch_id": sub_id,
    "attempt": int(attempt),
    "inputs": {
        "manifest": str(manifest_path),
        "repair_worklist": str(repair_worklist_path) if repair_worklist_path.exists() else None,
        "repair_windowless_fallback": str(fallback_manifest_path) if fallback_manifest_path.exists() else None,
    },
    "outputs": {
        "retry_manifest": str(out_manifest_path) if out_manifest_written else None,
    },
    "summary": {
        "target_videos": len(selected_lines),
        "localized_repair_videos": len(localized_video_ids),
        "windowless_auto_fallback_videos": len(fallback_auto_ids),
        "windowless_manual_only_videos": len(manual_only_ids),
        "windowless_excluded_preexisting_quarantine_videos": len(fallback_excluded_preexisting_quarantine_ids),
        "rerun_from_stage_counts": {
            row["rerun_from_stage"]: row["video_count"] for row in stage_group_rows
        },
    },
    "target_video_ids": sorted(target_video_ids),
    "targets": target_rows,
    "stage_groups": stage_group_rows,
    "manual_only_video_ids": manual_only_ids[:200],
    "excluded_preexisting_quarantine_video_ids": sorted(fallback_excluded_preexisting_quarantine_ids)[:200],
}
out_meta_path.parent.mkdir(parents=True, exist_ok=True)
out_meta_path.write_text(json.dumps(meta, indent=2) + "\n", encoding="utf-8")

print(f"TARGET_MANIFEST={str(out_manifest_path) if out_manifest_written else ''}")
print(f"TARGET_META={out_meta_path}")
print(f"TARGET_COUNT={len(selected_lines)}")
print(f"LOCALIZED_REPAIR_VIDEOS={len(localized_video_ids)}")
print(f"WINDOWLESS_AUTO_FALLBACK_VIDEOS={len(fallback_auto_ids)}")
print(f"WINDOWLESS_MANUAL_ONLY_VIDEOS={len(manual_only_ids)}")
print(f"WINDOWLESS_EXCLUDED_PREEXISTING_QUARANTINE_VIDEOS={len(fallback_excluded_preexisting_quarantine_ids)}")
PYEOF
}

