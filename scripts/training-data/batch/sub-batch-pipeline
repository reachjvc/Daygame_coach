#!/usr/bin/env bash
#
# scripts/training-data/batch/sub-batch-pipeline
#
# Pipeline orchestrator for sub-batches. Runs stages with automatic
# post-stage validation, bounded auto-repair retries, and quarantine-and-continue.
#
# Operator entrypoint (recommended):
#   ./scripts/training-data/batch/run-campaign --start P001.4 --end P003.10
#
# Usage (low-level orchestrator):
#   A) Sub-batch run path (implicit run mode):
#      ./sub-batch-pipeline P001.1                   # runs stages 06→09 + validation + auto-repair retries
#      ./sub-batch-pipeline P001.1 --from 07         # resume from stage 07
#
#   B) Batch execution (legacy run-all path):
#      ./sub-batch-pipeline P001 --run-all
#      ./sub-batch-pipeline P001 --run-all --count 3  # next 3 incomplete
#
#   C) Operator/debug modes (not the standard production path):
#      ./sub-batch-pipeline P001.1 --stage 06
#      ./sub-batch-pipeline --list
#      ./sub-batch-pipeline P001.1 --status
#      ./sub-batch-pipeline P001 --status
#      ./sub-batch-pipeline P001.1 --view
#      ./sub-batch-pipeline P001.1 --validate
#      ./sub-batch-pipeline P001.1 --approve

