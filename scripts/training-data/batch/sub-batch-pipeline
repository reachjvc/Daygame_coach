done

# Default mode cleanup:
# - Sub-batch ID with no explicit mode => standard pipeline run.
# - Batch ID with no explicit mode => status (avoid accidental run-all).
if [[ -z "$MODE" && -n "$SUB_BATCH_ID" ]]; then
  if is_sub_batch "$SUB_BATCH_ID"; then
    MODE="run_pipeline"
  else
    MODE="status"
  fi
fi

# Handle --list (no sub-batch needed)
if [[ "$MODE" == "list" ]]; then
  list_batches
  exit 0
fi

# Require sub-batch ID for other modes
if [[ -z "$SUB_BATCH_ID" ]]; then
  usage
  exit 1
fi

# Determine if this is a batch ID or sub-batch ID
if is_sub_batch "$SUB_BATCH_ID"; then
  BATCH_ID=$(get_batch_id "$SUB_BATCH_ID")
else
  BATCH_ID="$SUB_BATCH_ID"
fi

if [[ -n "$PARALLEL" ]]; then
  if ! [[ "$PARALLEL" =~ ^[1-9][0-9]*$ ]]; then
    error "--parallel must be a positive integer"
  fi
fi
if [[ -n "$RUN_ALL_PARALLEL" ]]; then
  if ! [[ "$RUN_ALL_PARALLEL" =~ ^[1-9][0-9]*$ ]]; then
    error "--sub-batch-parallel must be a positive integer"
  fi
fi
if [[ -n "$RUN_ALL_MAX_FAILURES" ]]; then
  if ! [[ "$RUN_ALL_MAX_FAILURES" =~ ^[0-9]+$ ]]; then
    error "--max-failures must be a non-negative integer"
  fi
fi

# Keep the standard pipeline interface clean: these flags are ops/inspection-only.
if [[ "$MODE" == "run_pipeline" || "$MODE" == "run_all" ]]; then
  if [[ -n "$VALIDATE_SOURCE" ]]; then
    error "--source is ops/inspection-only (use ./scripts/training-data/batch/sub-batch-ops ... --validate --source ...)"
  fi
  if [[ -n "$VALIDATE_WAIVER_FILE" ]]; then
    error "--waiver-file is ops/inspection-only (use ./scripts/training-data/batch/sub-batch-ops ... --validate --waiver-file ...)"
  fi
fi

# Standard pipeline default: use conveyor-belt parallel mode unless explicitly overridden.
if [[ "$MODE" == "run_pipeline" || "$MODE" == "run_all" ]]; then
  if [[ -z "$PARALLEL" && -n "${CFG_DEFAULT_PARALLEL_LLM_CALLS:-}" ]]; then
    if [[ "${CFG_DEFAULT_PARALLEL_LLM_CALLS}" =~ ^[1-9][0-9]*$ ]]; then
      PARALLEL="$CFG_DEFAULT_PARALLEL_LLM_CALLS"
      echo "[sub-batch-pipeline] Using configured parallel LLM calls: $PARALLEL"
    fi
  fi
fi
if [[ "$MODE" == "run_all" ]]; then
  if [[ -z "$RUN_ALL_PARALLEL" && -n "${CFG_DEFAULT_PARALLEL_SUB_BATCHES:-}" ]]; then
    if [[ "${CFG_DEFAULT_PARALLEL_SUB_BATCHES}" =~ ^[1-9][0-9]*$ ]]; then
      RUN_ALL_PARALLEL="$CFG_DEFAULT_PARALLEL_SUB_BATCHES"
      echo "[sub-batch-pipeline] Using configured sub-batch concurrency: $RUN_ALL_PARALLEL"
    fi
  fi
  if [[ -z "$RUN_ALL_PARALLEL" ]]; then
    RUN_ALL_PARALLEL="1"
  fi
  if [[ -z "$RUN_ALL_MAX_FAILURES" && -n "${CFG_RUN_ALL_MAX_FAILURES:-}" ]]; then
    if [[ "${CFG_RUN_ALL_MAX_FAILURES}" =~ ^[1-9][0-9]*$ ]]; then
      RUN_ALL_MAX_FAILURES="$CFG_RUN_ALL_MAX_FAILURES"
      echo "[sub-batch-pipeline] Using configured run-all max failures: $RUN_ALL_MAX_FAILURES"
    fi
  fi
  if [[ "$PARALLEL" =~ ^[1-9][0-9]*$ && "${CFG_MAX_AGGREGATE_LLM_CALLS:-}" =~ ^[1-9][0-9]*$ ]]; then
    local_auto_cap=$((CFG_MAX_AGGREGATE_LLM_CALLS / PARALLEL))
    if [[ "$local_auto_cap" -lt 1 ]]; then
      local_auto_cap=1
    fi
    if [[ "$RUN_ALL_PARALLEL" -gt "$local_auto_cap" ]]; then
      if [[ "$RUN_ALL_ALLOW_AGGREGATE_OVERLOAD" == "true" ]]; then
        echo "[sub-batch-pipeline] WARNING: sub-batch concurrency ($RUN_ALL_PARALLEL) exceeds safe cap ($local_auto_cap) for max_aggregate_llm_calls=${CFG_MAX_AGGREGATE_LLM_CALLS} and --parallel=$PARALLEL."
      else
        echo "[sub-batch-pipeline] Capping sub-batch concurrency to $local_auto_cap to honor max aggregate LLM calls (${CFG_MAX_AGGREGATE_LLM_CALLS})."
        RUN_ALL_PARALLEL="$local_auto_cap"
      fi
    fi
  fi
  if [[ "$RUN_ALL_PARALLEL" =~ ^[1-9][0-9]*$ && "$PARALLEL" =~ ^[1-9][0-9]*$ ]]; then
    local_estimated_llm_load=$((RUN_ALL_PARALLEL * PARALLEL))
    if [[ "$RUN_ALL_PARALLEL" -gt 1 ]]; then
      echo "[sub-batch-pipeline] Estimated aggregate LLM concurrency: $local_estimated_llm_load (${RUN_ALL_PARALLEL} sub-batches x ${PARALLEL} each)"
    fi
    if [[ "${CFG_MAX_AGGREGATE_LLM_CALLS:-}" =~ ^[1-9][0-9]*$ && "$local_estimated_llm_load" -gt "$CFG_MAX_AGGREGATE_LLM_CALLS" ]]; then
      echo "[sub-batch-pipeline] WARNING: estimated aggregate LLM concurrency ($local_estimated_llm_load) exceeds configured max_aggregate_llm_calls (${CFG_MAX_AGGREGATE_LLM_CALLS})."
    fi
  fi
fi

# Execute based on mode
case "$MODE" in
