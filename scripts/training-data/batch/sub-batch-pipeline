# Check if stage is nested (has source/video folder structure)
is_nested_stage() {
  local stage="$1"
  for s in "${NESTED_STAGES[@]}"; do
    [[ "$s" == "$stage" ]] && return 0
  done
  return 1
}

# Create symlink view for a stage
create_stage_view() {
  local sub_id="$1"
  local stage="$2"
  local batch_id
  batch_id=$(get_batch_id "$sub_id")

  local stage_dir="${STAGE_DIRS[$stage]:-}"
  [[ -z "$stage_dir" ]] && return 0

  local pattern="${STAGE_PATTERNS[$stage]}"
  local manifest="$BATCHES_DIR/${sub_id}.txt"
  local view_base="$VIEWS_DIR/$batch_id/$sub_id/$stage_dir"
  local stage_data_root="$DATA_DIR/$stage_dir"
  if [[ -L "$stage_data_root" ]]; then
    stage_data_root=$(realpath "$stage_data_root")
  fi

  # Clear existing view for this stage
  rm -rf "$view_base" 2>/dev/null || true

  local link_count=0
  local pending_count=0

  # Process each video from manifest
  while IFS='|' read -r source folder || [[ -n "$source" ]]; do
    [[ "$source" =~ ^# ]] && continue
    [[ -z "$source" ]] && continue
    # Trim leading/trailing whitespace without collapsing internal spaces
    source="${source#"${source%%[![:space:]]*}"}"
    source="${source%"${source##*[![:space:]]}"}"
    folder="${folder#"${folder%%[![:space:]]*}"}"
    folder="${folder%"${folder##*[![:space:]]}"}"
    vid_id=$(extract_video_id "$folder")
    [[ -z "$vid_id" ]] && continue

    # Create source/video folder structure in view
    local video_view_dir="$view_base/$source/$folder"
    mkdir -p "$video_view_dir"

    local found_file=false

	    if is_nested_stage "$stage"; then
	      # Nested stage: data/<stage>/<source>/<video>/
	      local src_video_dir="$stage_data_root/$source/$folder"
	      if [[ ! -d "$src_video_dir" && -d "$stage_data_root/$source" ]]; then
	        # Folder names in manifests are display-only and can drift (unicode punctuation, title edits).
	        # Resolve nested stage dirs by video_id when the exact folder is missing.
	        while IFS= read -r -d '' d; do
	          local bn
	          bn=$(basename "$d")
	          local alt_id
	          alt_id=$(extract_video_id "$bn")
	          if [[ -n "$alt_id" && "$alt_id" == "$vid_id" ]]; then
	            src_video_dir="$d"
	            break
	          fi
	        done < <(find "$stage_data_root/$source" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
	      fi
	      if [[ -d "$src_video_dir" ]]; then
	        # Symlink all matching files in the video folder
	        while IFS= read -r -d '' f; do
	          found_file=true
          local link_name=$(basename "$f")
          local rel_target
          rel_target=$(realpath --relative-to="$video_view_dir" "$f")
          ln -sf "$rel_target" "$video_view_dir/$link_name" 2>/dev/null || true
          ((++link_count))
        done < <(find "$src_video_dir" -maxdepth 1 -type f -name "$pattern" -print0 2>/dev/null)
      fi
    else
      # Source-scoped stage layout:
      # - Source/video layout: data/<stage>/<source>/<video>/
      # - Source-flat layout:  data/<stage>/<source>/*.json

      # 1) Source-video layout (if present)
      local src_video_dir="$stage_data_root/$source/$folder"
      if [[ -d "$src_video_dir" ]]; then
        while IFS= read -r -d '' f; do
          found_file=true
          local link_name=$(basename "$f")
          local rel_target
          rel_target=$(realpath --relative-to="$video_view_dir" "$f")
          ln -sf "$rel_target" "$video_view_dir/$link_name" 2>/dev/null || true
          ((++link_count))
        done < <(find "$src_video_dir" -maxdepth 1 -type f -name "$pattern" -print0 2>/dev/null)
      fi

      # 2) Source-flat layout (if present)
      local src_source_dir="$stage_data_root/$source"
      if [[ "$found_file" == false && -d "$src_source_dir" ]]; then
        while IFS= read -r -d '' f; do
          found_file=true
          local link_name=$(basename "$f")
          local rel_target
          rel_target=$(realpath --relative-to="$video_view_dir" "$f")
          ln -sf "$rel_target" "$video_view_dir/$link_name" 2>/dev/null || true
          ((++link_count))
        done < <(find "$src_source_dir" -maxdepth 1 -type f -name "*${vid_id}*" -name "$pattern" -print0 2>/dev/null)
      fi

    fi

    # Create .pending marker if no files found
    if [[ "$found_file" == false ]]; then
      touch "$video_view_dir/.pending"
      ((++pending_count))
    fi
  done < "$manifest"

  echo "  $stage_dir: $link_count files, $pending_count pending"
}

# Create full symlink view for all stages
create_full_view() {
  local sub_id="$1"
  local batch_id
  batch_id=$(get_batch_id "$sub_id")

  echo ""
  echo "=== Creating View for $sub_id ==="
  echo ""

  for stage in "${ALL_STAGES[@]}"; do
    create_stage_view "$sub_id" "$stage"
  done

  echo ""
  echo "Browse: $VIEWS_DIR/$batch_id/$sub_id/"
}

# Update status
update_status() {
  local batch_id="$1"
  local sub_id="$2"
  local new_status="$3"
  local status_file="$BATCHES_DIR/${batch_id}.status.json"

  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  python3 - "$status_file" "$sub_id" "$new_status" "$timestamp" <<'PYEOF'
import json
import sys

status_file, sub_id, new_status, timestamp = sys.argv[1:5]

with open(status_file) as f:
    data = json.load(f)

if sub_id not in data["sub_batches"]:
    print(f"ERROR: Sub-batch {sub_id} not found", file=sys.stderr)
    sys.exit(1)

data["sub_batches"][sub_id]["status"] = new_status
if new_status == "approved":
    data["sub_batches"][sub_id]["approved_at"] = timestamp
elif new_status == "pending_review":
    data["sub_batches"][sub_id]["completed_at"] = timestamp

with open(status_file, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PYEOF
}

# Approve sub-batch
approve_sub_batch() {
  local sub_id="$1"
  local batch_id
  batch_id=$(get_batch_id "$sub_id")

  if [[ "$DRY_RUN" == true ]]; then
    echo "[DRY RUN] Would mark $sub_id as approved"
    return 0
  fi

  update_status "$batch_id" "$sub_id" "approved"

  # Remove symlink view folder
  local view_dir="$VIEWS_DIR/$batch_id/$sub_id"
  if [[ -d "$view_dir" ]]; then
    echo "Removing view folder: $view_dir"
    rm -rf "$view_dir"
  fi

  # Also clean old-style view folder if exists
  local old_view_dir="$DATA_DIR/$sub_id"
  if [[ -d "$old_view_dir" ]]; then
    rm -rf "$old_view_dir"
  fi

  echo "Approved: $sub_id"
}

validate_sub_batch() {
  local sub_id="$1"
  local manifest="$BATCHES_DIR/${sub_id}.txt"
  if [[ ! -f "$manifest" ]]; then
    error "Sub-batch manifest not found: $manifest"
  fi

  local rc=0
  local -a validate_args=(--manifest "$manifest")
  local -a confidence_trace_args=(--manifest "$manifest" --strict-missing)
  local -a batch_report_args=()
  local -a stage_report_check_args=()
  local waiver_file="$VALIDATE_WAIVER_FILE"
  local quarantine_file="$VALIDATE_QUARANTINE_FILE"

  # Always-on: deep checks, stage reports, quarantine emission
  validate_args+=(--quarantine-level "$CFG_QUARANTINE_LEVEL")
  validate_args+=(--check-stage05-audio --check-stage08-report --check-stage09-chunks)
  validate_args+=(--emit-stage-reports --emit-quarantine)

  local stage_reports_dir="$REPO_ROOT/data/validation/stage_reports/$sub_id"

  if [[ -n "$VALIDATE_SOURCE" ]]; then
    validate_args+=(--source "$VALIDATE_SOURCE")
    confidence_trace_args+=(--source "$VALIDATE_SOURCE")
    batch_report_args+=(--source "$VALIDATE_SOURCE")
    stage_report_check_args+=(--source "$VALIDATE_SOURCE")
    stage_reports_dir="$REPO_ROOT/data/validation/stage_reports/${sub_id}.${VALIDATE_SOURCE}"
  else
    batch_report_args+=(--all)
  fi

  # Auto-detect waivers + quarantine
  if [[ -z "$waiver_file" ]]; then
    local auto_waiver="$WAIVERS_DIR/${sub_id}.json"
    if [[ -f "$auto_waiver" ]]; then
      waiver_file="$auto_waiver"
      echo "Using auto-detected waiver file: $waiver_file"
    fi
  fi
  if [[ -z "$quarantine_file" ]]; then
    local auto_quarantine="$QUARANTINE_DIR/${sub_id}.json"
    if [[ -f "$auto_quarantine" ]]; then
      quarantine_file="$auto_quarantine"
      echo "Using auto-detected quarantine file: $quarantine_file"
    fi
  fi

  if [[ -n "$waiver_file" ]]; then
    validate_args+=(--waiver-file "$waiver_file")
  fi
  if [[ -n "$quarantine_file" ]]; then
    validate_args+=(--quarantine-file "$quarantine_file")
    confidence_trace_args+=(--quarantine-file "$quarantine_file")
  fi

  validate_args+=(--stage-reports-dir "$stage_reports_dir")

  echo ""
  echo "=== Validation: $sub_id ==="
  [[ -n "$quarantine_file" ]] && echo "  Quarantine: $quarantine_file"
  [[ -n "$waiver_file" ]] && echo "  Waivers: $waiver_file"
  echo "  Confidence trace policy: strict-only"
  echo ""

  # 1. Manifest + cross-stage validation
  python3 "$REPO_ROOT/scripts/training-data/validation/validate_manifest.py" "${validate_args[@]}" || rc=$?

  # 2. Stage report contract validation + readiness
  echo ""
  echo "=== Confidence Trace Validation ==="
  echo ""
  python3 "$REPO_ROOT/scripts/training-data/validation/validate_confidence_trace.py" \
    "${confidence_trace_args[@]}" || rc=$?

  # 3. Stage report contract validation + readiness
  if [[ -n "$CFG_MAX_WARNING_CHECKS" ]]; then
    stage_report_check_args+=(--max-warning-checks "$CFG_MAX_WARNING_CHECKS")
  fi
  for rule in "${CFG_MAX_WARNING_CHECKS_BY_TYPE[@]}"; do
    stage_report_check_args+=(--max-warning-check "$rule")
  done
  for rule in "${CFG_MAX_WARNING_CHECKS_BY_CLASS[@]}"; do
    stage_report_check_args+=(--max-warning-class "$rule")
  done
  for chk in "${CFG_BLOCK_WARNING_CHECKS[@]}"; do
    stage_report_check_args+=(--block-warning-check "$chk")
  done
  for cls in "${CFG_BLOCK_WARNING_CLASSES[@]}"; do
    stage_report_check_args+=(--block-warning-class "$cls")
  done
  for rule in "${CFG_BLOCK_WARNING_CLASS_BY_CONTENT_TYPE[@]}"; do
    stage_report_check_args+=(--block-warning-class-by-content-type "$rule")
  done
  for rule in "${CFG_REVIEW_WARNING_CLASS_BUDGET_BY_CONTENT_TYPE[@]}"; do
    stage_report_check_args+=(--review-warning-class-budget-by-content-type "$rule")
  done
  if [[ -n "$CFG_REVIEW_VIDEO_DAMAGE_SCORE" ]]; then
    stage_report_check_args+=(--review-video-damage-score "$CFG_REVIEW_VIDEO_DAMAGE_SCORE")
  fi
  if [[ -n "$CFG_BLOCK_VIDEO_DAMAGE_SCORE" ]]; then
    stage_report_check_args+=(--block-video-damage-score "$CFG_BLOCK_VIDEO_DAMAGE_SCORE")
  fi
  if [[ -n "$CFG_REVIEW_DAMAGED_CHUNK_RATIO" ]]; then
    stage_report_check_args+=(--review-damaged-chunk-ratio "$CFG_REVIEW_DAMAGED_CHUNK_RATIO")
  fi
  if [[ -n "$CFG_BLOCK_DAMAGED_CHUNK_RATIO" ]]; then
    stage_report_check_args+=(--block-damaged-chunk-ratio "$CFG_BLOCK_DAMAGED_CHUNK_RATIO")
  fi
  if [[ -n "$CFG_REVIEW_WINDOWLESS_VIDEO_DAMAGE_SCORE" ]]; then
    stage_report_check_args+=(--review-windowless-video-damage-score "$CFG_REVIEW_WINDOWLESS_VIDEO_DAMAGE_SCORE")
  fi
  if [[ -n "$CFG_BLOCK_WINDOWLESS_VIDEO_DAMAGE_SCORE" ]]; then
    stage_report_check_args+=(--block-windowless-video-damage-score "$CFG_BLOCK_WINDOWLESS_VIDEO_DAMAGE_SCORE")
  fi
  for rule in "${CFG_REVIEW_WINDOWLESS_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE[@]}"; do
    stage_report_check_args+=(--review-windowless-video-damage-score-by-content-type "$rule")
  done
  for rule in "${CFG_BLOCK_WINDOWLESS_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE[@]}"; do
    stage_report_check_args+=(--block-windowless-video-damage-score-by-content-type "$rule")
  done
  if [[ -n "$CFG_REVIEW_SEVERE_DAMAGE_CHUNK_RATIO" ]]; then
    stage_report_check_args+=(--review-severe-damage-chunk-ratio "$CFG_REVIEW_SEVERE_DAMAGE_CHUNK_RATIO")
  fi
  if [[ -n "$CFG_BLOCK_SEVERE_DAMAGE_CHUNK_RATIO" ]]; then
    stage_report_check_args+=(--block-severe-damage-chunk-ratio "$CFG_BLOCK_SEVERE_DAMAGE_CHUNK_RATIO")
  fi

  echo ""
  echo "=== Stage Report Validation ==="
  echo ""
  python3 "$REPO_ROOT/scripts/training-data/validation/validate_stage_report.py" \
    --dir "$stage_reports_dir" \
    --manifest "$manifest" \
    "${stage_report_check_args[@]}" \
    --emit-canonical-gate \
    --emit-readiness-summary || rc=$?

  # 4. Batch report (statistics + drift detection, no semantic gate in auto mode)
  echo ""
  echo "=== Batch Report ==="
  echo ""
  python3 "$REPO_ROOT/scripts/training-data/validation/batch_report.py" \
    "${batch_report_args[@]}" --manifest "$manifest" --batch-id "$sub_id" --no-write || rc=$?

  # 5. Pipeline scorecard (single JSON artifact for trend tracking / throughput targets)
  local scorecard_label="$sub_id"
  local -a scorecard_args=(--manifest "$manifest")
  if [[ -n "$VALIDATE_SOURCE" ]]; then
    scorecard_label="${sub_id}.${VALIDATE_SOURCE}"
    scorecard_args+=(--source "$VALIDATE_SOURCE")
  fi
  if [[ -n "$quarantine_file" ]]; then
    scorecard_args+=(--quarantine-file "$quarantine_file")
  fi
  if [[ -n "$CFG_MAX_POSITIVE_DAMAGE_WINDOWLESS_RATIO" ]]; then
    scorecard_args+=(--max-positive-damage-windowless-ratio "$CFG_MAX_POSITIVE_DAMAGE_WINDOWLESS_RATIO")
  fi
  local scorecard_out="$REPO_ROOT/data/validation/scorecards/${scorecard_label}.scorecard.json"
  scorecard_args+=(--out "$scorecard_out")

  echo ""
  echo "=== Pipeline Scorecard ==="
  echo ""
  python3 "$REPO_ROOT/scripts/training-data/validation/pipeline_scorecard.py" \
    "${scorecard_args[@]}" >/dev/null || rc=$?
  if [[ -f "$scorecard_out" ]]; then
    python3 - "$scorecard_out" <<'PYEOF' || true
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)
alerts = payload.get("alerts")
if not isinstance(alerts, list) or not alerts:
    sys.exit(0)
print(f"[sub-batch-pipeline] Scorecard alerts: {len(alerts)} (monitoring only; batch not blocked)")
for row in alerts[:3]:
    if not isinstance(row, dict):
        continue
    metric_path = row.get("metric_path")
    metric_value = row.get("metric_value")
    threshold_max = row.get("threshold_max")
    rid = row.get("id")
    print(
        f"[sub-batch-pipeline]   {rid}: {metric_path}={metric_value} "
        f"(threshold_max={threshold_max})"
    )
PYEOF
  fi

  # 6. Ingest quarantine report (dry-run only, no DB writes) so repair/fallback exports
  # always have a current manifest-scoped source of readiness/taxonomy gating outcomes.
  local repair_label="$sub_id"
  local ingest_quarantine_glob="$REPO_ROOT/data/validation/ingest_quarantine/${sub_id}.*.report.json"
  local ingest_quarantine_report_for_repairs=""
  if [[ -n "$VALIDATE_SOURCE" ]]; then
    repair_label="${sub_id}.${VALIDATE_SOURCE}"
    ingest_quarantine_glob="$REPO_ROOT/data/validation/ingest_quarantine/${sub_id}.${VALIDATE_SOURCE}.*.report.json"
  fi
  ingest_quarantine_report_for_repairs="$REPO_ROOT/data/validation/ingest_quarantine/${repair_label}.auto.report.json"

  echo ""
  echo "=== Ingest Readiness/Taxonomy Report (Stage 10 dry-run) ==="
  echo ""
  local tsx_loader="$REPO_ROOT/node_modules/tsx/dist/loader.mjs"
  local ingest10_script="$REPO_ROOT/scripts/training-data/10.EXT.ingest.ts"
  if [[ -f "$tsx_loader" && -f "$ingest10_script" ]]; then
    local -a ingest_gate_cmd=(node --import "$tsx_loader" "$ingest10_script" --manifest "$manifest" --dry-run --quarantine-report-out "$ingest_quarantine_report_for_repairs")
    if [[ -n "$VALIDATE_SOURCE" ]]; then
      ingest_gate_cmd+=(--source "$VALIDATE_SOURCE")
    fi
    if [[ -n "$quarantine_file" && -f "$quarantine_file" ]]; then
      ingest_gate_cmd+=(--quarantine-file "$quarantine_file")
    fi
    if ! "${ingest_gate_cmd[@]}"; then
      local ingest_gate_rc=$?
      echo "[sub-batch-pipeline] Stage 10 dry-run returned non-zero ($ingest_gate_rc); continuing if quarantine report was written."
    fi
    if [[ ! -f "$ingest_quarantine_report_for_repairs" ]]; then
      echo "[sub-batch-pipeline] Stage 10 dry-run did not emit expected report: $ingest_quarantine_report_for_repairs"
      ingest_quarantine_report_for_repairs=""
    fi
  else
    echo "[sub-batch-pipeline] Skipping Stage 10 dry-run report generation (missing tsx loader or ingest script)."
  fi

  # 7. Segment repair worklist (best-effort; uses fresh Stage 10 dry-run report when available)
  local -a repair_args=(--manifest "$manifest")
  local -a ready_spotcheck_threshold_args=()
  if [[ -n "$CFG_READY_SPOTCHECK_MIN_VIDEO_DAMAGE_SCORE" ]]; then
    ready_spotcheck_threshold_args+=(--min-video-damage-score "$CFG_READY_SPOTCHECK_MIN_VIDEO_DAMAGE_SCORE")
  fi
  for rule in "${CFG_READY_SPOTCHECK_MIN_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE[@]}"; do
    ready_spotcheck_threshold_args+=(--min-video-damage-score-by-content-type "$rule")
  done
  if [[ -n "$VALIDATE_SOURCE" ]]; then
    repair_args+=(--source "$VALIDATE_SOURCE")
  fi
  if [[ -n "$ingest_quarantine_report_for_repairs" && -f "$ingest_quarantine_report_for_repairs" ]]; then
    repair_args=(--report "$ingest_quarantine_report_for_repairs")
  fi
  if compgen -G "$ingest_quarantine_glob" >/dev/null; then
    local repair_json_out="$REPO_ROOT/data/validation/repair_worklists/${repair_label}.repair-worklist.json"
    local repair_csv_out="$REPO_ROOT/data/validation/repair_worklists/${repair_label}.repair-worklist.csv"
    local repair_context_out="$REPO_ROOT/data/validation/repair_worklists/${repair_label}.repair-context.json"
    local repair_windowless_fallback_out="$REPO_ROOT/data/validation/repair_worklists/${repair_label}.repair-windowless-fallback.json"
    echo ""
    echo "=== Segment Repair Worklist ==="
    echo ""
    python3 "$REPO_ROOT/scripts/training-data/validation/export_segment_repair_worklist.py" \
      "${repair_args[@]}" \
      --out "$repair_json_out" \
      --csv-out "$repair_csv_out" || rc=$?
    if [[ -f "$repair_json_out" ]]; then
      python3 "$REPO_ROOT/scripts/training-data/validation/materialize_segment_repair_context.py" \
        --worklist "$repair_json_out" \
        --radius "$CFG_REPAIR_CONTEXT_RADIUS" \
        --out "$repair_context_out" || rc=$?
      python3 "$REPO_ROOT/scripts/training-data/validation/export_windowless_damage_fallback_manifest.py" \
        --worklist "$repair_json_out" \
        --out "$repair_windowless_fallback_out" || rc=$?
    fi

    # READY spotcheck packet: low-damage READY windows worth manual inspection.
    # This is intentionally separate from the repair worklist so we can inspect
    # "apparently fine" videos and catch hidden issues before moving on.
    local ready_spotcheck_json_out="$REPO_ROOT/data/validation/repair_worklists/${repair_label}.ready-spotcheck.json"
    local ready_spotcheck_csv_out="$REPO_ROOT/data/validation/repair_worklists/${repair_label}.ready-spotcheck.csv"
    local ready_spotcheck_context_out="$REPO_ROOT/data/validation/repair_worklists/${repair_label}.ready-spotcheck-context.json"
    local ready_spotcheck_windowless_fallback_out="$REPO_ROOT/data/validation/repair_worklists/${repair_label}.ready-spotcheck-windowless-fallback.json"
    echo ""
    echo "=== READY Spotcheck Pack ==="
    echo ""
    python3 "$REPO_ROOT/scripts/training-data/validation/export_segment_repair_worklist.py" \
      "${repair_args[@]}" \
      --status READY \
      "${ready_spotcheck_threshold_args[@]}" \
      --out "$ready_spotcheck_json_out" \
      --csv-out "$ready_spotcheck_csv_out" || rc=$?
    if [[ -f "$ready_spotcheck_json_out" ]]; then
      python3 "$REPO_ROOT/scripts/training-data/validation/materialize_segment_repair_context.py" \
        --worklist "$ready_spotcheck_json_out" \
        --radius "$CFG_READY_SPOTCHECK_CONTEXT_RADIUS" \
        --out "$ready_spotcheck_context_out" || rc=$?
      python3 "$REPO_ROOT/scripts/training-data/validation/export_windowless_damage_fallback_manifest.py" \
        --worklist "$ready_spotcheck_json_out" \
        --out "$ready_spotcheck_windowless_fallback_out" || rc=$?
    fi

    # Consolidated action summary: one artifact with counts/paths for localized
    # repairs, windowless fallback tasks, and READY spotchecks.
    local action_summary_out="$REPO_ROOT/data/validation/repair_worklists/${repair_label}.action-summary.json"
    python3 - "$action_summary_out" \
      "$repair_json_out" \
      "$repair_context_out" \
      "$repair_windowless_fallback_out" \
      "$ready_spotcheck_json_out" \
      "$ready_spotcheck_context_out" \
      "$ready_spotcheck_windowless_fallback_out" <<'PYEOF' || rc=$?
import json
import sys
import time
from pathlib import Path

out_path = Path(sys.argv[1])
paths = {
    "repair_worklist": Path(sys.argv[2]),
    "repair_context": Path(sys.argv[3]),
    "repair_windowless_fallback": Path(sys.argv[4]),
    "ready_spotcheck_worklist": Path(sys.argv[5]),
    "ready_spotcheck_context": Path(sys.argv[6]),
    "ready_spotcheck_windowless_fallback": Path(sys.argv[7]),
}

def load_json(path: Path):
    if not path.exists():
        return None
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None
    return data if isinstance(data, dict) else None

def dict_val(d, *keys, default=None):
    cur = d
    for k in keys:
        if not isinstance(cur, dict):
            return default
        cur = cur.get(k)
    return cur if cur is not None else default

repair_worklist = load_json(paths["repair_worklist"]) or {}
repair_context = load_json(paths["repair_context"]) or {}
repair_windowless = load_json(paths["repair_windowless_fallback"]) or {}
ready_worklist = load_json(paths["ready_spotcheck_worklist"]) or {}
ready_context = load_json(paths["ready_spotcheck_context"]) or {}
ready_windowless = load_json(paths["ready_spotcheck_windowless_fallback"]) or {}

payload = {
    "version": 1,
    "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    "paths": {k: str(v) for k, v in paths.items() if v.exists()},
    "summary": {
        "repair": {
            "localized_windows": int(dict_val(repair_worklist, "summary", "segment_windows", default=0) or 0),
            "localized_videos": int(dict_val(repair_worklist, "summary", "videos", default=0) or 0),
            "windowless_videos": int(dict_val(repair_worklist, "summary", "windowless_damage_videos", default=0) or 0),
            "context_windows_materialized": int(dict_val(repair_context, "materialization", "windows_materialized", default=0) or 0),
            "windowless_fallback_tasks": int(dict_val(repair_windowless, "summary", "windowless_damage_videos", default=0) or 0),
            "windowless_fallback_by_strategy": dict_val(repair_windowless, "summary", "by_strategy", default={}) or {},
        },
        "ready_spotcheck": {
            "localized_windows": int(dict_val(ready_worklist, "summary", "segment_windows", default=0) or 0),
            "localized_videos": int(dict_val(ready_worklist, "summary", "videos", default=0) or 0),
            "windowless_videos": int(dict_val(ready_worklist, "summary", "windowless_damage_videos", default=0) or 0),
            "context_windows_materialized": int(dict_val(ready_context, "materialization", "windows_materialized", default=0) or 0),
            "windowless_fallback_tasks": int(dict_val(ready_windowless, "summary", "windowless_damage_videos", default=0) or 0),
            "windowless_fallback_by_strategy": dict_val(ready_windowless, "summary", "by_strategy", default={}) or {},
        },
    },
}

out_path.parent.mkdir(parents=True, exist_ok=True)
out_path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
print(f"[sub-batch-pipeline] Action summary written: {out_path}")
print(
    "[sub-batch-pipeline]   repair: "
    f"localized_windows={payload['summary']['repair']['localized_windows']}, "
    f"windowless_fallback_tasks={payload['summary']['repair']['windowless_fallback_tasks']}"
)
print(
    "[sub-batch-pipeline]   ready_spotcheck: "
    f"localized_windows={payload['summary']['ready_spotcheck']['localized_windows']}, "
    f"windowless_fallback_tasks={payload['summary']['ready_spotcheck']['windowless_fallback_tasks']}"
)
PYEOF
  else
    echo ""
    echo "=== Segment Repair Worklist ==="
    echo ""
    echo "No ingest quarantine report found yet for $repair_label (skipping repair worklist export)."
  fi

  return "$rc"
}

