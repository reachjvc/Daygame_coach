      shift
      ;;
    --validate)
      warn_operator_mode_direct_use "--validate"
      MODE="validate"
      shift
      ;;
    --run)
      MODE="run_pipeline"
      shift
      ;;
    --run-all)
      MODE="run_all"
      shift
      ;;
    --from)
      [[ $# -lt 2 ]] && error "--from requires a stage"
