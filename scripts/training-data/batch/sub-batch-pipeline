load_pipeline_config() {
  local config_file="$SCRIPT_DIR/pipeline.config.json"
  if [[ ! -f "$config_file" ]]; then
    echo "WARNING: Pipeline config not found: $config_file (using defaults)"
    return 0
  fi

  eval "$(python3 - "$config_file" <<'PYEOF'
import json
import sys

with open(sys.argv[1]) as f:
    cfg = json.load(f)

v = cfg.get("validation", {})
r = v.get("readiness", {})

print(f'CFG_QUARANTINE_LEVEL="{v.get("quarantine_level", "error")}"')
print(f'CFG_MAX_WARNING_CHECKS="{r.get("max_warning_checks", 3)}"')

by_type = r.get("max_warning_checks_by_type", {})
if by_type:
    items = " ".join(f'"{k}={v}"' for k, v in by_type.items())
    print(f'CFG_MAX_WARNING_CHECKS_BY_TYPE=({items})')
else:
    print('CFG_MAX_WARNING_CHECKS_BY_TYPE=()')

blocks = r.get("block_warning_checks", [])
if blocks:
    items = " ".join(f'"{b}"' for b in blocks)
    print(f'CFG_BLOCK_WARNING_CHECKS=({items})')
else:
    print('CFG_BLOCK_WARNING_CHECKS=()')

by_class = r.get("max_warning_checks_by_class", {})
if by_class:
    items = " ".join(f'"{k}={v}"' for k, v in by_class.items())
    print(f'CFG_MAX_WARNING_CHECKS_BY_CLASS=({items})')
else:
    print('CFG_MAX_WARNING_CHECKS_BY_CLASS=()')

block_classes = r.get("block_warning_classes", [])
if block_classes:
    items = " ".join(f'"{b}"' for b in block_classes)
    print(f'CFG_BLOCK_WARNING_CLASSES=({items})')
else:
    print('CFG_BLOCK_WARNING_CLASSES=()')

block_by_type = r.get("block_warning_class_by_content_type", {})
if isinstance(block_by_type, dict) and block_by_type:
    items = []
    for video_type, class_list in block_by_type.items():
        if not isinstance(video_type, str):
            continue
        if not isinstance(class_list, list):
            continue
        for warning_class in class_list:
            if not isinstance(warning_class, str):
                continue
            vt = video_type.strip()
            wc = warning_class.strip()
            if not vt or not wc:
                continue
            items.append(f'"{vt}:{wc}"')
    if items:
        print(f'CFG_BLOCK_WARNING_CLASS_BY_CONTENT_TYPE=({" ".join(items)})')
    else:
        print('CFG_BLOCK_WARNING_CLASS_BY_CONTENT_TYPE=()')
else:
    print('CFG_BLOCK_WARNING_CLASS_BY_CONTENT_TYPE=()')

review_by_type = r.get("review_warning_class_budget_by_content_type", {})
if isinstance(review_by_type, dict) and review_by_type:
    items = []
    for video_type, class_map in review_by_type.items():
        if not isinstance(video_type, str) or not isinstance(class_map, dict):
            continue
        for warning_class, limit in class_map.items():
            items.append(f'"{video_type}:{warning_class}={limit}"')
    if items:
        print(f'CFG_REVIEW_WARNING_CLASS_BUDGET_BY_CONTENT_TYPE=({" ".join(items)})')
    else:
        print('CFG_REVIEW_WARNING_CLASS_BUDGET_BY_CONTENT_TYPE=()')
else:
    print('CFG_REVIEW_WARNING_CLASS_BUDGET_BY_CONTENT_TYPE=()')

def emit_optional_ratio(var_name: str, raw: object) -> None:
    if isinstance(raw, (int, float)) and not isinstance(raw, bool):
        value = float(raw)
        if 0.0 <= value <= 1.0:
            print(f'{var_name}="{value}"')
            return
    print(f'{var_name}=""')

def emit_non_negative_int(var_name: str, raw: object, default: int = 0) -> None:
    if isinstance(raw, bool):
        print(f'{var_name}="{default}"')
        return
    if isinstance(raw, int):
        value = raw
    elif isinstance(raw, float) and raw.is_integer():
        value = int(raw)
    else:
        print(f'{var_name}="{default}"')
        return
    if value < 0:
        value = default
    print(f'{var_name}="{value}"')

def emit_optional_positive_int(var_name: str, raw: object) -> None:
    if isinstance(raw, bool):
        print(f'{var_name}=""')
        return
    if isinstance(raw, int):
        value = raw
    elif isinstance(raw, float) and raw.is_integer():
        value = int(raw)
    else:
        print(f'{var_name}=""')
        return
    if value <= 0:
        print(f'{var_name}=""')
        return
    print(f'{var_name}="{value}"')

def emit_bool_string(var_name: str, raw: object, default: bool) -> None:
    if isinstance(raw, bool):
        print(f'{var_name}="{"true" if raw else "false"}"')
        return
    print(f'{var_name}="{"true" if default else "false"}"')

emit_optional_ratio("CFG_REVIEW_VIDEO_DAMAGE_SCORE", r.get("review_video_damage_score"))
emit_optional_ratio("CFG_BLOCK_VIDEO_DAMAGE_SCORE", r.get("block_video_damage_score"))
emit_optional_ratio("CFG_REVIEW_DAMAGED_CHUNK_RATIO", r.get("review_damaged_chunk_ratio"))
emit_optional_ratio("CFG_BLOCK_DAMAGED_CHUNK_RATIO", r.get("block_damaged_chunk_ratio"))
emit_optional_ratio(
    "CFG_REVIEW_WINDOWLESS_VIDEO_DAMAGE_SCORE",
    r.get("review_windowless_video_damage_score"),
)
emit_optional_ratio(
    "CFG_BLOCK_WINDOWLESS_VIDEO_DAMAGE_SCORE",
    r.get("block_windowless_video_damage_score"),
)
review_windowless_by_type = r.get("review_windowless_video_damage_score_by_content_type", {})
if isinstance(review_windowless_by_type, dict) and review_windowless_by_type:
    items = []
    for video_type, threshold in review_windowless_by_type.items():
        if not isinstance(video_type, str):
            continue
        if isinstance(threshold, bool):
            continue
        if isinstance(threshold, (int, float)):
            value = float(threshold)
            if 0.0 <= value <= 1.0:
                items.append(f'"{video_type.strip()}={value}"')
    if items:
        print(f'CFG_REVIEW_WINDOWLESS_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE=({" ".join(items)})')
    else:
        print('CFG_REVIEW_WINDOWLESS_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE=()')
else:
    print('CFG_REVIEW_WINDOWLESS_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE=()')
block_windowless_by_type = r.get("block_windowless_video_damage_score_by_content_type", {})
if isinstance(block_windowless_by_type, dict) and block_windowless_by_type:
    items = []
    for video_type, threshold in block_windowless_by_type.items():
        if not isinstance(video_type, str):
            continue
        if isinstance(threshold, bool):
            continue
        if isinstance(threshold, (int, float)):
            value = float(threshold)
            if 0.0 <= value <= 1.0:
                items.append(f'"{video_type.strip()}={value}"')
    if items:
        print(f'CFG_BLOCK_WINDOWLESS_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE=({" ".join(items)})')
    else:
        print('CFG_BLOCK_WINDOWLESS_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE=()')
else:
    print('CFG_BLOCK_WINDOWLESS_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE=()')
emit_optional_ratio("CFG_REVIEW_SEVERE_DAMAGE_CHUNK_RATIO", r.get("review_severe_damage_chunk_ratio"))
emit_optional_ratio("CFG_BLOCK_SEVERE_DAMAGE_CHUNK_RATIO", r.get("block_severe_damage_chunk_ratio"))
emit_optional_ratio(
    "CFG_MAX_POSITIVE_DAMAGE_WINDOWLESS_RATIO",
    r.get("max_positive_damage_windowless_ratio"),
)
emit_optional_ratio(
    "CFG_READY_SPOTCHECK_MIN_VIDEO_DAMAGE_SCORE",
    r.get("ready_spotcheck_min_video_damage_score", 0.03),
)
ready_spotcheck_by_type = r.get("ready_spotcheck_min_video_damage_score_by_content_type", {})
if isinstance(ready_spotcheck_by_type, dict) and ready_spotcheck_by_type:
    items = []
    for video_type, threshold in ready_spotcheck_by_type.items():
        if not isinstance(video_type, str):
            continue
        if isinstance(threshold, bool):
            continue
        if isinstance(threshold, (int, float)):
            value = float(threshold)
            if 0.0 <= value <= 1.0:
                items.append(f'"{video_type.strip()}={value}"')
    if items:
        print(f'CFG_READY_SPOTCHECK_MIN_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE=({" ".join(items)})')
    else:
        print('CFG_READY_SPOTCHECK_MIN_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE=()')
else:
    print('CFG_READY_SPOTCHECK_MIN_VIDEO_DAMAGE_SCORE_BY_CONTENT_TYPE=()')
emit_non_negative_int("CFG_REPAIR_CONTEXT_RADIUS", r.get("repair_context_radius", 0), default=0)
emit_non_negative_int(
    "CFG_READY_SPOTCHECK_CONTEXT_RADIUS",
    r.get("ready_spotcheck_context_radius", 0),
    default=0,
)
automation = cfg.get("automation", {})
stage_runtime = automation.get("stage_runtime", {}) if isinstance(automation, dict) else {}
if not isinstance(stage_runtime, dict):
    stage_runtime = {}
emit_non_negative_int("CFG_STAGE_HEARTBEAT_SECS", stage_runtime.get("heartbeat_secs", 60), default=60)
emit_optional_positive_int("CFG_DEFAULT_PARALLEL_LLM_CALLS", automation.get("parallel_llm_calls", 10))
emit_optional_positive_int("CFG_DEFAULT_PARALLEL_SUB_BATCHES", automation.get("parallel_sub_batches", 1))
emit_optional_positive_int("CFG_MAX_AGGREGATE_LLM_CALLS", automation.get("max_aggregate_llm_calls"))
stage_parallel_caps = automation.get("stage_parallel_caps", {}) if isinstance(automation, dict) else {}
if isinstance(stage_parallel_caps, dict):
    items = []
    for stage_key, cap in stage_parallel_caps.items():
        if not isinstance(stage_key, str):
            continue
        key = stage_key.strip()
        if not key or isinstance(cap, bool):
            continue
        if isinstance(cap, float) and cap.is_integer():
            cap = int(cap)
        if isinstance(cap, int) and cap > 0:
            items.append(f'"{key}={cap}"')
    if items:
        print(f'CFG_STAGE_PARALLEL_CAPS=({" ".join(items)})')
    else:
        print('CFG_STAGE_PARALLEL_CAPS=()')
else:
    print('CFG_STAGE_PARALLEL_CAPS=()')
run_all = automation.get("run_all", {}) if isinstance(automation, dict) else {}
if not isinstance(run_all, dict):
    run_all = {}
emit_optional_positive_int("CFG_RUN_ALL_MAX_FAILURES", run_all.get("max_failures"))
emit_bool_string("CFG_RUN_ALL_LOCK_BATCH", run_all.get("lock_batch"), True)
auto_repair = automation.get("auto_repair", {}) if isinstance(automation, dict) else {}
if not isinstance(auto_repair, dict):
    auto_repair = {}
emit_bool_string("CFG_AUTO_REPAIR_ENABLED", auto_repair.get("enabled"), True)
emit_non_negative_int("CFG_AUTO_REPAIR_MAX_ATTEMPTS", auto_repair.get("max_attempts", 1), default=1)
emit_optional_positive_int("CFG_AUTO_REPAIR_LLM_TIMEOUT_SECONDS", auto_repair.get("llm_timeout_seconds"))
emit_optional_positive_int("CFG_AUTO_REPAIR_LLM_RETRIES", auto_repair.get("llm_retries"))
rerun_from_stage = auto_repair.get("rerun_from_stage", "06b")
valid_stages = {"06b", "06c", "06d", "06e", "06f", "06g", "06h", "07", "07b", "08", "09"}
if isinstance(rerun_from_stage, str) and rerun_from_stage in valid_stages:
    print(f'CFG_AUTO_REPAIR_RERUN_FROM_STAGE="{rerun_from_stage}"')
else:
    print('CFG_AUTO_REPAIR_RERUN_FROM_STAGE="06b"')

PYEOF
  )"
}

# Load config at startup
load_pipeline_config

maybe_reroute_to_ops_wrapper() {
  if [[ "${SUB_BATCH_PIPELINE_ALLOW_OPS_DIRECT:-}" == "1" ]]; then
    return 0
  fi
  local ops_wrapper="$SCRIPT_DIR/sub-batch-ops"
  [[ -x "$ops_wrapper" ]] || return 0

  local arg
  for arg in "${ORIG_ARGS[@]}"; do
    case "$arg" in
      --list|--status|--view|--approve|--validate|--stage|--stage=*)
        echo "WARNING: ${arg%%=*} is an ops/inspection mode. Rerouting to ./scripts/training-data/batch/sub-batch-ops." >&2
        exec "$ops_wrapper" "${ORIG_ARGS[@]}"
        ;;
    esac
  done
}

maybe_reroute_to_ops_wrapper

usage() {
  cat <<'EOF'
Usage:
  Canonical operator command:
    ./scripts/training-data/batch/run-campaign --start P001.4 --end P003.10

  Standard pipeline (recommended):
    ./sub-batch-pipeline P001.1                  Run the normal pipeline (06→09 + validation + auto-repair retries + artifacts)
    ./sub-batch-pipeline P001.1 --from 07        Resume the normal pipeline from stage 07
    ./sub-batch-pipeline P001.1 --parallel 10    Normal pipeline in conveyor-belt mode
    ./sub-batch-pipeline P001 --run-all          Run normal pipeline for all incomplete sub-batches
    ./sub-batch-pipeline P001 --run-all --count 3  Run next 3 incomplete sub-batches
    ./sub-batch-pipeline P001 --run-all --sub-batch-parallel 2  Run two sub-batches at once (logs per sub-batch)

  Ops / inspection tools:
    Use ./sub-batch-ops (separate interface for --status/--stage/--validate/--view/--approve/--list)

Options:
  --dry-run                Preview without running
  --from <stage>           Start the standard pipeline from this stage (default: 06)
  --parallel <n>           Override max concurrent LLM calls (conveyor mode is default via config)
  --count <n>              With --run-all, limit to n sub-batches
  --sub-batch-parallel <n> With --run-all, number of sub-batches to execute concurrently
  --max-failures <n>       With --run-all, stop launching new sub-batches after n failures (0 disables)
  --allow-concurrent-run-all  With --run-all, bypass per-batch run lock
  --allow-aggregate-overload  With --run-all, allow estimated aggregate LLM load above configured max
  --source <name>          Operator/debug only (when routed via sub-batch-ops)
  --quarantine-file <path> Override auto-detected quarantine file (run/validate)
  --waiver-file <path>     Operator/debug only (when routed via sub-batch-ops)

Notes:
  For campaign/range execution, use run-campaign instead of invoking this script repeatedly.
  `--run` is optional. If you pass a sub-batch ID and no explicit mode, the standard pipeline runs.
  Direct ops/inspection modes on `sub-batch-pipeline` are deprecated; use `sub-batch-ops`.
  Validation/repair/spotcheck/auto-repair policy is config-driven via pipeline.config.json.

Config: scripts/training-data/batch/pipeline.config.json
  All validation thresholds and policies are configured there.
EOF
}

error() {
  echo "ERROR: $*" >&2
  exit 1
}

warn_operator_mode_direct_use() {
  local flag="$1"
  if [[ "${SUB_BATCH_PIPELINE_ALLOW_OPS_DIRECT:-}" == "1" ]]; then
    return 0
  fi
  echo "WARNING: $flag is an ops/inspection mode. Use ./scripts/training-data/batch/sub-batch-ops instead." >&2
}

release_run_all_lock() {
  if [[ -n "${RUN_ALL_LOCK_FD:-}" ]]; then
    if command -v flock >/dev/null 2>&1; then
      flock -u "$RUN_ALL_LOCK_FD" 2>/dev/null || true
    fi
    exec {RUN_ALL_LOCK_FD}>&-
    RUN_ALL_LOCK_FD=""
  fi
}

acquire_run_all_lock() {
  local batch_id="$1"
  if [[ "$RUN_ALL_ALLOW_CONCURRENT" == "true" ]]; then
    echo "[sub-batch-pipeline] WARNING: bypassing run-all lock for $batch_id (--allow-concurrent-run-all)."
    return 0
  fi
  if [[ "${CFG_RUN_ALL_LOCK_BATCH:-true}" != "true" ]]; then
    echo "[sub-batch-pipeline] Run-all lock disabled by config (automation.run_all.lock_batch=false)."
    return 0
  fi
  if ! command -v flock >/dev/null 2>&1; then
    echo "[sub-batch-pipeline] WARNING: flock not found; cannot enforce run-all lock for $batch_id."
    return 0
  fi

  local lock_dir="$REPO_ROOT/data/validation/run_all_locks"
  local lock_file="$lock_dir/${batch_id}.lock"
  mkdir -p "$lock_dir"

  exec {RUN_ALL_LOCK_FD}>"$lock_file"
  if flock -n "$RUN_ALL_LOCK_FD"; then
    echo "[sub-batch-pipeline] Acquired run-all lock: $lock_file"
    return 0
  fi

  release_run_all_lock
  error "Another --run-all appears active for $batch_id (lock: $lock_file). Use --allow-concurrent-run-all to bypass."
}

