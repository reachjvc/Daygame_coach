      shift
      ;;
    --sub-batch-parallel|--run-all-parallel)
      [[ $# -lt 2 ]] && error "$1 requires a number"
      RUN_ALL_PARALLEL="$2"
      RUN_ALL_PARALLEL_EXPLICIT="true"
      shift 2
      ;;
    --sub-batch-parallel=*|--run-all-parallel=*)
      RUN_ALL_PARALLEL="${1#*=}"
      RUN_ALL_PARALLEL_EXPLICIT="true"
      shift
      ;;
    --max-failures)
      [[ $# -lt 2 ]] && error "--max-failures requires a number"
      RUN_ALL_MAX_FAILURES="$2"
      shift 2
      ;;
    --max-failures=*)
      RUN_ALL_MAX_FAILURES="${1#--max-failures=}"
      shift
      ;;
    --allow-concurrent-run-all)
      RUN_ALL_ALLOW_CONCURRENT="true"
      shift
      ;;
    --allow-aggregate-overload)
      RUN_ALL_ALLOW_AGGREGATE_OVERLOAD="true"
