compare_auto_repair_attempt_readiness() {
  local before_summary="$1"
  local after_summary="$2"
  local target_meta="$3"
  local out_json="$4"

  python3 - "$before_summary" "$after_summary" "$target_meta" "$out_json" <<'PYEOF'
import json
import sys
import time
from pathlib import Path

before_path = Path(sys.argv[1])
after_path = Path(sys.argv[2])
meta_path = Path(sys.argv[3])
out_path = Path(sys.argv[4])

def load_json(path: Path):
    if not path.exists():
        return None
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None
    return data if isinstance(data, dict) else None

def status_severity(status: object) -> int:
    s = str(status or "").strip().upper()
    return {"READY": 0, "REVIEW": 1, "BLOCKED": 2}.get(s, 3)

def parse_score(row: dict) -> float | None:
    if not isinstance(row, dict):
        return None
    dp = row.get("damage_profile")
    if not isinstance(dp, dict):
        return None
    raw = dp.get("video_damage_score")
    if isinstance(raw, bool):
        return None
    if isinstance(raw, (int, float)):
        val = float(raw)
        if val == val and val not in {float("inf"), float("-inf")}:
            return val
    return None

def index_videos(summary: dict | None) -> dict[str, dict]:
    out: dict[str, dict] = {}
    if not isinstance(summary, dict):
        return out
    rows = summary.get("videos")
    if not isinstance(rows, list):
        return out
    for row in rows:
        if not isinstance(row, dict):
            continue
        vid = row.get("video_id")
        if isinstance(vid, str) and vid:
            out[vid] = row
    return out

before = load_json(before_path)
after = load_json(after_path)
meta = load_json(meta_path)
target_ids: list[str] = []
if isinstance(meta, dict):
    ids = meta.get("target_video_ids")
    if isinstance(ids, list):
        target_ids = [x for x in ids if isinstance(x, str) and x]

before_idx = index_videos(before)
after_idx = index_videos(after)
EPS = 0.005

rows = []
improved = 0
regressed = 0
unchanged = 0
status_improved = 0
status_regressed = 0
damage_improved = 0
damage_regressed = 0
resolved_to_ready = 0
still_non_ready = 0

for vid in sorted(set(target_ids)):
    b = before_idx.get(vid) or {}
    a = after_idx.get(vid) or {}
    b_status = str(b.get("status") or "MISSING").strip().upper()
    a_status = str(a.get("status") or "MISSING").strip().upper()
    b_sev = status_severity(b_status)
    a_sev = status_severity(a_status)
    b_score = parse_score(b)
    a_score = parse_score(a)
    delta = None
    if b_score is not None and a_score is not None:
        delta = a_score - b_score

    verdict = "unchanged"
    notes = []
    if a_sev < b_sev:
        verdict = "improved"
        improved += 1
        status_improved += 1
        notes.append("status_improved")
    elif a_sev > b_sev:
        verdict = "regressed"
        regressed += 1
        status_regressed += 1
        notes.append("status_regressed")
    else:
        if delta is not None and delta <= -EPS:
            verdict = "improved"
            improved += 1
            damage_improved += 1
            notes.append("damage_score_improved")
        elif delta is not None and delta >= EPS:
            verdict = "regressed"
            regressed += 1
            damage_regressed += 1
            notes.append("damage_score_regressed")
        else:
            unchanged += 1

    if a_status == "READY":
        resolved_to_ready += 1
    if a_status in {"REVIEW", "BLOCKED"}:
        still_non_ready += 1

    rows.append({
        "video_id": vid,
        "before_status": b_status,
        "after_status": a_status,
        "before_damage_score": round(b_score, 6) if b_score is not None else None,
        "after_damage_score": round(a_score, 6) if a_score is not None else None,
        "damage_score_delta": round(delta, 6) if delta is not None else None,
        "verdict": verdict,
        "notes": notes,
        "before_reason_code": b.get("reason_code") if isinstance(b.get("reason_code"), str) else None,
        "after_reason_code": a.get("reason_code") if isinstance(a.get("reason_code"), str) else None,
    })

payload = {
    "version": 1,
    "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    "inputs": {
        "before_readiness_summary": str(before_path),
        "after_readiness_summary": str(after_path),
        "target_meta": str(meta_path),
    },
    "summary": {
        "target_videos": len(rows),
        "improved": improved,
        "regressed": regressed,
        "unchanged": unchanged,
        "status_improved": status_improved,
        "status_regressed": status_regressed,
        "damage_improved": damage_improved,
        "damage_regressed": damage_regressed,
        "resolved_to_ready": resolved_to_ready,
        "still_non_ready": still_non_ready,
    },
    "videos": rows,
}

out_path.parent.mkdir(parents=True, exist_ok=True)
out_path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")

print(f"IMPROVED={improved}")
print(f"REGRESSED={regressed}")
print(f"UNCHANGED={unchanged}")
print(f"RESOLVED_TO_READY={resolved_to_ready}")
print(f"STILL_NON_READY={still_non_ready}")
print(f"OUT_JSON={out_path}")
PYEOF
}

write_auto_repair_attempt_failure_result() {
  local out_json="$1"
  local sub_id="$2"
  local attempt="$3"
  local phase="$4"
  local failure_rc="${5:-}"
  local before_summary="${6:-}"
  local target_meta="${7:-}"

  python3 - "$out_json" "$sub_id" "$attempt" "$phase" "$failure_rc" "$before_summary" "$target_meta" <<'PYEOF'
import json
import sys
import time
from pathlib import Path

out_path = Path(sys.argv[1])
sub_id = sys.argv[2]
attempt = int(sys.argv[3]) if sys.argv[3].isdigit() else None
phase = sys.argv[4]
failure_rc_raw = sys.argv[5]
before_summary = sys.argv[6]
target_meta = sys.argv[7]

def load_json(path_str: str):
    if not path_str:
        return None
    path = Path(path_str)
    if not path.exists():
        return None
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None
    return data if isinstance(data, dict) else None

target_meta_data = load_json(target_meta)
target_ids = []
if isinstance(target_meta_data, dict):
    ids = target_meta_data.get("target_video_ids")
    if isinstance(ids, list):
        target_ids = [x for x in ids if isinstance(x, str) and x]

failure_rc = None
if failure_rc_raw and failure_rc_raw.lstrip("-").isdigit():
    failure_rc = int(failure_rc_raw)

payload = {
    "version": 1,
    "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    "status": "execution_failed",
    "sub_batch_id": sub_id,
    "attempt": attempt,
    "failure": {
        "phase": phase or "unknown",
        "exit_code": failure_rc,
    },
    "inputs": {
        "before_readiness_summary": before_summary or None,
        "target_meta": target_meta or None,
    },
    "summary": {
        "target_videos": len(target_ids),
    },
    "target_video_ids": target_ids[:500],
}

out_path.parent.mkdir(parents=True, exist_ok=True)
out_path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
print(f"OUT_JSON={out_path}")
PYEOF
}

stage_order_index() {
  local needle="$1"
  local i
  for i in "${!STAGE_ORDER[@]}"; do
    if [[ "${STAGE_ORDER[$i]}" == "$needle" ]]; then
      echo "$i"
      return 0
    fi
  done
  echo "-1"
  return 1
}

later_stage_by_order() {
  local a="$1"
  local b="$2"
  local ia ib
  ia="$(stage_order_index "$a")"
  ib="$(stage_order_index "$b")"
  if ! [[ "$ia" =~ ^-?[0-9]+$ ]]; then ia=-1; fi
  if ! [[ "$ib" =~ ^-?[0-9]+$ ]]; then ib=-1; fi
  if [[ "$ia" -lt 0 ]]; then
    echo "$b"
    return 0
  fi
  if [[ "$ib" -lt 0 ]]; then
    echo "$a"
    return 0
  fi
  if [[ "$ia" -ge "$ib" ]]; then
    echo "$a"
  else
    echo "$b"
  fi
}

iter_auto_repair_stage_groups() {
  local target_meta="$1"
  python3 - "$target_meta" <<'PYEOF'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)
groups = data.get("stage_groups")
if not isinstance(groups, list):
    sys.exit(0)
order = {"06b": 0, "06e": 1, "07": 2}
rows = []
for row in groups:
    if not isinstance(row, dict):
        continue
    stage = row.get("rerun_from_stage")
    manifest = row.get("manifest")
    count = row.get("video_count")
    if not isinstance(stage, str) or not stage:
        continue
    if not isinstance(manifest, str) or not manifest:
        continue
    if not isinstance(count, int):
        if isinstance(count, float) and count.is_integer():
            count = int(count)
        else:
            count = 0
    rows.append((order.get(stage, 99), stage, manifest, max(0, int(count))))
for _, stage, manifest, count in sorted(rows):
    print(f"{stage}\t{manifest}\t{count}")
PYEOF
}

run_stage_range_for_manifest() {
  local sub_id="$1"
  local manifest_path="$2"
  local start_stage="$3"
  local end_stage="${4:-09}"
  local prev_stage_context="${RUN_STAGE_CONTEXT:-standard}"
  RUN_STAGE_CONTEXT="auto_repair"

  if [[ ! -f "$manifest_path" ]]; then
    RUN_STAGE_CONTEXT="$prev_stage_context"
    error "Retry manifest not found: $manifest_path"
  fi

  local start_idx=-1
  local end_idx=-1
  local i
  for i in "${!STAGE_ORDER[@]}"; do
    if [[ "${STAGE_ORDER[$i]}" == "$start_stage" ]]; then
      start_idx=$i
    fi
    if [[ "${STAGE_ORDER[$i]}" == "$end_stage" ]]; then
      end_idx=$i
    fi
  done
  if [[ $start_idx -lt 0 ]]; then
    RUN_STAGE_CONTEXT="$prev_stage_context"
    error "Unknown auto-repair start stage: $start_stage"
  fi
  if [[ $end_idx -lt 0 ]]; then
    RUN_STAGE_CONTEXT="$prev_stage_context"
    error "Unknown auto-repair end stage: $end_stage"
  fi
  if [[ $start_idx -gt $end_idx ]]; then
    RUN_STAGE_CONTEXT="$prev_stage_context"
    error "Invalid auto-repair stage range: $start_stage..$end_stage"
  fi

  local stages=("${STAGE_ORDER[@]:$start_idx:$((end_idx - start_idx + 1))}")
  echo ""
  echo "=== Auto-repair stage rerun ($sub_id) ==="
  echo "  Manifest: $manifest_path"
  echo "  Stages:   ${stages[*]}"
  echo ""

  if [[ -n "${PARALLEL:-}" ]]; then
    local auto_quarantine="$QUARANTINE_DIR/${sub_id}.json"
    local retry_quarantine="$RUN_QUARANTINE_FILE"
    if [[ -z "$retry_quarantine" && -f "$auto_quarantine" ]]; then
      retry_quarantine="$auto_quarantine"
    fi
    local runner_rc=0
    local -a runner_args=("$sub_id" --parallel "$PARALLEL" --from "$start_stage" --manifest "$manifest_path" --skip-end-validation)
    local stage_cap
    for stage_cap in "${CFG_STAGE_PARALLEL_CAPS[@]}"; do
      [[ -n "$stage_cap" ]] && runner_args+=(--stage-parallel-cap "$stage_cap")
    done
    if [[ -n "$retry_quarantine" ]]; then
      runner_args+=(--quarantine-file "$retry_quarantine")
    fi
    if [[ -n "${CFG_AUTO_REPAIR_LLM_TIMEOUT_SECONDS:-}" ]]; then
      runner_args+=(--llm-timeout-seconds "$CFG_AUTO_REPAIR_LLM_TIMEOUT_SECONDS")
    fi
    if [[ -n "${CFG_AUTO_REPAIR_LLM_RETRIES:-}" ]]; then
      runner_args+=(--llm-retries "$CFG_AUTO_REPAIR_LLM_RETRIES")
    fi
    "$REPO_ROOT/.venv/bin/python" -u "$SCRIPT_DIR/pipeline-runner" "${runner_args[@]}" || runner_rc=$?
    RUN_STAGE_CONTEXT="$prev_stage_context"
    echo "Auto-repair rerun failed in parallel pipeline-runner (exit $runner_rc)"
    return "$runner_rc"
  fi

  local stage
  for stage in "${stages[@]}"; do
    run_stage "$sub_id" "$stage" "$manifest_path"
    local rc=$?
    if [[ $rc -eq 2 ]]; then
      echo "Auto-repair rerun: all retry-target videos quarantined at stage $stage"
      RUN_STAGE_CONTEXT="$prev_stage_context"
      return 0
    fi
    if [[ $rc -ne 0 ]]; then
      echo "Auto-repair rerun failed at stage $stage (exit $rc)"
      RUN_STAGE_CONTEXT="$prev_stage_context"
      return "$rc"
    fi
  done
  RUN_STAGE_CONTEXT="$prev_stage_context"
  return 0
}

auto_repair_sub_batch() {
  local sub_id="$1"
  AUTO_REPAIR_ATTEMPTS_RAN_LAST="0"
  AUTO_REPAIR_LAST_REVALIDATE_RC=""
  if [[ "$DRY_RUN" == true ]]; then
    return 0
  fi
  if [[ "${CFG_AUTO_REPAIR_ENABLED:-true}" != "true" ]]; then
    return 0
  fi

  local max_attempts="${CFG_AUTO_REPAIR_MAX_ATTEMPTS:-1}"
  if ! [[ "$max_attempts" =~ ^[0-9]+$ ]]; then
    max_attempts="1"
  fi
  if [[ "$max_attempts" -le 0 ]]; then
    return 0
  fi

  local rerun_from="${CFG_AUTO_REPAIR_RERUN_FROM_STAGE:-06b}"
  local prev_target_count=""
  local prev_attempt_improved_count=""
  local attempt
  local attempts_ran=0

  for (( attempt=1; attempt<=max_attempts; attempt++ )); do
    local target_manifest=""
    local target_meta=""
    local target_count="0"
    local localized_count="0"
    local windowless_auto_count="0"
    local windowless_manual_only_count="0"
    local windowless_excluded_preexisting_count="0"
    while IFS='=' read -r key value; do
      case "$key" in
        TARGET_MANIFEST) target_manifest="$value" ;;
        TARGET_META) target_meta="$value" ;;
        TARGET_COUNT) target_count="$value" ;;
        LOCALIZED_REPAIR_VIDEOS) localized_count="$value" ;;
        WINDOWLESS_AUTO_FALLBACK_VIDEOS) windowless_auto_count="$value" ;;
        WINDOWLESS_MANUAL_ONLY_VIDEOS) windowless_manual_only_count="$value" ;;
        WINDOWLESS_EXCLUDED_PREEXISTING_QUARANTINE_VIDEOS) windowless_excluded_preexisting_count="$value" ;;
      esac
    done < <(build_auto_repair_retry_manifest "$sub_id" "$attempt")

    if ! [[ "$target_count" =~ ^[0-9]+$ ]]; then
      target_count="0"
    fi
    if [[ "$target_count" -le 0 ]]; then
      if [[ "$attempt" -eq 1 ]]; then
        echo ""
        echo "[sub-batch-pipeline] Auto-repair: no fixable non-READY targets for $sub_id"
      else
        echo ""
        echo "[sub-batch-pipeline] Auto-repair: no remaining fixable non-READY targets after attempt $((attempt - 1))"
      fi
      if [[ "$windowless_manual_only_count" =~ ^[0-9]+$ ]] && [[ "$windowless_manual_only_count" -gt 0 ]]; then
        echo "[sub-batch-pipeline] Auto-repair: $windowless_manual_only_count windowless video(s) still require manual review"
      fi
      break
    fi

    if [[ -n "$prev_target_count" && "$target_count" -ge "$prev_target_count" ]]; then
      local no_prior_improvement=false
      if [[ -z "$prev_attempt_improved_count" ]]; then
        no_prior_improvement=true
      elif [[ "$prev_attempt_improved_count" =~ ^[0-9]+$ && "$prev_attempt_improved_count" -eq 0 ]]; then
        no_prior_improvement=true
      fi
      if [[ "$no_prior_improvement" == true ]]; then
      echo ""
      echo "[sub-batch-pipeline] Auto-repair: stopping (no improvement after previous attempt; targets=${target_count}, prev=${prev_target_count})"
      [[ -n "$target_meta" ]] && echo "[sub-batch-pipeline] Auto-repair target summary: $target_meta"
      break
      fi
    fi

    echo ""
    echo "[sub-batch-pipeline] Auto-repair attempt $attempt/$max_attempts for $sub_id"
    echo "[sub-batch-pipeline]   targets=${target_count} localized=${localized_count} windowless_auto=${windowless_auto_count} windowless_manual_only=${windowless_manual_only_count}"
    if [[ "$windowless_excluded_preexisting_count" =~ ^[0-9]+$ ]] && [[ "$windowless_excluded_preexisting_count" -gt 0 ]]; then
      echo "[sub-batch-pipeline]   excluded preexisting-quarantine fallback targets=${windowless_excluded_preexisting_count}"
    fi
    [[ -n "$target_meta" ]] && echo "[sub-batch-pipeline]   target summary: $target_meta"
    if [[ -n "$target_meta" && -f "$target_meta" ]]; then
      python3 - "$target_meta" <<'PYEOF' || true
import json
import sys
from pathlib import Path
path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)
counts = (data.get("summary") or {}).get("rerun_from_stage_counts")
if isinstance(counts, dict) and counts:
    print(f"[sub-batch-pipeline]   stage-group targets: {counts}")
PYEOF
    fi

    if [[ -z "$target_manifest" || ! -f "$target_manifest" ]]; then
      echo "[sub-batch-pipeline] Auto-repair: target manifest missing (skipping retries)"
      break
    fi

    local readiness_before_path
    readiness_before_path="$(auto_repair_readiness_summary_path "$sub_id")"
    local attempt_before_snapshot="$REPO_ROOT/data/validation/repair_worklists/${sub_id}.auto-repair.attempt${attempt}.before.readiness-summary.json"
    if [[ -n "$VALIDATE_SOURCE" ]]; then
      attempt_before_snapshot="$REPO_ROOT/data/validation/repair_worklists/${sub_id}.${VALIDATE_SOURCE}.auto-repair.attempt${attempt}.before.readiness-summary.json"
    fi
    local attempt_result_out="$REPO_ROOT/data/validation/repair_worklists/${sub_id}.auto-repair.attempt${attempt}.result.json"
    if [[ -n "$VALIDATE_SOURCE" ]]; then
      attempt_result_out="$REPO_ROOT/data/validation/repair_worklists/${sub_id}.${VALIDATE_SOURCE}.auto-repair.attempt${attempt}.result.json"
    fi
    if [[ -f "$readiness_before_path" ]]; then
      cp -f "$readiness_before_path" "$attempt_before_snapshot" || true
    fi

    local ran_grouped_retry=false
    local retry_rerun_rc=0
    local group_stage group_manifest group_count
    if [[ -n "$target_meta" && -f "$target_meta" ]]; then
      while IFS=$'\t' read -r group_stage group_manifest group_count; do
        [[ -n "$group_stage" ]] || continue
        [[ -n "$group_manifest" ]] || continue
        local effective_group_stage
        effective_group_stage="$(later_stage_by_order "$group_stage" "$rerun_from")"
        echo "[sub-batch-pipeline] Auto-repair group: stage=${group_stage} effective_start=${effective_group_stage} videos=${group_count}"
        retry_rerun_rc=0
        run_stage_range_for_manifest "$sub_id" "$group_manifest" "$effective_group_stage" "09" || retry_rerun_rc=$?
        if [[ "$retry_rerun_rc" -ne 0 ]]; then
          local failed_result_path=""
          while IFS='=' read -r key value; do
            case "$key" in
              OUT_JSON) failed_result_path="$value" ;;
            esac
          done < <(write_auto_repair_attempt_failure_result "$attempt_result_out" "$sub_id" "$attempt" "retry_rerun" "$retry_rerun_rc" "$attempt_before_snapshot" "$target_meta")
          [[ -n "$failed_result_path" ]] && echo "[sub-batch-pipeline]   attempt result artifact: $failed_result_path"
          return "$retry_rerun_rc"
        fi
        ran_grouped_retry=true
      done < <(iter_auto_repair_stage_groups "$target_meta")
    fi
    if [[ "$ran_grouped_retry" != true ]]; then
      retry_rerun_rc=0
      run_stage_range_for_manifest "$sub_id" "$target_manifest" "$rerun_from" "09" || retry_rerun_rc=$?
      if [[ "$retry_rerun_rc" -ne 0 ]]; then
        local failed_result_path=""
        while IFS='=' read -r key value; do
          case "$key" in
            OUT_JSON) failed_result_path="$value" ;;
          esac
        done < <(write_auto_repair_attempt_failure_result "$attempt_result_out" "$sub_id" "$attempt" "retry_rerun" "$retry_rerun_rc" "$attempt_before_snapshot" "$target_meta")
        [[ -n "$failed_result_path" ]] && echo "[sub-batch-pipeline]   attempt result artifact: $failed_result_path"
        return "$retry_rerun_rc"
      fi
    fi
    attempts_ran=$attempt
    prev_target_count="$target_count"

    echo ""
    echo "[sub-batch-pipeline] Auto-repair: revalidating full sub-batch after attempt $attempt"
    local revalidate_rc=0
    validate_sub_batch "$sub_id" || revalidate_rc=$?
    AUTO_REPAIR_LAST_REVALIDATE_RC="$revalidate_rc"
    if [[ "$revalidate_rc" -ne 0 ]]; then
      local failed_result_path=""
      while IFS='=' read -r key value; do
        case "$key" in
          OUT_JSON) failed_result_path="$value" ;;
        esac
      done < <(write_auto_repair_attempt_failure_result "$attempt_result_out" "$sub_id" "$attempt" "revalidate" "$revalidate_rc" "$attempt_before_snapshot" "$target_meta")
      [[ -n "$failed_result_path" ]] && echo "[sub-batch-pipeline]   attempt result artifact: $failed_result_path"
      return "$revalidate_rc"
    fi

    prev_attempt_improved_count="0"
    local readiness_after_path
    readiness_after_path="$(auto_repair_readiness_summary_path "$sub_id")"
    if [[ -f "$attempt_before_snapshot" && -f "$readiness_after_path" && -n "$target_meta" && -f "$target_meta" ]]; then
      local attempt_improved="0"
      local attempt_regressed="0"
      local attempt_unchanged="0"
      local attempt_resolved_ready="0"
      local attempt_still_non_ready="0"
      local attempt_result_path=""
      while IFS='=' read -r key value; do
        case "$key" in
          IMPROVED) attempt_improved="$value" ;;
          REGRESSED) attempt_regressed="$value" ;;
          UNCHANGED) attempt_unchanged="$value" ;;
          RESOLVED_TO_READY) attempt_resolved_ready="$value" ;;
          STILL_NON_READY) attempt_still_non_ready="$value" ;;
          OUT_JSON) attempt_result_path="$value" ;;
        esac
      done < <(compare_auto_repair_attempt_readiness "$attempt_before_snapshot" "$readiness_after_path" "$target_meta" "$attempt_result_out")
      prev_attempt_improved_count="$attempt_improved"
      echo "[sub-batch-pipeline] Auto-repair attempt $attempt result: improved=${attempt_improved} regressed=${attempt_regressed} unchanged=${attempt_unchanged} resolved_to_ready=${attempt_resolved_ready} still_non_ready=${attempt_still_non_ready}"
      [[ -n "$attempt_result_path" ]] && echo "[sub-batch-pipeline]   attempt result artifact: $attempt_result_path"
    else
      echo "[sub-batch-pipeline] Auto-repair attempt $attempt result: readiness diff unavailable"
    fi
  done

  if [[ "$attempts_ran" -gt 0 ]]; then
    AUTO_REPAIR_ATTEMPTS_RAN_LAST="$attempts_ran"
    echo "[sub-batch-pipeline] Auto-repair attempts completed: $attempts_ran"
  fi
  return 0
}

# Extract batch ID from sub-batch ID (P001.1 -> P001)
get_batch_id() {
  local sub_id="$1"
  echo "${sub_id%.*}"
}

# Check if argument looks like a sub-batch (has .N suffix)
is_sub_batch() {
  [[ "$1" =~ \.[0-9]+$ ]]
}

# Extract video ID from filename/path
extract_video_id() {
  local name="$1"
  if [[ "$name" =~ \[([a-zA-Z0-9_-]{11})\] ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

# Load manifest video IDs
load_manifest_ids() {
  local manifest="$1"
  grep -v "^#" "$manifest" | while read -r line; do
    extract_video_id "$line"
  done
}

# List all batches
list_batches() {
  echo ""
  echo "=== All Batches ==="
  echo ""

  for status_file in "$BATCHES_DIR"/*.status.json; do
    [[ -f "$status_file" ]] || continue
    python3 - "$status_file" <<'PYEOF'
import json
import sys

with open(sys.argv[1]) as f:
    data = json.load(f)

batch_id = data["batch_id"]
total = data["total_videos"]
sub_count = len(data["sub_batches"])

# Count statuses
counts = {"approved": 0, "pending_review": 0, "in_progress": 0, "not_started": 0}
for info in data["sub_batches"].values():
    counts[info["status"]] = counts.get(info["status"], 0) + 1

print(f"{batch_id}: {total} videos in {sub_count} sub-batches")
print(f"  approved: {counts['approved']}, pending: {counts['pending_review']}, in_progress: {counts['in_progress']}, not_started: {counts['not_started']}")
PYEOF
  done

  # List batches without status files (not yet split)
  for batch_file in "$BATCHES_DIR"/P*.txt; do
    [[ -f "$batch_file" ]] || continue
    batch_name=$(basename "$batch_file" .txt)
    # Skip sub-batch files (have dots)
    [[ "$batch_name" =~ \. ]] && continue
    status_file="$BATCHES_DIR/${batch_name}.status.json"
    if [[ ! -f "$status_file" ]]; then
      count=$(grep -v "^#" "$batch_file" | grep -c . || echo 0)
      echo "$batch_name: $count videos (not split yet - run sub-batch-create)"
    fi
  done
}

# Show per-stage status for a sub-batch
show_sub_batch_status() {
  local sub_id="$1"
  local batch_id
  batch_id=$(get_batch_id "$sub_id")

  local manifest="$BATCHES_DIR/${sub_id}.txt"
  if [[ ! -f "$manifest" ]]; then
    error "Sub-batch manifest not found: $manifest"
  fi

  # Get video IDs from manifest
  local -a video_ids=()
  while IFS='|' read -r source folder || [[ -n "$source" ]]; do
    [[ "$source" =~ ^# ]] && continue
    [[ -z "$source" ]] && continue
    # Trim leading/trailing whitespace without collapsing internal spaces
    source="${source#"${source%%[![:space:]]*}"}"
    source="${source%"${source##*[![:space:]]}"}"
    folder="${folder#"${folder%%[![:space:]]*}"}"
    folder="${folder%"${folder##*[![:space:]]}"}"
    vid_id=$(extract_video_id "$folder")
    [[ -n "$vid_id" ]] && video_ids+=("$vid_id:$source:$folder")
  done < "$manifest"

  local total=${#video_ids[@]}

  echo ""
  echo "=== Sub-batch $sub_id Status ($total videos) ==="
  echo ""

  for stage in "${RUNNABLE_STAGES[@]}"; do
    local stage_dir="${STAGE_DIRS[$stage]}"
    local pattern="${STAGE_PATTERNS[$stage]}"
    local found=0
    local missing=()

    for entry in "${video_ids[@]}"; do
      IFS=':' read -r vid_id source folder <<< "$entry"

      # Check if output exists for this video
      local found_file=false

      # Search in stage directory
      if [[ -d "$DATA_DIR/$stage_dir" ]]; then
        while IFS= read -r -d '' f; do
          found_file=true
          break
        # Follow symlinks when the stage dir itself is a symlink (common in worktree-based experiments).
        done < <(find -L "$DATA_DIR/$stage_dir" -name "*${vid_id}*" -name "$pattern" -print0 2>/dev/null)
      fi

      if [[ "$found_file" == true ]]; then
        ((++found))
      else
        missing+=("$folder")
      fi
    done

    local status_icon="⬜"
    if [[ $found -eq $total ]]; then
      status_icon="✅"
    elif [[ $found -gt 0 ]]; then
      status_icon="🔶"
    fi

    printf "  %s Stage %s: %d/%d\n" "$status_icon" "$stage" "$found" "$total"

    # Show missing files if partially complete
    if [[ $found -gt 0 && $found -lt $total && ${#missing[@]} -le 5 ]]; then
      for m in "${missing[@]}"; do
        echo "      missing: $m"
      done
    elif [[ ${#missing[@]} -gt 5 ]]; then
      echo "      (${#missing[@]} missing)"
    fi
  done

  echo ""

  # Show current status from status file
  local status_file="$BATCHES_DIR/${batch_id}.status.json"
  if [[ -f "$status_file" ]]; then
    python3 - "$status_file" "$sub_id" <<'PYEOF'
import json
import sys

with open(sys.argv[1]) as f:
    data = json.load(f)

sub_id = sys.argv[2]
info = data["sub_batches"].get(sub_id, {})
status = info.get("status", "unknown")
print(f"Overall status: {status}")
PYEOF
  fi
}

# Show batch-level status (all sub-batches)
show_batch_status() {
  local batch_id="$1"
  local status_file="$BATCHES_DIR/${batch_id}.status.json"

  if [[ ! -f "$status_file" ]]; then
    error "Status file not found: $status_file (run sub-batch-create first)"
  fi

  python3 - "$status_file" <<'PYEOF'
import json
import sys

with open(sys.argv[1]) as f:
    data = json.load(f)

print(f"\nBatch {data['batch_id']} Status")
print(f"Total videos: {data['total_videos']}")
print(f"Sub-batch size: {data['sub_batch_size']}")
print()

status_symbols = {
    "approved": "\u2705",
    "pending_review": "\U0001F50D",
    "in_progress": "\u23F3",
    "not_started": "\u2B1C",
}

for sub_id in sorted(data["sub_batches"].keys(), key=lambda x: int(x.split(".")[-1])):
    info = data["sub_batches"][sub_id]
    status = info["status"]
    symbol = status_symbols.get(status, "?")
    count = info.get("video_count", "?")
    print(f"  {symbol} {sub_id}: {status} ({count} videos)")

# Summary
counts = {}
for info in data["sub_batches"].values():
    s = info["status"]
    counts[s] = counts.get(s, 0) + info.get("video_count", 0)

print()
print("Summary:")
for status in ["approved", "pending_review", "in_progress", "not_started"]:
    if status in counts:
        print(f"  {status}: {counts[status]} videos")
PYEOF
}

# Run a single stage
run_stage() {
  local sub_id="$1"
  local stage="$2"
  local manifest_override="${3:-}"
  local batch_id
  batch_id=$(get_batch_id "$sub_id")

  local manifest="$BATCHES_DIR/${sub_id}.txt"
  if [[ -n "$manifest_override" ]]; then
    manifest="$manifest_override"
  fi
  if [[ ! -f "$manifest" ]]; then
    error "Sub-batch manifest not found: $manifest"
  fi

  local script="${STAGE_SCRIPTS[$stage]:-}"
  if [[ -z "$script" ]]; then
    error "Unknown stage: $stage (valid: ${RUNNABLE_STAGES[*]})"
  fi

  local stage_dir="${STAGE_DIRS[$stage]}"
  local -a stage_args=(--manifest "$manifest")
  if stage_supports_overwrite "$stage"; then
    # Single strict path: always refresh outputs for stages that expose
    # --overwrite to avoid stale downstream artifacts after upstream changes.
    stage_args+=(--overwrite)
  fi
  if stage_supports_apply_repairs "$stage"; then
    stage_args+=(--apply-repairs)
  fi
  if stage_supports_llm_runtime_flags "$stage"; then
    local llm_timeout=""
    local llm_retries=""
    if [[ "${RUN_STAGE_CONTEXT:-standard}" == "auto_repair" ]]; then
      llm_timeout="${CFG_AUTO_REPAIR_LLM_TIMEOUT_SECONDS:-}"
      llm_retries="${CFG_AUTO_REPAIR_LLM_RETRIES:-}"
    fi
    if [[ -n "$llm_timeout" ]]; then
      stage_args+=(--timeout-seconds "$llm_timeout")
    fi
    if [[ -n "$llm_retries" ]]; then
      stage_args+=(--llm-retries "$llm_retries")
    fi
    if [[ "${RUN_STAGE_CONTEXT:-standard}" == "auto_repair" ]] && [[ -n "$llm_timeout" || -n "$llm_retries" ]]; then
      echo "[sub-batch-pipeline] Auto-repair LLM runtime overrides for $stage: timeout=${llm_timeout:-default} retries=${llm_retries:-default}"
    fi
  fi
  local quarantine_file=""
  local auto_quarantine="$QUARANTINE_DIR/${sub_id}.json"

  echo ""
  echo "=== Running Stage $stage for $sub_id ==="
  echo ""

  quarantine_file="$RUN_QUARANTINE_FILE"
  if [[ -z "$quarantine_file" ]]; then
    if [[ -f "$auto_quarantine" ]]; then
      quarantine_file="$auto_quarantine"
    fi
  fi

  if [[ "$DRY_RUN" == true ]]; then
    if stage_supports_quarantine "$stage" && [[ -n "$quarantine_file" ]]; then
      stage_args+=(--quarantine-file "$quarantine_file")
    fi
    echo "[DRY RUN] Would run: $script ${stage_args[*]}"
    return 0
  fi

  if ! run_stage_contract_preflight "$stage" "$manifest" "$quarantine_file"; then
    echo "Stage $stage: CONTRACT PRECHECK FAILED"
    return 1
  fi

  # Update status to in_progress
  local status_file="$BATCHES_DIR/${batch_id}.status.json"
  if [[ -f "$status_file" ]]; then
    python3 - "$status_file" "$sub_id" "$stage" <<'PYEOF'
import json
import sys

status_file, sub_id, stage = sys.argv[1:4]

with open(status_file) as f:
    data = json.load(f)

if sub_id in data["sub_batches"]:
    data["sub_batches"][sub_id]["status"] = "in_progress"
    data["sub_batches"][sub_id]["current_stage"] = stage

with open(status_file, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PYEOF
  fi

  if stage_supports_quarantine "$stage"; then
    if [[ -n "$quarantine_file" && -f "$quarantine_file" ]]; then
      stage_args+=(--quarantine-file "$quarantine_file")
      echo "Using quarantine file: $quarantine_file"
    elif [[ -n "$quarantine_file" ]]; then
      echo "WARNING: Quarantine file not found, ignoring: $quarantine_file"
    fi
  fi

  # Build execution command (TypeScript stages need tsx loader)
  local -a exec_cmd
  if [[ "$script" == *.ts ]]; then
    local tsx_loader="$REPO_ROOT/node_modules/tsx/dist/loader.mjs"
    if [[ ! -f "$tsx_loader" ]]; then
      echo "ERROR: tsx loader not found: $tsx_loader"
      return 1
    fi
    exec_cmd=(node --import "$tsx_loader" "$script")
  else
    exec_cmd=("$script")
  fi

  # Run the stage
  if run_with_heartbeat "stage $stage ($sub_id)" "${exec_cmd[@]}" "${stage_args[@]}"; then
    echo ""
    echo "Stage $stage: COMPLETE"
  else
    local stage_rc=$?
    echo ""
    echo "Stage $stage: FAILED (exit code $stage_rc)"
    # For stage 08, try to quarantine per-video failures instead of hard-failing
    if [[ "$stage" == "08" ]]; then
      local report_file
      report_file=$(find "$DATA_DIR/08.DET.taxonomy-validation" -name "*.report.json" -newer "$manifest" -print -quit 2>/dev/null)
      if [[ -n "$report_file" ]]; then
        echo "--- Checking for per-video quarantine from Stage 08 report ---"
        python3 "$SCRIPT_DIR/quarantine_updater.py" \
          --quarantine-file "$auto_quarantine" \
          --stage08-report "$report_file" 2>&1 || true
      fi
    fi
    return 1
  fi

  # Create symlink view
  create_stage_view "$sub_id" "$stage"

  # --- Post-stage validation hooks ---
  run_post_stage_validation "$sub_id" "$stage" "$manifest" "$auto_quarantine"
  local validate_rc=$?
  if [[ $validate_rc -eq 2 ]]; then
    return 2  # all videos quarantined
  fi

  return 0
}

# Count non-comment lines in manifest
count_manifest_videos() {
  grep -v "^#" "$1" | grep -c . || echo 0
}

# Post-stage validation hooks
run_post_stage_validation() {
  local sub_id="$1"
  local stage="$2"
  local manifest="$3"
  local quarantine_file="$4"

  case "$stage" in
    06b)
      echo ""
      echo "--- Post-stage validation: checking 06b verdicts ---"
      python3 "$SCRIPT_DIR/quarantine_updater.py" \
        --quarantine-file "$quarantine_file" \
        --stage06b-dir "$DATA_DIR/06b.LLM.verify" \
        --manifest "$manifest" 2>&1 || true
      ;;
    07)
      echo ""
      echo "--- Post-stage validation: cross-stage (06/06c vs 07) ---"
      local cross_stage_json
      cross_stage_json=$(python3 "$REPO_ROOT/scripts/training-data/validation/validate_cross_stage.py" \
        --manifest "$manifest" --json 2>/dev/null) || true
      if [[ -n "$cross_stage_json" ]]; then
        echo "$cross_stage_json" | python3 "$SCRIPT_DIR/quarantine_updater.py" \
          --quarantine-file "$quarantine_file" \
          --stage 07 2>&1 || true
        # Show summary
        echo "$cross_stage_json" | python3 -c "
import json, sys
data = json.load(sys.stdin)
s = data.get('summary', {})
errors = s.get('errors', 0)
warnings = s.get('warnings', 0)
total = s.get('total_checks', 0)
status = 'PASS' if errors == 0 else 'FAIL'
print(f'  Cross-stage: {status} ({total} checks, {errors} errors, {warnings} warnings)')
" 2>/dev/null || true
      fi
      ;;
    07b)
      echo ""
      echo "--- Post-stage validation: 07b enrichment verification ---"
      local verify07b_json
      verify07b_json=$(python3 "$REPO_ROOT/scripts/training-data/validation/validate_stage07b.py" \
        --manifest "$manifest" \
        --quarantine-file "$quarantine_file" \
        --json 2>/dev/null) || true
      if [[ -n "$verify07b_json" ]]; then
        echo "$verify07b_json" | python3 "$SCRIPT_DIR/quarantine_updater.py" \
          --quarantine-file "$quarantine_file" \
          --stage 07b 2>&1 || true
        echo "$verify07b_json" | python3 -c "
import json, sys
data = json.load(sys.stdin)
s = data.get('summary', {})
errors = s.get('errors', 0)
warnings = s.get('warnings', 0)
blocked = s.get('blocked_videos', 0)
review = s.get('review_videos', 0)
checked = s.get('checked_files', 0)
status = 'PASS' if errors == 0 else 'FAIL'
print(f'  07b verify: {status} ({checked} files, {errors} errors, {warnings} warnings, block={blocked}, review={review})')
" 2>/dev/null || true
      fi
      ;;
    09)
      echo ""
      echo "--- Post-stage validation: chunk integrity ---"
      local chunks_json
      chunks_json=$(python3 "$REPO_ROOT/scripts/training-data/validation/validate_chunks.py" \
        --manifest "$manifest" --json 2>/dev/null) || true
      if [[ -n "$chunks_json" ]]; then
        echo "$chunks_json" | python3 "$SCRIPT_DIR/quarantine_updater.py" \
          --quarantine-file "$quarantine_file" \
          --stage 09 2>&1 || true
        # Show summary
        echo "$chunks_json" | python3 -c "
import json, sys
data = json.load(sys.stdin)
errors = data.get('issues_summary', {}).get('errors', 0)
warnings = data.get('issues_summary', {}).get('warnings', 0)
files = data.get('processed_files', 0)
status = 'PASS' if errors == 0 else 'FAIL'
print(f'  Chunks: {status} ({files} files, {errors} errors, {warnings} warnings)')
" 2>/dev/null || true
      fi
      ;;
  esac

  # Check if all videos are now quarantined
  if [[ -f "$quarantine_file" ]]; then
    local manifest_count
    manifest_count=$(count_manifest_videos "$manifest")
    local all_quarantined
    all_quarantined=$(python3 -c "
import json, sys
q = json.load(open(sys.argv[1]))
m_count = int(sys.argv[2])
print('yes' if len(q.get('quarantined_video_ids',[])) >= m_count else 'no')
" "$quarantine_file" "$manifest_count" 2>/dev/null) || all_quarantined="no"
    if [[ "$all_quarantined" == "yes" ]]; then
      echo ""
      echo "ALL videos in $sub_id are quarantined. Skipping remaining stages."
      return 2
    fi
  fi

  return 0
}

# Run a command and emit periodic heartbeats while it is still running.
run_with_heartbeat() {
  local label="$1"
  shift

  local hb_secs="${STAGE_HEARTBEAT_SECS:-${CFG_STAGE_HEARTBEAT_SECS:-60}}"
  local start_ts
  start_ts=$(date +%s)

  "$@" &
  local cmd_pid=$!
  local hb_pid=""

  if [[ "$hb_secs" =~ ^[0-9]+$ ]] && [[ "$hb_secs" -gt 0 ]]; then
    (
      while kill -0 "$cmd_pid" 2>/dev/null; do
        sleep "$hb_secs" || exit 0
        kill -0 "$cmd_pid" 2>/dev/null || exit 0
        local now_ts elapsed
        now_ts=$(date +%s)
        elapsed=$((now_ts - start_ts))
        echo "[sub-batch-pipeline] heartbeat: $label still running (${elapsed}s)"
      done
    ) &
    hb_pid=$!
  fi

  local rc=0
  wait "$cmd_pid" || rc=$?

  if [[ -n "$hb_pid" ]]; then
    kill "$hb_pid" 2>/dev/null || true
    wait "$hb_pid" 2>/dev/null || true
  fi

  return "$rc"
}

# Run pipeline: stages sequentially with post-stage validation + end-of-run validation
run_pipeline() {
  local sub_id="$1"
  local start_stage="${2:-06}"

  # Parallel mode: delegate to pipeline-runner (conveyor-belt orchestrator)
  if [[ -n "$PARALLEL" ]]; then
    local runner_args=("$sub_id" --parallel "$PARALLEL" --from "$start_stage")
    local stage_cap
    for stage_cap in "${CFG_STAGE_PARALLEL_CAPS[@]}"; do
      [[ -n "$stage_cap" ]] && runner_args+=(--stage-parallel-cap "$stage_cap")
    done
    if [[ -n "$RUN_QUARANTINE_FILE" ]]; then
      runner_args+=(--quarantine-file "$RUN_QUARANTINE_FILE")
    fi
    if [[ "$DRY_RUN" == true ]]; then
      runner_args+=(--dry-run)
    fi
    local runner_rc=0
    "$REPO_ROOT/.venv/bin/python" -u "$SCRIPT_DIR/pipeline-runner" "${runner_args[@]}" || runner_rc=$?
    if [[ "$DRY_RUN" == true ]]; then
      return "$runner_rc"
    fi
    if [[ $runner_rc -ne 0 && $runner_rc -ne 2 ]]; then
      return "$runner_rc"
    fi

    local auto_repair_rc=0
    auto_repair_sub_batch "$sub_id" || auto_repair_rc=$?
    local recovered_validation_failure=false
    if [[ $runner_rc -eq 2 && $auto_repair_rc -eq 0 && "${AUTO_REPAIR_ATTEMPTS_RAN_LAST:-0}" =~ ^[0-9]+$ && "${AUTO_REPAIR_ATTEMPTS_RAN_LAST:-0}" -gt 0 ]]; then
      if [[ "${AUTO_REPAIR_LAST_REVALIDATE_RC:-}" == "0" ]]; then
        recovered_validation_failure=true
      fi
    fi

    echo ""
    print_pipeline_summary "$sub_id"

    if [[ $auto_repair_rc -ne 0 ]]; then
      return 1
    fi
    if [[ $runner_rc -eq 2 && "$recovered_validation_failure" != true ]]; then
      return 1
    fi
    return 0
  fi

  # --- Sequential mode (original behavior) ---

  # Find start index in STAGE_ORDER
  local start_idx=-1
  for i in "${!STAGE_ORDER[@]}"; do
    if [[ "${STAGE_ORDER[$i]}" == "$start_stage" ]]; then
      start_idx=$i
      break
    fi
  done

  if [[ $start_idx -eq -1 ]]; then
    error "Unknown stage: $start_stage (valid: ${STAGE_ORDER[*]})"
  fi

  local remaining=("${STAGE_ORDER[@]:$start_idx}")
  local manifest="$BATCHES_DIR/${sub_id}.txt"
  local manifest_count
  manifest_count=$(count_manifest_videos "$manifest")

  echo ""
  echo "========================================"
  echo "  Pipeline: $sub_id"
  echo "  Stages: ${remaining[*]}"
  echo "  Videos: $manifest_count"
  echo "  Config: $SCRIPT_DIR/pipeline.config.json"
  echo "========================================"

  local pipeline_failed=false
  for stage in "${remaining[@]}"; do
    run_stage "$sub_id" "$stage"
    local rc=$?
    if [[ $rc -eq 2 ]]; then
      echo ""
      echo "Sub-batch $sub_id: all videos quarantined at stage $stage"
      break
    elif [[ $rc -ne 0 ]]; then
      echo ""
      echo "PIPELINE HALTED at stage $stage (non-zero exit)"
      pipeline_failed=true
      break
    fi
  done

  echo ""
  echo "=== End-of-run validation: $sub_id ==="
  echo ""
  local validate_rc=0
  validate_sub_batch "$sub_id" || validate_rc=$?

  local auto_repair_rc=0
  if [[ "$pipeline_failed" != true ]]; then
    auto_repair_sub_batch "$sub_id" || auto_repair_rc=$?
    if [[ $auto_repair_rc -eq 0 && "${AUTO_REPAIR_ATTEMPTS_RAN_LAST:-0}" =~ ^[0-9]+$ && "${AUTO_REPAIR_ATTEMPTS_RAN_LAST:-0}" -gt 0 ]]; then
      if [[ "${AUTO_REPAIR_LAST_REVALIDATE_RC:-}" == "0" ]]; then
        validate_rc=0
      fi
    fi
  fi

  echo ""
  print_pipeline_summary "$sub_id"

  if [[ "$pipeline_failed" == true || $validate_rc -ne 0 || $auto_repair_rc -ne 0 ]]; then
    return 1
  fi
  return 0
}

# Run all incomplete sub-batches in a batch
run_all_sub_batches() {
  local batch_id="$1"
  local count="${2:-0}"
  local sub_batch_parallel="${3:-1}"
  local max_failures="${4:-0}"
  local status_file="$BATCHES_DIR/${batch_id}.status.json"

  if [[ ! -f "$status_file" ]]; then
    error "Status file not found: $status_file (run sub-batch-create first)"
  fi

  local sub_batches
  sub_batches=$(python3 - "$status_file" "$count" <<'PYEOF'
import json
import sys

with open(sys.argv[1]) as f:
    data = json.load(f)

count = int(sys.argv[2])
found = 0

for sub_id in sorted(data["sub_batches"].keys(), key=lambda x: int(x.split(".")[-1])):
    info = data["sub_batches"][sub_id]
    if info["status"] in ("not_started", "in_progress"):
        print(sub_id)
        found += 1
        if count > 0 and found >= count:
            break
PYEOF
  )

  if [[ -z "$sub_batches" ]]; then
    echo "No incomplete sub-batches found in $batch_id"
    return 0
  fi

  local -a sub_batch_list=()
  mapfile -t sub_batch_list <<< "$sub_batches"
  local total_subs="${#sub_batch_list[@]}"
  local timestamp
  timestamp=$(date -u +"%Y%m%dT%H%M%SZ")
  local run_logs_root="$REPO_ROOT/data/validation/run_all_logs"
  mkdir -p "$run_logs_root"
  local run_logs_dir
  run_logs_dir=$(mktemp -d "$run_logs_root/${batch_id}.${timestamp}.XXXXXX")
  local run_started_epoch
  run_started_epoch=$(date +%s)
  local results_tsv="$run_logs_dir/results.tsv"
  : >"$results_tsv"
  echo ""
  echo "========================================"
  echo "  Batch run: $batch_id ($total_subs sub-batches)"
  echo "  Sub-batches: ${sub_batch_list[*]}"
  echo "  Sub-batch concurrency: $sub_batch_parallel"
  echo "  Run logs: $run_logs_dir"
  echo "========================================"

  local pass_count=0
  local fail_count=0
  local skip_count=0
  local -a passed_subs=()
  local -a failed_subs=()
  local -a skipped_subs=()
  local halt_new_launches="false"
  local halt_reason=""
  local next_index=0

  if ! [[ "$max_failures" =~ ^[1-9][0-9]*$ ]]; then
    max_failures=0
  fi
  if [[ "$max_failures" -gt 0 ]]; then
    echo "  Max failures before halt: $max_failures"
  else
    echo "  Max failures before halt: unlimited"
  fi

  if [[ "$DRY_RUN" == true && "$sub_batch_parallel" -gt 1 ]]; then
    echo "[sub-batch-pipeline] --dry-run with concurrent --run-all is forced to sequential output."
    sub_batch_parallel=1
  fi

  if [[ "$sub_batch_parallel" -le 1 ]]; then
    while [[ "$next_index" -lt "$total_subs" ]]; do
      local sub_id="${sub_batch_list[$next_index]}"
      ((next_index+=1))
      local started_epoch
      started_epoch=$(date +%s)
      local rc=0
      run_pipeline "$sub_id" "${START_STAGE:-06}" || rc=$?
      local ended_epoch
      ended_epoch=$(date +%s)
      local elapsed_sec=$((ended_epoch - started_epoch))
      local status_word="FAIL"
      if [[ $rc -eq 0 ]]; then
        ((++pass_count))
        passed_subs+=("$sub_id")
        status_word="PASS"
      else
        ((++fail_count))
        failed_subs+=("$sub_id")
        echo ""
        echo "Sub-batch $sub_id had failures. Continuing to next sub-batch."
        if [[ "$max_failures" -gt 0 && "$fail_count" -ge "$max_failures" && "$next_index" -lt "$total_subs" ]]; then
          halt_new_launches="true"
          halt_reason="max_failures"
          echo "[sub-batch-pipeline] Reached max failures ($fail_count/$max_failures); halting before remaining sub-batches."
          printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
            "$sub_id" "$status_word" "$rc" "$started_epoch" "$ended_epoch" "$elapsed_sec" "" >>"$results_tsv"
          break
        fi
      fi
      printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
        "$sub_id" "$status_word" "$rc" "$started_epoch" "$ended_epoch" "$elapsed_sec" "" >>"$results_tsv"
    done
  else
    local -a active_pids=()
    declare -A pid_to_sub=()
    declare -A pid_to_log=()
    declare -A pid_to_started_epoch=()

    while [[ "$next_index" -lt "$total_subs" || "${#active_pids[@]}" -gt 0 ]]; do
      while [[ "$halt_new_launches" != "true" && "$next_index" -lt "$total_subs" && "${#active_pids[@]}" -lt "$sub_batch_parallel" ]]; do
        local sub_id="${sub_batch_list[$next_index]}"
        local sub_log="$run_logs_dir/${sub_id}.log"
        local started_epoch
        started_epoch=$(date +%s)
        ((next_index+=1))

        (
          run_pipeline "$sub_id" "${START_STAGE:-06}"
        ) >"$sub_log" 2>&1 &
        local sub_pid=$!
        active_pids+=("$sub_pid")
        pid_to_sub["$sub_pid"]="$sub_id"
        pid_to_log["$sub_pid"]="$sub_log"
        pid_to_started_epoch["$sub_pid"]="$started_epoch"
        echo "[sub-batch-pipeline] Started $sub_id (pid=$sub_pid)"
      done

      if [[ "${#active_pids[@]}" -gt 0 ]]; then
        local finished_pid=""
        local rc=0
        wait -n -p finished_pid "${active_pids[@]}" || rc=$?
        if [[ -z "$finished_pid" ]]; then
          echo "[sub-batch-pipeline] WARNING: sub-batch worker finished without a pid reference."
          continue
        fi
        local sub_id="${pid_to_sub[$finished_pid]:-unknown}"
        local sub_log="${pid_to_log[$finished_pid]:-$run_logs_dir/${sub_id}.log}"
        local started_epoch="${pid_to_started_epoch[$finished_pid]:-0}"
        local ended_epoch
        ended_epoch=$(date +%s)
        local elapsed_sec=0
        if [[ "$started_epoch" =~ ^[0-9]+$ ]]; then
          elapsed_sec=$((ended_epoch - started_epoch))
        fi
        unset "pid_to_sub[$finished_pid]" || true
        unset "pid_to_log[$finished_pid]" || true
        unset "pid_to_started_epoch[$finished_pid]" || true

        local -a remaining_pids=()
        local pid
        for pid in "${active_pids[@]}"; do
          [[ "$pid" == "$finished_pid" ]] && continue
          remaining_pids+=("$pid")
        done
        active_pids=("${remaining_pids[@]}")

        if [[ $rc -eq 0 ]]; then
          ((++pass_count))
          passed_subs+=("$sub_id")
          echo "[sub-batch-pipeline] Finished $sub_id: PASS"
          printf "%s\tPASS\t%s\t%s\t%s\t%s\t%s\n" \
            "$sub_id" "$rc" "$started_epoch" "$ended_epoch" "$elapsed_sec" "$sub_log" >>"$results_tsv"
        else
          ((++fail_count))
          failed_subs+=("$sub_id")
          echo "[sub-batch-pipeline] Finished $sub_id: FAIL (log: $sub_log)"
          printf "%s\tFAIL\t%s\t%s\t%s\t%s\t%s\n" \
            "$sub_id" "$rc" "$started_epoch" "$ended_epoch" "$elapsed_sec" "$sub_log" >>"$results_tsv"
          if [[ "$max_failures" -gt 0 && "$fail_count" -ge "$max_failures" && "$halt_new_launches" != "true" ]]; then
            halt_new_launches="true"
            halt_reason="max_failures"
            local remaining_to_launch=$((total_subs - next_index))
            if [[ "$remaining_to_launch" -gt 0 ]]; then
              echo "[sub-batch-pipeline] Reached max failures ($fail_count/$max_failures); no new sub-batches will be launched."
            fi
          fi
        fi
      fi
      if [[ "$halt_new_launches" == "true" && "${#active_pids[@]}" -eq 0 ]]; then
        break
      fi
    done
  fi

  if [[ "$next_index" -lt "$total_subs" ]]; then
    skipped_subs=("${sub_batch_list[@]:$next_index}")
    for sub_id in "${skipped_subs[@]}"; do
      printf "%s\tSKIP\t\t\t\t\t\n" "$sub_id" >>"$results_tsv"
    done
  fi
  skip_count="${#skipped_subs[@]}"

  local run_finished_epoch
  run_finished_epoch=$(date +%s)
  local run_elapsed_sec=$((run_finished_epoch - run_started_epoch))
  local run_summary_file="$run_logs_dir/summary.txt"
  {
    echo "batch_id=$batch_id"
    echo "generated_at_utc=$timestamp"
    echo "total_sub_batches=$total_subs"
    echo "sub_batch_concurrency=$sub_batch_parallel"
    echo "llm_parallel_per_sub_batch=${PARALLEL:-}"
    echo "run_started_epoch=$run_started_epoch"
    echo "run_finished_epoch=$run_finished_epoch"
    echo "run_elapsed_sec=$run_elapsed_sec"
    echo "pass_count=$pass_count"
    echo "fail_count=$fail_count"
    echo "skip_count=$skip_count"
    echo "halt_reason=${halt_reason:-}"
    echo "max_failures=${max_failures:-0}"
    echo "passed_sub_batches=${passed_subs[*]}"
    echo "failed_sub_batches=${failed_subs[*]}"
    echo "skipped_sub_batches=${skipped_subs[*]}"
  } >"$run_summary_file"
  local run_summary_json="$run_logs_dir/summary.json"
  python3 - "$results_tsv" "$run_summary_json" "$batch_id" "$timestamp" "$total_subs" "$sub_batch_parallel" "${PARALLEL:-}" "$run_started_epoch" "$run_finished_epoch" "$run_elapsed_sec" "$max_failures" "$halt_reason" <<'PYEOF'
import json
import sys

results_path = sys.argv[1]
out_path = sys.argv[2]
batch_id = sys.argv[3]
generated_at = sys.argv[4]
total_sub_batches = int(sys.argv[5]) if sys.argv[5].isdigit() else 0
sub_batch_concurrency = int(sys.argv[6]) if sys.argv[6].isdigit() else 0
llm_parallel = int(sys.argv[7]) if str(sys.argv[7]).isdigit() else None
run_started_epoch = int(sys.argv[8]) if str(sys.argv[8]).isdigit() else None
run_finished_epoch = int(sys.argv[9]) if str(sys.argv[9]).isdigit() else None
run_elapsed_sec = int(sys.argv[10]) if str(sys.argv[10]).isdigit() else None
max_failures = int(sys.argv[11]) if str(sys.argv[11]).isdigit() else 0
halt_reason = (sys.argv[12] or "").strip() or None

rows = []
with open(results_path, encoding="utf-8") as f:
    for raw in f:
        line = raw.rstrip("\n")
        if not line:
            continue
        parts = line.split("\t")
        while len(parts) < 7:
            parts.append("")
        sub_id, status, rc, started, ended, elapsed, log_path = parts[:7]
        rows.append(
            {
                "sub_batch_id": sub_id,
                "status": status,
                "exit_code": int(rc) if rc.lstrip("-").isdigit() else None,
                "started_epoch": int(started) if started.isdigit() else None,
                "finished_epoch": int(ended) if ended.isdigit() else None,
                "elapsed_sec": int(elapsed) if elapsed.lstrip("-").isdigit() else None,
                "log_path": log_path or None,
            }
        )

pass_count = sum(1 for row in rows if row.get("status") == "PASS")
fail_count = sum(1 for row in rows if row.get("status") == "FAIL")
skip_count = sum(1 for row in rows if row.get("status") == "SKIP")

payload = {
    "version": 1,
    "generated_at_utc": generated_at,
    "batch_id": batch_id,
    "summary": {
        "total_sub_batches": total_sub_batches,
        "sub_batch_concurrency": sub_batch_concurrency,
        "llm_parallel_per_sub_batch": llm_parallel,
        "run_started_epoch": run_started_epoch,
        "run_finished_epoch": run_finished_epoch,
        "run_elapsed_sec": run_elapsed_sec,
        "pass_count": pass_count,
        "fail_count": fail_count,
        "skip_count": skip_count,
        "max_failures": max_failures if max_failures > 0 else None,
        "halt_reason": halt_reason,
    },
    "sub_batches": rows,
}

with open(out_path, "w", encoding="utf-8") as f:
    json.dump(payload, f, indent=2, ensure_ascii=False)
    f.write("\n")
PYEOF
  echo "  Run summary: $run_summary_file"
  echo "  Run summary JSON: $run_summary_json"

  echo ""
  echo "========================================"
  echo "  Batch $batch_id complete"
  echo "  Passed: $pass_count / $total_subs"
  if [[ $fail_count -gt 0 ]]; then
    echo "  Failed: $fail_count / $total_subs"
    echo "  Failed sub-batches: ${failed_subs[*]}"
  fi
  if [[ $skip_count -gt 0 ]]; then
    echo "  Skipped: $skip_count / $total_subs"
    echo "  Skipped sub-batches: ${skipped_subs[*]}"
  fi
  if [[ "$halt_reason" == "max_failures" ]]; then
    echo "  Halted early: reached max failures ($fail_count/$max_failures)"
  fi
  echo "========================================"
  echo ""
  show_batch_status "$batch_id"
  if [[ "$fail_count" -gt 0 || "$skip_count" -gt 0 ]]; then
    return 1
  fi
  return 0
}

# Legacy alias
run_from_stage() {
  run_pipeline "$1" "$2"
