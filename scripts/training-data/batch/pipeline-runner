def load_quarantine_video_ids(quarantine_file: Path | None) -> Set[str]:
    ids, _ = load_quarantine_state(quarantine_file)
    return ids


def add_quarantine_reason(vs: VideoState, check: str, message: str) -> None:
    check = LEGACY_QUARANTINE_CHECK_MAP.get(check.strip(), check.strip())
    if check not in vs.quarantine_checks:
        vs.quarantine_checks.add(check)
        vs.quarantine_reasons.append(
            {
                "severity": "error",
                "check": check,
                "message": message[:300],
            }
        )


async def run_contract_preflight(
    stage: Stage,
    manifest_path: str,
    quarantine_file: Path | None,
    log_prefix: str,
) -> int:
    cmd = [
        VENV_PYTHON,
        "-u",
        str(VALIDATION_DIR / "validate_stage_contract.py"),
        "--manifest",
        manifest_path,
        "--stage",
        stage.key,
    ]
    if quarantine_file and quarantine_file.exists():
        cmd.extend(["--quarantine-file", str(quarantine_file)])

    proc = await asyncio.create_subprocess_exec(
        *cmd,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.STDOUT,
    )
    assert proc.stdout is not None
    while True:
        line = await proc.stdout.readline()
        if not line:
            break
        text = line.decode("utf-8", errors="replace").rstrip()
        print(f"{log_prefix} [preflight:{stage.key}] {text}")
    await proc.wait()
    return proc.returncode or 0


def _pick_newest(paths: List[Path]) -> Optional[Path]:
    if not paths:
        return None

    def key(path: Path) -> Tuple[float, str]:
        try:
            return (path.stat().st_mtime, str(path))
        except OSError:
            return (0.0, str(path))

    return max(paths, key=key)


def find_stage_artifact(
    stage_key: str,
    source: str,
    video_id: str,
    suffix: str,
) -> Optional[Path]:
    root = STAGE_OUTPUT_DIRS.get(stage_key)
    if root is None:
        return None
    source_dir = root / source
    if not source_dir.exists():
        return None
    candidates = list(source_dir.rglob(f"*{video_id}*{suffix}"))
    return _pick_newest(candidates)


def resolve_stage07_pair(vs: VideoState) -> Tuple[Optional[Path], Optional[Path]]:
    s07_path = find_stage_artifact("07", vs.source, vs.video_id, ".enriched.json")
    s06_path = find_stage_artifact("06c", vs.source, vs.video_id, ".conversations.json")
    return s06_path, s07_path


async def run_stage_validator_errors(
    stage: Stage,
    vs: VideoState,
    manifest_path: str,
    quarantine_file: Path | None,
    log_prefix: str,
) -> Tuple[Set[str], Dict[str, List[dict]]]:
    if stage.key == "07":
        s06_path, s07_path = resolve_stage07_pair(vs)
        if not (s06_path and s07_path):
            return {
                vs.video_id,
            }, {
                vs.video_id: [
                    {
                        "check": "stage07_validator_inputs_missing",
                        "message": "Missing direct Stage 06c/07 artifacts for cross-stage validation; fail-closed block applied.",
                    }
                ]
            }
        cmd = [
            VENV_PYTHON,
            "-u",
            str(VALIDATION_DIR / "validate_cross_stage.py"),
            "--s06",
            str(s06_path),
            "--s07",
            str(s07_path),
            "--json",
        ]
    elif stage.key == "07b":
        cmd = [
            VENV_PYTHON,
            "-u",
            str(VALIDATION_DIR / "validate_stage07b.py"),
            "--source",
            vs.source,
            "--video-id",
            vs.video_id,
            "--json",
        ]
        if quarantine_file and quarantine_file.exists():
            cmd.extend(["--quarantine-file", str(quarantine_file)])
    elif stage.key == "09":
        cmd = [
            VENV_PYTHON,
            "-u",
            str(VALIDATION_DIR / "validate_chunks.py"),
            "--source",
            vs.source,
            "--video-id",
            vs.video_id,
            "--json",
        ]
    else:
        return set(), {}

    proc = await asyncio.create_subprocess_exec(
        *cmd,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.DEVNULL,
    )
    stdout, _ = await proc.communicate()
    text = stdout.decode("utf-8", errors="replace").strip()
    if not text:
        return set(), {}
    try:
        payload = json.loads(text)
    except json.JSONDecodeError:
        print(f"{log_prefix} [validate:{stage.key}] WARNING: non-JSON validator output")
        return set(), {}
    if not isinstance(payload, dict):
        return set(), {}
    quarantined_ids, quarantined_videos = extract_from_cross_stage_or_chunks(payload, stage_label=stage.key)
    reasons_by_video: Dict[str, List[dict]] = {}
    for row in quarantined_videos:
        if not isinstance(row, dict):
            continue
        vid = row.get("video_id")
        if not isinstance(vid, str) or not vid.strip():
            continue
        reasons = row.get("reasons")
        if not isinstance(reasons, list):
            continue
        for reason in reasons:
            if not isinstance(reason, dict):
                continue
            check = str(reason.get("check", "")).strip()
            message = str(reason.get("message", "")).strip()
            if not check or not message:
                continue
            reasons_by_video.setdefault(vid, []).append(
                {
                    "check": check,
                    "message": message,
                }
            )
    return quarantined_ids, reasons_by_video


def _safe_count_list(value: Any) -> int:
    if isinstance(value, list):
        return len(value)
    return 0


def _stage06b_flag_summary_counts(payload: dict) -> Dict[str, int]:
    counts: Dict[str, int] = {}
    if not isinstance(payload, dict):
        return counts
    metadata = payload.get("metadata")
    if not isinstance(metadata, dict):
        return counts
    flag_summary = metadata.get("flag_summary")
    if not isinstance(flag_summary, dict):
        return counts
    structured_counts = flag_summary.get("structured_flag_class_counts")
    if not isinstance(structured_counts, dict):
        return counts
    for key, raw_value in structured_counts.items():
        if isinstance(raw_value, bool):
            continue
        if isinstance(raw_value, int) and raw_value >= 0:
            counts[str(key)] = raw_value
    return counts


def evaluate_06b_gate(video_id: str, source: str) -> Tuple[bool, Optional[str], Optional[str]]:
    """Fail-closed gate for Stage 06b REJECT + severe FLAG outcomes."""
    verify_dir = DATA_DIR / "06b.LLM.verify" / source
    if not verify_dir.exists():
        return False, None, None
    verification_path = _pick_newest(list(verify_dir.rglob(f"*{video_id}*.verification.json")))
    if verification_path is None:
        return False, None, None
    try:
        payload = json.loads(verification_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return False, None, None

    verdict = str(
        payload.get("verdict") or payload.get("overall_verdict") or ""
    ).strip().upper()
    if verdict == "REJECT":
        return True, "stage06b_reject", "Stage 06b verdict: REJECT"
    if verdict != "FLAG":
        return False, None, None

    transcript_score: Optional[float] = None
    stage06_dir = DATA_DIR / "06.LLM.video-type" / source
    if stage06_dir.exists():
        stage06_path = _pick_newest(list(stage06_dir.rglob(f"*{video_id}*.conversations.json")))
        if stage06_path is not None:
            try:
                stage06_payload = json.loads(stage06_path.read_text(encoding="utf-8"))
                transcript_confidence = stage06_payload.get("transcript_confidence")
                if isinstance(transcript_confidence, dict):
                    raw_score = transcript_confidence.get("score")
                    if isinstance(raw_score, (int, float)) and not isinstance(raw_score, bool):
                        transcript_score = float(raw_score)
            except (json.JSONDecodeError, OSError):
                transcript_score = None

    if (
        transcript_score is not None
        and transcript_score <= STAGE06B_FLAG_LOW_TRANSCRIPT_SCORE_BLOCK_THRESHOLD
    ):
        return (
            True,
            "stage06b_flag_low_transcript_quality",
            (
                "Stage 06b FLAG with low Stage 06 transcript score "
                f"({transcript_score:.1f}<={STAGE06B_FLAG_LOW_TRANSCRIPT_SCORE_BLOCK_THRESHOLD:.1f})."
            ),
        )

    structured_counts = _stage06b_flag_summary_counts(payload)

    misattribution_count = _safe_count_list(payload.get("misattributions"))

    conversation_flag_count = structured_counts.get("conversation_flag")
    if not isinstance(conversation_flag_count, int):
        conversation_flag_count = 0
        conversation_verdicts = payload.get("conversation_verdicts")
        if isinstance(conversation_verdicts, list):
            for row in conversation_verdicts:
                if not isinstance(row, dict):
                    continue
                verdict_text = str(row.get("verdict", "")).strip().upper()
                if verdict_text in {"FLAG", "ISSUE"}:
                    conversation_flag_count += 1

    boundary_major_or_moderate_count = structured_counts.get("boundary_issue_major_or_moderate")
    if not isinstance(boundary_major_or_moderate_count, int):
        boundary_major_or_moderate_count = 0
        boundary_issues = payload.get("boundary_issues")
        if isinstance(boundary_issues, list):
            for row in boundary_issues:
                if not isinstance(row, dict):
                    continue
                severity = str(row.get("severity", "")).strip().lower()
                if severity in {"major", "moderate"}:
                    boundary_major_or_moderate_count += 1

    major_other_flag_count = 0
    missing_target_coverage_count = 0
    other_flags_detailed = payload.get("other_flags_detailed")
    if isinstance(other_flags_detailed, list):
        for row in other_flags_detailed:
            if not isinstance(row, dict):
                continue
            flag_class = str(row.get("flag_class", "")).strip()
            severity = str(row.get("severity", "")).strip().lower()
            if flag_class == "missing_target_coverage":
                missing_target_coverage_count += 1
            if severity == "major":
                major_other_flag_count += 1

    triggered: List[str] = []
    if misattribution_count >= STAGE06B_FLAG_MISATTRIBUTION_BLOCK_THRESHOLD:
        triggered.append(f"misattributions={misattribution_count}")
    if conversation_flag_count >= STAGE06B_FLAG_CONVERSATION_BLOCK_THRESHOLD:
        triggered.append(f"conversation_flags={conversation_flag_count}")
    if boundary_major_or_moderate_count >= STAGE06B_FLAG_BOUNDARY_BLOCK_THRESHOLD:
        triggered.append(f"boundary_major_or_moderate={boundary_major_or_moderate_count}")
    if missing_target_coverage_count >= STAGE06B_FLAG_MISSING_TARGET_COVERAGE_BLOCK_THRESHOLD:
        triggered.append(f"missing_target_coverage={missing_target_coverage_count}")
    if major_other_flag_count >= STAGE06B_FLAG_MAJOR_OTHER_BLOCK_THRESHOLD:
        triggered.append(f"major_other_flags={major_other_flag_count}")

    if not triggered:
        return False, None, None

    details = (
        f"mis={misattribution_count}, conv_flags={conversation_flag_count}, "
        f"boundary_major_or_moderate={boundary_major_or_moderate_count}, "
        f"missing_target_coverage={missing_target_coverage_count}, "
        f"major_other={major_other_flag_count}"
        + (
            f", transcript_score={transcript_score:.1f}"
            if transcript_score is not None
            else ""
        )
    )
    message = f"Stage 06b severe FLAG ({'; '.join(triggered)}). Metrics: {details}."
    return True, "stage06b_flag_severe", message


def evaluate_06_gate(video_id: str, source: str) -> Tuple[bool, Optional[str], Optional[str]]:
    """Fail-closed gate for severe Stage 06 speaker-collapse outcomes."""
    stage06_dir = DATA_DIR / "06.LLM.video-type" / source
    if not stage06_dir.exists():
        return False, None, None

    stage06_path = _pick_newest(list(stage06_dir.rglob(f"*{video_id}*.conversations.json")))
    if stage06_path is None:
        return False, None, None

    try:
        payload = json.loads(stage06_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return False, None, None

    collapse_meta = payload.get("speaker_collapse")
    if not isinstance(collapse_meta, dict) or not bool(collapse_meta.get("detected")):
        return False, None, None

    raw_total_segments = collapse_meta.get("total_segments_affected", 0)
    if not isinstance(raw_total_segments, (int, float)) or isinstance(raw_total_segments, bool):
        return False, None, None
    total_segments_affected = int(raw_total_segments)
    if total_segments_affected < STAGE06_SPEAKER_COLLAPSE_TOTAL_BLOCK_THRESHOLD:
        return False, None, None

    reassignment_rate = collapse_meta.get("reassignment_rate", 0.0)
    if not isinstance(reassignment_rate, (int, float)) or isinstance(reassignment_rate, bool):
        reassignment_rate = 0.0
    unknown_count = collapse_meta.get("unknown_count", 0)
    if not isinstance(unknown_count, (int, float)) or isinstance(unknown_count, bool):
        unknown_count = 0

    transcript_score_text = ""
    transcript_confidence = payload.get("transcript_confidence")
    if isinstance(transcript_confidence, dict):
        raw_score = transcript_confidence.get("score")
        if isinstance(raw_score, (int, float)) and not isinstance(raw_score, bool):
            transcript_score_text = f", transcript_score={int(raw_score)}"

    message = (
        "Stage 06 speaker collapse overload "
        f"(affected_segments={total_segments_affected}>="
        f"{STAGE06_SPEAKER_COLLAPSE_TOTAL_BLOCK_THRESHOLD}, "
        f"reassignment_rate={float(reassignment_rate):.2f}, "
        f"unknown_count={int(unknown_count)}"
        f"{transcript_score_text})."
    )
    return True, "stage06_speaker_collapse_overload", message


def evaluate_06h_gate(video_id: str, source: str) -> Tuple[bool, Optional[str], Optional[str]]:
    """Fail-closed gate on Stage 06h confidence/video-quality block decisions."""
    stage06h_dir = DATA_DIR / "06h.DET.confidence-propagation" / source
    if not stage06h_dir.exists():
        return False, None, None

    stage06h_path = _pick_newest(list(stage06h_dir.rglob(f"*{video_id}*.conversations.json")))
    if stage06h_path is None:
        return False, None, None

    try:
        payload = json.loads(stage06h_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return False, None, None

    video_summary = payload.get("video_summary")
    gate_decision = ""
    reason_codes: List[str] = []
    if isinstance(video_summary, dict):
        gate_decision = str(video_summary.get("gate_decision", "")).strip().lower()
        raw_reasons = video_summary.get("gate_reason_codes")
        if isinstance(raw_reasons, list):
            for row in raw_reasons:
                reason = str(row).strip()
                if reason:
                    reason_codes.append(reason)

    # Backward-compatible fallback: older payloads may only expose confidence_metadata.quality_gate.
    if not gate_decision:
        confidence_meta = payload.get("confidence_metadata")
        if isinstance(confidence_meta, dict):
            quality_gate = confidence_meta.get("quality_gate")
            if isinstance(quality_gate, dict) and bool(quality_gate.get("blocked")):
                gate_decision = "block"
                raw_reasons = quality_gate.get("reason_codes")
                if isinstance(raw_reasons, list):
                    for row in raw_reasons:
                        reason = str(row).strip()
                        if reason:
                            reason_codes.append(reason)

    if gate_decision != "block":
        return False, None, None

    reason_preview = ", ".join(reason_codes[:3]) if reason_codes else "no reason codes provided"
    message = f"Stage 06h video gate: block ({reason_preview})"
    return True, "stage06h_video_gate_block", message


def evaluate_06f_gate(video_id: str, source: str) -> Tuple[bool, Optional[str], Optional[str]]:
    """Fail-closed gate on extreme 06f damage/quality overload."""
    stage06f_dir = DATA_DIR / "06f.DET.damage-map" / source
    if not stage06f_dir.exists():
        return False, None, None

    stage06f_path = _pick_newest(list(stage06f_dir.rglob(f"*{video_id}*.damage-map.json")))
    if stage06f_path is None:
        return False, None, None

    try:
        payload = json.loads(stage06f_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return False, None, None

    segments = payload.get("segments")
    if not isinstance(segments, list):
        return False, None, None

    total_seed_count = 0
    high_seed_count = 0
    for row in segments:
        if not isinstance(row, dict):
            continue
        segment_id = row.get("segment_id")
        if isinstance(segment_id, bool):
            continue
        if not isinstance(segment_id, int):
            continue
        total_seed_count += 1
        severity = str(row.get("severity", "")).strip().lower()
        if severity == "high":
            high_seed_count += 1

    triggered: List[str] = []
    if total_seed_count >= STAGE06F_DAMAGE_SEED_TOTAL_BLOCK_THRESHOLD:
        triggered.append(f"total_seeds={total_seed_count}")
    if high_seed_count >= STAGE06F_DAMAGE_SEED_HIGH_BLOCK_THRESHOLD:
        triggered.append(f"high_severity_seeds={high_seed_count}")

    # Quality-overload guard from Stage 06e summary, aligned with Stage 06h totals gate.
    lq_total_count: Optional[int] = None
    segment_count: Optional[int] = None
    lq_total_ratio = 0.0

    stage06e_dir = DATA_DIR / "06e.LLM.quality-check" / source
    stage06e_path = _pick_newest(list(stage06e_dir.rglob(f"*{video_id}*.quality-check.json"))) if stage06e_dir.exists() else None
    if stage06e_path is not None:
        try:
            stage06e_payload = json.loads(stage06e_path.read_text(encoding="utf-8"))
            summary = stage06e_payload.get("summary")
            if isinstance(summary, dict):
                raw_lq_total = summary.get("low_quality_count", 0)
                raw_segment_count = summary.get("segments_total", 0)
                if isinstance(raw_lq_total, (int, float)) and not isinstance(raw_lq_total, bool):
                    lq_total_count = int(raw_lq_total)
                if isinstance(raw_segment_count, (int, float)) and not isinstance(raw_segment_count, bool):
                    segment_count = int(raw_segment_count)
                if segment_count and segment_count > 0 and lq_total_count is not None:
                    lq_total_ratio = float(lq_total_count) / float(segment_count)
        except (json.JSONDecodeError, OSError, ValueError, TypeError):
            lq_total_count = None
            segment_count = None
            lq_total_ratio = 0.0

    if lq_total_count is not None:
        if lq_total_count >= STAGE06F_LQ_TOTAL_BLOCK_ABSOLUTE_THRESHOLD:
            triggered.append(f"low_quality_total={lq_total_count}")
        if (
            lq_total_count >= STAGE06F_LQ_TOTAL_BLOCK_RATIO_MIN_COUNT
            and lq_total_ratio >= STAGE06F_LQ_TOTAL_BLOCK_RATIO_THRESHOLD
        ):
            triggered.append(
                "low_quality_ratio="
                f"{lq_total_ratio:.4f}>={STAGE06F_LQ_TOTAL_BLOCK_RATIO_THRESHOLD:.2f}"
                f"_mincount_{STAGE06F_LQ_TOTAL_BLOCK_RATIO_MIN_COUNT}"
            )
        if (
            lq_total_count >= STAGE06F_LQ_TOTAL_BLOCK_EXTREME_RATIO_MIN_COUNT
            and lq_total_ratio >= STAGE06F_LQ_TOTAL_BLOCK_EXTREME_RATIO_THRESHOLD
        ):
            triggered.append(
                "low_quality_extreme_ratio="
                f"{lq_total_ratio:.4f}>={STAGE06F_LQ_TOTAL_BLOCK_EXTREME_RATIO_THRESHOLD:.2f}"
                f"_mincount_{STAGE06F_LQ_TOTAL_BLOCK_EXTREME_RATIO_MIN_COUNT}"
            )

    if not triggered:
        return False, None, None

    details = [
        f"total_seeds={total_seed_count}",
        f"high_severity_seeds={high_seed_count}",
        (
            "seed_thresholds("
            f"total>={STAGE06F_DAMAGE_SEED_TOTAL_BLOCK_THRESHOLD}, "
            f"high>={STAGE06F_DAMAGE_SEED_HIGH_BLOCK_THRESHOLD})"
        ),
    ]
    if lq_total_count is not None:
        details.extend(
            [
                f"low_quality_total={lq_total_count}",
                f"segment_count={segment_count if segment_count is not None else 0}",
                f"low_quality_ratio={lq_total_ratio:.4f}",
                (
                    "low_quality_thresholds("
                    f"abs>={STAGE06F_LQ_TOTAL_BLOCK_ABSOLUTE_THRESHOLD}, "
                    f"ratio>={STAGE06F_LQ_TOTAL_BLOCK_RATIO_THRESHOLD:.2f}, "
                    f"ratio_mincount>={STAGE06F_LQ_TOTAL_BLOCK_RATIO_MIN_COUNT}, "
                    f"extreme_ratio>={STAGE06F_LQ_TOTAL_BLOCK_EXTREME_RATIO_THRESHOLD:.2f}, "
                    "extreme_ratio_mincount="
                    f"{STAGE06F_LQ_TOTAL_BLOCK_EXTREME_RATIO_MIN_COUNT})"
                ),
            ]
        )

    has_seed_trigger = (
        total_seed_count >= STAGE06F_DAMAGE_SEED_TOTAL_BLOCK_THRESHOLD
        or high_seed_count >= STAGE06F_DAMAGE_SEED_HIGH_BLOCK_THRESHOLD
    )
    check_key = "stage06f_damage_seed_overload" if has_seed_trigger else "stage06f_low_quality_overload"
    message = (
        f"Stage 06f overload gate ({'; '.join(triggered)}). "
        f"Metrics: {', '.join(details)}."
    )
    return True, check_key, message


def replay_upstream_gates_for_resume(
    vs: VideoState,
    start_stage_key: str,
    progress: Dict[str, str],
    log_prefix: str,
) -> bool:
    """Replay upstream fail-closed gates when a run resumes after their stage."""
    start_idx = STAGE_KEY_INDEX.get(start_stage_key)
    if start_idx is None:
        return False

    gate_specs = [
        (
            "06",
            evaluate_06_gate,
            "stage06_speaker_collapse_overload",
            "Stage 06 speaker-collapse overload blocked this video.",
        ),
        (
            "06b",
            evaluate_06b_gate,
            "stage06b_flag_severe",
            "Stage 06b severe verification failure.",
        ),
        (
            "06f",
            evaluate_06f_gate,
            "stage06f_damage_seed_overload",
            "Stage 06f damage-map overload blocked this video.",
        ),
        (
            "06h",
            evaluate_06h_gate,
            "stage06h_video_gate_block",
            "Stage 06h quality gate blocked this video.",
        ),
    ]

    for gate_stage, evaluator, fallback_check, fallback_message in gate_specs:
        gate_idx = STAGE_KEY_INDEX.get(gate_stage)
        if gate_idx is None or start_idx <= gate_idx:
            continue
        should_quarantine, check_key, message = evaluator(vs.video_id, vs.source)
        if not should_quarantine:
            continue

        vs.status = "quarantined"
        add_quarantine_reason(
            vs,
            check_key or fallback_check,
            message or fallback_message,
        )
        print(
            f"{log_prefix} QUARANTINED: upstream {gate_stage} gate replay -> "
            f"{message or fallback_message}"
        )
        progress[vs.video_id] = "QUARANTINED"
        return True

    return False


def write_quarantine_file(
    quarantine_path: Path,
    quarantined: List[VideoState],
    existing_seed_videos: Optional[List[dict]] = None,
) -> None:
    """Write quarantine file in the standard format."""
    existing_videos = (
        [row for row in (_normalize_quarantine_row(item) for item in (existing_seed_videos or [])) if row]
        if existing_seed_videos is not None
        else load_quarantine_state(quarantine_path)[1]
    )
    rows_by_video: Dict[str, dict] = {
        str(row.get("video_id", "")).strip(): dict(row)
        for row in existing_videos
        if str(row.get("video_id", "")).strip()
    }

    for vs in quarantined:
        checks = sorted(vs.quarantine_checks) if vs.quarantine_checks else ["stage06b_reject"]
        reasons = (
            vs.quarantine_reasons
            if vs.quarantine_reasons
            else [
                {
                    "severity": "error",
                    "check": "stage06b_reject",
                    "message": "Stage 06b verdict: REJECT",
                }
            ]
        )
        normalized_reasons = [row for row in (_normalize_quarantine_reason(reason) for reason in reasons) if row]
        current = rows_by_video.get(vs.video_id, {"video_id": vs.video_id})
        merged_checks = set(current.get("checks", [])) if isinstance(current.get("checks"), list) else set()
        merged_checks.update(checks)
        merged_checks.update(str(reason.get("check", "")).strip() for reason in normalized_reasons if str(reason.get("check", "")).strip())
        merged_reasons = list(current.get("reasons", [])) if isinstance(current.get("reasons"), list) else []
        existing_reason_keys = {
            (str(reason.get("check", "")).strip(), str(reason.get("message", "")).strip())
            for reason in merged_reasons
            if isinstance(reason, dict)
        }
        for reason in normalized_reasons:
            key = (str(reason.get("check", "")).strip(), str(reason.get("message", "")).strip())
            if key not in existing_reason_keys:
                merged_reasons.append(reason)
                existing_reason_keys.add(key)
        current["checks"] = sorted(check for check in merged_checks if str(check).strip())
        if merged_reasons:
            current["reasons"] = merged_reasons
        rows_by_video[vs.video_id] = current

    write_quarantine_payload(quarantine_path, list(rows_by_video.values()))


# ── Per-video pipeline ──────────────────────────────────────────────────────

async def run_video(
    vs: VideoState,
    stages: List[Stage],
    semaphore: asyncio.Semaphore,
    stage_semaphores: Dict[str, asyncio.Semaphore],
    llm_outage_event: asyncio.Event,
    stage_env: Optional[Dict[str, str]],
    quarantine_file: Path | None,
    preexisting_quarantine_ids: Set[str],
    dry_run: bool,
    progress: Dict[str, str],
    llm_timeout_seconds: int | None = None,
    llm_retries: int | None = None,
    force_stages: Optional[Set[str]] = None,
) -> None:
    """Run one video through all stages sequentially."""
    log_prefix = f"[{vs.video_id}]"
    if vs.video_id in preexisting_quarantine_ids:
        vs.status = "skipped_preexisting_quarantine"
        progress[vs.video_id] = "QUARANTINED"
        print(f"{log_prefix} SKIP: already quarantined before run")
        return

    if not dry_run and stages:
        start_stage_key = stages[0].key
        if replay_upstream_gates_for_resume(vs, start_stage_key, progress, log_prefix):
            return

    for stage in stages:
        if llm_outage_event.is_set():
            vs.status = "failed"
            vs.error_stage = stage.key
            vs.error_msg = "global_llm_outage"
            progress[vs.video_id] = "FAIL(llm_outage)"
            print(f"{log_prefix} ABORTED: global LLM outage active; stopping remaining stages")
            return

        vs.current_stage = stage.key
        vs.status = "running"
        progress[vs.video_id] = stage.key

        # Create temp 1-video manifest
        fd, tmp_manifest = tempfile.mkstemp(suffix=".txt", prefix=f"manifest_{vs.video_id}_")
        try:
            with os.fdopen(fd, "w") as f:
                f.write(f"{vs.source} | {vs.folder}\n")

            cmd = build_stage_command(
                stage,
                tmp_manifest,
                quarantine_file,
                llm_timeout_seconds=llm_timeout_seconds,
                llm_retries=llm_retries,
                force_stages=force_stages,
            )

            if dry_run:
                label = "LLM" if stage.needs_llm else "DET"
                print(f"{log_prefix} [{label}] {stage.key}: {' '.join(cmd)}")
                continue

            preflight_rc = await run_contract_preflight(stage, tmp_manifest, quarantine_file, log_prefix)
            if preflight_rc != 0:
                vs.status = "quarantined"
                add_quarantine_reason(
                    vs,
                    f"stage{stage.key}_contract_preflight_fail",
                    f"Stage {stage.key} contract preflight failed (exit {preflight_rc}); fail-closed quarantine.",
                )
                print(f"{log_prefix} QUARANTINED: stage {stage.key} contract preflight failed (exit {preflight_rc})")
                progress[vs.video_id] = "QUARANTINED"
                return

            if stage.needs_llm:
                progress[vs.video_id] = f"{stage.key}(wait)"
                stage_semaphore = stage_semaphores.get(stage.key)
                async with semaphore:
                    if stage_semaphore is not None:
                        async with stage_semaphore:
                            progress[vs.video_id] = f"{stage.key}(llm)"
                            rc, runtime_marker, runtime_excerpt = await run_subprocess(
                                cmd,
                                stage,
                                vs.video_id,
                                log_prefix,
                                env=stage_env,
                            )
                    else:
                        progress[vs.video_id] = f"{stage.key}(llm)"
                        rc, runtime_marker, runtime_excerpt = await run_subprocess(
                            cmd,
                            stage,
                            vs.video_id,
                            log_prefix,
                            env=stage_env,
                        )
            else:
                rc, runtime_marker, runtime_excerpt = await run_subprocess(
                    cmd,
                    stage,
                    vs.video_id,
                    log_prefix,
                    env=stage_env,
                )

            if rc != 0:
                if stage.needs_llm:
                    if runtime_marker == "limit":
                        llm_outage_event.set()
                        vs.status = "failed"
                        vs.error_stage = stage.key
                        vs.error_msg = (
                            f"claude_limit_exhausted: {runtime_excerpt or 'limit marker detected'}"
                        )
                        progress[vs.video_id] = "FAIL(llm_limit)"
                        print(
                            f"{log_prefix} ABORTED: Claude limit marker detected during stage {stage.key}; "
                            "marking as runtime outage (non-quarantine)"
                        )
                        return
                    if runtime_marker == "timeout":
                        vs.status = "failed"
                        vs.error_stage = stage.key
                        vs.error_msg = (
                            f"llm_timeout_during_stage: {runtime_excerpt or 'timeout marker detected'}"
                        )
                        progress[vs.video_id] = "FAIL(llm_timeout)"
                        print(
                            f"{log_prefix} ABORTED: stage {stage.key} hit LLM timeout "
                            f"({runtime_excerpt or 'timeout marker detected'}); "
                            "marking as runtime failure (non-quarantine)."
                        )
                        return
                    llm_ready, llm_reason = await run_llm_capacity_preflight(stage_env)
                    if not llm_ready:
                        llm_outage_event.set()
                        vs.status = "failed"
                        vs.error_stage = stage.key
                        vs.error_msg = f"llm_outage_during_stage: {llm_reason or 'unknown'}"
                        progress[vs.video_id] = "FAIL(llm_outage)"
                        print(
                            f"{log_prefix} ABORTED: stage {stage.key} failed while Claude preflight is unhealthy "
                            f"({llm_reason or 'unknown'}); not quarantining runtime outage."
                        )
                        return
                vs.status = "quarantined"
                add_quarantine_reason(
                    vs,
                    f"stage{stage.key}_execution_error",
                    f"Stage {stage.key} exited non-zero (exit {rc}); fail-closed quarantine.",
                )
                print(f"{log_prefix} QUARANTINED: stage {stage.key} execution failure (exit {rc})")
                progress[vs.video_id] = "QUARANTINED"
                return

            # Post-06: fail-closed gate on severe speaker-collapse overload.
            if stage.key == "06":
                should_quarantine, check_key, message = evaluate_06_gate(vs.video_id, vs.source)
                if should_quarantine:
                    vs.status = "quarantined"
                    add_quarantine_reason(
                        vs,
                        check_key or "stage06_speaker_collapse_overload",
                        message or "Stage 06 speaker-collapse overload blocked this video.",
                    )
                    print(f"{log_prefix} QUARANTINED: {message or 'severe 06 speaker-collapse gate trigger'}")
                    progress[vs.video_id] = "QUARANTINED"
                    return

            # Post-06b: fail-closed gate on REJECT + severe FLAG outcomes.
            if stage.key == "06b":
                should_quarantine, check_key, message = evaluate_06b_gate(vs.video_id, vs.source)
                if should_quarantine:
                    vs.status = "quarantined"
                    add_quarantine_reason(
                        vs,
                        check_key or "stage06b_flag_severe",
                        message or "Stage 06b severe verification failure.",
                    )
                    print(f"{log_prefix} QUARANTINED: {message or 'severe 06b gate trigger'}")
                    progress[vs.video_id] = "QUARANTINED"
                    return

            # Post-06h: fail-closed gate on confidence/quality block decisions.
            if stage.key == "06h":
                should_quarantine, check_key, message = evaluate_06h_gate(vs.video_id, vs.source)
                if should_quarantine:
                    vs.status = "quarantined"
                    add_quarantine_reason(
                        vs,
                        check_key or "stage06h_video_gate_block",
                        message or "Stage 06h quality gate blocked this video.",
                    )
                    print(f"{log_prefix} QUARANTINED: {message or '06h block gate trigger'}")
                    progress[vs.video_id] = "QUARANTINED"
                    return

            # Post-06f: fail-closed gate on extreme damage-map seed overload.
            if stage.key == "06f":
                should_quarantine, check_key, message = evaluate_06f_gate(vs.video_id, vs.source)
                if should_quarantine:
                    vs.status = "quarantined"
                    add_quarantine_reason(
                        vs,
                        check_key or "stage06f_damage_seed_overload",
                        message or "Stage 06f damage-map overload blocked this video.",
                    )
                    print(f"{log_prefix} QUARANTINED: {message or '06f overload gate trigger'}")
                    progress[vs.video_id] = "QUARANTINED"
                    return

            if stage.key in ("07", "07b", "09"):
                error_ids, reasons_by_video = await run_stage_validator_errors(
                    stage,
                    vs,
                    tmp_manifest,
                    quarantine_file,
                    log_prefix,
                )
                if vs.video_id in error_ids:
                    vs.status = "quarantined"
                    reason_rows = reasons_by_video.get(vs.video_id, [])
                    if reason_rows:
                        for reason_row in reason_rows:
                            add_quarantine_reason(
                                vs,
                                str(reason_row.get("check", "")).strip() or f"stage{stage.key}_block",
                                str(reason_row.get("message", "")).strip() or f"Stage {stage.key} validation reported block-level issues.",
                            )
                    else:
                        if stage.key == "07":
                            add_quarantine_reason(
                                vs,
                                "stage07_cross_stage_error",
                                "Stage 07 cross-stage validation reported error severity issues.",
                            )
                        elif stage.key == "07b":
                            add_quarantine_reason(
                                vs,
                                "stage07b_gate_block",
                                "Stage 07b enrichment verification reported block-level issues.",
                            )
                        else:
                            add_quarantine_reason(
                                vs,
                                "stage09_chunk_validation_error",
                                "Stage 09 chunk validation reported error severity issues.",
                            )
                    print(f"{log_prefix} QUARANTINED: stage {stage.key} validation errors")
                    progress[vs.video_id] = "QUARANTINED"
                    return

        finally:
            try:
                os.unlink(tmp_manifest)
            except OSError:
                pass

    vs.status = "done"
    progress[vs.video_id] = "done"
    print(f"[{vs.video_id}] COMPLETE")


# ── Progress display ────────────────────────────────────────────────────────

async def progress_reporter(
    videos: List[VideoState],
    progress: Dict[str, str],
    interval: float = 5.0,
) -> None:
    """Periodically print a status summary line."""
    total = len(videos)
    while True:
        await asyncio.sleep(interval)
        done = sum(1 for v in videos if v.status in ("done", "failed", "quarantined"))
        active = []
        for vid, stage in sorted(progress.items()):
            if stage not in ("done", "QUARANTINED") and "FAIL" not in stage:
                active.append(f"{vid[:7]}:{stage}")
        summary = " ".join(active[:8])
        if len(active) > 8:
            summary += f" +{len(active) - 8}"
        print(f"\n--- [{done}/{total} done] {summary} ---\n")
        if done >= total:
            break


# ── End-of-run validation ───────────────────────────────────────────────────

async def run_end_of_run_validation(
    sub_id: str,
    quarantine_file: Path | None,
) -> int:
    """Run end-of-run validation through the same code path as sequential mode."""
    cmd = ["bash", str(SCRIPT_DIR / "sub-batch-pipeline"), sub_id, "--validate"]
    if quarantine_file and quarantine_file.exists():
        cmd.extend(["--quarantine-file", str(quarantine_file)])

    print("\n=== End-of-run validation (delegated) ===\n")
    proc = await asyncio.create_subprocess_exec(*cmd)
    await proc.wait()
    return proc.returncode or 0


def _contains_limit_marker(text: str) -> bool:
    low = (text or "").lower()
    return any(marker in low for marker in CLAUDE_LIMIT_MARKERS)


def _contains_timeout_marker(text: str) -> bool:
    low = (text or "").lower()
    return any(marker in low for marker in CLAUDE_TIMEOUT_MARKERS)


def _excerpt(text: str, limit: int = 240) -> str:
    cleaned = " ".join((text or "").split())
    if len(cleaned) <= limit:
        return cleaned
    return cleaned[:limit].rstrip() + "..."


def resolve_claude_binary() -> Optional[str]:
    for env_key in ("CLAUDE_BINARY", "CLAUDE_BIN"):
        raw = str(os.environ.get(env_key, "")).strip()
        if not raw:
            continue
        p = Path(raw)
        if p.exists() and p.is_file():
            return str(p)

    resolved = shutil.which("claude")
    if resolved:
        return resolved

    nvm_candidates = sorted(
        Path.home().glob(".nvm/versions/node/*/bin/claude"),
        key=lambda path: path.stat().st_mtime if path.exists() else 0.0,
        reverse=True,
    )
    for cand in nvm_candidates:
        if cand.exists() and cand.is_file():
            return str(cand)

    for cand in CLAUDE_BINARY_PATHS:
        if cand.exists() and cand.is_file():
            return str(cand)
    return None


def build_stage_subprocess_env(claude_binary: Optional[str]) -> Dict[str, str]:
    env = dict(os.environ)
    if not claude_binary:
        return env

    resolved = Path(claude_binary).expanduser()
    if not resolved.is_absolute():
        found = shutil.which(str(claude_binary))
        if found:
            resolved = Path(found)
    claude_path = str(resolved)
    env["CLAUDE_BINARY"] = claude_path
    env["CLAUDE_BIN"] = claude_path

    claude_dir = str(resolved.parent)
    path_raw = env.get("PATH", "")
    path_parts = [p for p in path_raw.split(os.pathsep) if p]
    if claude_dir and claude_dir not in path_parts:
        env["PATH"] = claude_dir + (os.pathsep + path_raw if path_raw else "")
    return env


async def run_llm_capacity_preflight(env: Optional[Dict[str, str]] = None) -> Tuple[bool, Optional[str]]:
    """Fail fast when Claude is globally unavailable or quota-exhausted."""
    claude_bin = resolve_claude_binary()
    if not claude_bin:
        return False, "Claude CLI binary not found in PATH, env, NVM, or known install paths."

    cmd = [
        claude_bin,
        "--model",
        CLAUDE_PREFLIGHT_MODEL,
        "-p",
        CLAUDE_PREFLIGHT_PROMPT,
        "--output-format",
        "text",
        "--tools",
        "",
        "--strict-mcp-config",
        "--no-session-persistence",
    ]
    last_reason = "Claude preflight failed with unknown error."
    for attempt in range(1, CLAUDE_PREFLIGHT_MAX_ATTEMPTS + 1):
        try:
            proc = await asyncio.create_subprocess_exec(
                *cmd,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE,
                env=env,
            )
        except FileNotFoundError:
            return False, "Claude CLI binary not found."

        try:
            stdout, stderr = await asyncio.wait_for(
                proc.communicate(),
                timeout=CLAUDE_PREFLIGHT_TIMEOUT_SECONDS,
            )
        except asyncio.TimeoutError:
            proc.kill()
            await proc.wait()
            last_reason = (
                "Claude CLI preflight timed out after "
                f"{CLAUDE_PREFLIGHT_TIMEOUT_SECONDS}s (attempt {attempt}/{CLAUDE_PREFLIGHT_MAX_ATTEMPTS})."
            )
            if attempt < CLAUDE_PREFLIGHT_MAX_ATTEMPTS:
                await asyncio.sleep(CLAUDE_PREFLIGHT_RETRY_DELAY_SECONDS * attempt)
                continue
            return False, last_reason

        out_text = stdout.decode("utf-8", errors="replace").strip()
        err_text = stderr.decode("utf-8", errors="replace").strip()
        combined = "\n".join(part for part in (out_text, err_text) if part).strip()
        rc = proc.returncode or 0

        if rc == 0 and out_text:
            return True, None

        if _contains_limit_marker(combined):
            return False, f"Claude limit exhausted: {_excerpt(combined)}"

        if rc != 0:
            details = _excerpt(combined) if combined else f"exit {rc} with empty output"
            last_reason = (
                f"Claude preflight failed ({details}) "
                f"(attempt {attempt}/{CLAUDE_PREFLIGHT_MAX_ATTEMPTS})."
            )
        else:
            last_reason = (
                "Claude preflight returned empty output "
                f"(attempt {attempt}/{CLAUDE_PREFLIGHT_MAX_ATTEMPTS})."
            )

        if attempt < CLAUDE_PREFLIGHT_MAX_ATTEMPTS:
            await asyncio.sleep(CLAUDE_PREFLIGHT_RETRY_DELAY_SECONDS * attempt)
            continue
        return False, last_reason

    return False, last_reason


# ── Main orchestrator ────────────────────────────────────────────────────────

async def run_pipeline(args: argparse.Namespace) -> int:
    sub_id = args.sub_batch
    if args.manifest:
        manifest_path = Path(args.manifest)
        if not manifest_path.is_absolute():
            manifest_path = REPO_ROOT / manifest_path
    else:
        manifest_path = BATCHES_DIR / f"{sub_id}.txt"
    if not manifest_path.exists():
        print(f"ERROR: Manifest not found: {manifest_path}", file=sys.stderr)
        return 1

    videos = load_manifest_videos(manifest_path)
    if not videos:
        print(f"ERROR: No videos found in manifest: {manifest_path}", file=sys.stderr)
        return 1

    # Determine stage range
    start_key = args.start_from
    if start_key not in STAGE_KEYS:
        print(f"ERROR: Unknown stage: {start_key} (valid: {', '.join(STAGE_KEYS)})", file=sys.stderr)
        return 1
    end_key = args.end_at
    if end_key not in STAGE_KEYS:
        print(f"ERROR: Unknown stage: {end_key} (valid: {', '.join(STAGE_KEYS)})", file=sys.stderr)
        return 1
    start_idx = STAGE_KEYS.index(start_key)
    end_idx = STAGE_KEYS.index(end_key)
    if end_idx < start_idx:
        print(f"ERROR: Invalid stage range: {start_key} → {end_key}", file=sys.stderr)
        return 1
    stages = STAGES[start_idx:end_idx + 1]

    stage_env: Optional[Dict[str, str]] = None
    if not args.dry_run and any(stage.needs_llm for stage in stages):
        claude_bin = resolve_claude_binary()
        if not claude_bin:
            print(
                "[pipeline-runner] LLM preflight failed: Claude CLI binary not found in PATH/env/NVM/known paths.",
                file=sys.stderr,
            )
            print(
                "[pipeline-runner] Aborting before per-video execution to avoid mass execution-error quarantine "
                "during global LLM outages/limits.",
                file=sys.stderr,
            )
            return 3
        stage_env = build_stage_subprocess_env(claude_bin)
        stage_env["STAGE06B_CLAUDE_LOCK"] = "1" if args.stage06b_claude_lock == "on" else "0"
        llm_ready, llm_reason = await run_llm_capacity_preflight(stage_env)
        if not llm_ready:
            print(
                f"[pipeline-runner] LLM preflight failed: {llm_reason or 'unknown failure'}",
                file=sys.stderr,
            )
            print(
                "[pipeline-runner] Aborting before per-video execution to avoid mass execution-error quarantine "
                "during global LLM outages/limits.",
                file=sys.stderr,
            )
            return 3

    parallel = args.parallel
    semaphore = asyncio.Semaphore(parallel)
    stage_parallel_caps = {
        stage_key: min(parallel, int(cap))
        for stage_key, cap in (args.stage_parallel_caps or {}).items()
        if isinstance(cap, int) and cap > 0
    }
    stage_semaphores = {
        stage_key: asyncio.Semaphore(cap)
        for stage_key, cap in stage_parallel_caps.items()
        if cap < parallel
    }
    if args.quarantine_file:
        quarantine_file = Path(args.quarantine_file)
        if not quarantine_file.is_absolute():
            quarantine_file = REPO_ROOT / quarantine_file
    else:
        quarantine_file = QUARANTINE_DIR / f"{sub_id}.json"

    preexisting_quarantine_ids: Set[str] = set()
    retained_existing_videos: List[dict] = []
    original_quarantine_count = 0
    if quarantine_file and quarantine_file.exists():
        original_ids, original_rows = load_quarantine_state(quarantine_file)
        original_quarantine_count = len(original_ids)
        retained_existing_videos = filter_quarantine_rows_for_restart(
            original_rows,
            start_key,
            active_video_ids={v.video_id for v in videos},
        )
        preexisting_quarantine_ids = {
            str(row.get("video_id", "")).strip()
            for row in retained_existing_videos
            if str(row.get("video_id", "")).strip()
        }
        removed_count = original_quarantine_count - len(preexisting_quarantine_ids)
        if removed_count > 0 and not args.dry_run:
            write_quarantine_payload(quarantine_file, retained_existing_videos)
        if removed_count > 0:
            print(
                f"[pipeline-runner] Restart from {start_key}: ignoring {removed_count} "
                f"same-stage/downstream quarantine entr{'y' if removed_count == 1 else 'ies'} "
                f"(retained quarantine rows: {len(preexisting_quarantine_ids)}/{original_quarantine_count})."
            )

    print()
    print("=" * 56)
    print(f"  Pipeline Runner: {sub_id}")
    print(f"  Videos: {len(videos)}")
    print(f"  Stages: {' → '.join(s.key for s in stages)}")
    print(f"  Parallel LLM calls: {parallel}")
    if any(stage.key == "06b" for stage in stages):
        print(f"  Stage 06b Claude lock: {args.stage06b_claude_lock}")
    if stage_parallel_caps:
        caps_text = ", ".join(f"{stage_key}={stage_parallel_caps[stage_key]}" for stage_key in sorted(stage_parallel_caps))
        print(f"  Stage LLM caps: {caps_text}")
    if args.dry_run:
        print("  Mode: DRY RUN")
    print("=" * 56)
    print()

    # Shared progress tracker
    llm_outage_event = asyncio.Event()
    progress: Dict[str, str] = {v.video_id: "pending" for v in videos}

    # Launch all video pipelines + progress reporter
    tasks = [
        asyncio.create_task(
            run_video(
                vs,
                stages,
                semaphore,
                stage_semaphores,
                llm_outage_event,
                stage_env,
                quarantine_file,
                preexisting_quarantine_ids,
                args.dry_run,
                progress,
                llm_timeout_seconds=args.llm_timeout_seconds,
                llm_retries=args.llm_retries,
                force_stages=set(args.force_stage or []),
            )
        )
        for vs in videos
    ]
    if not args.dry_run:
        reporter = asyncio.create_task(progress_reporter(videos, progress))
    else:
        reporter = None

    await asyncio.gather(*tasks)
    if reporter:
        reporter.cancel()
        try:
            await reporter
        except asyncio.CancelledError:
            pass

    # Write quarantine file for any rejected videos
    quarantined = [v for v in videos if v.status == "quarantined"]
    if quarantine_file and (quarantined or retained_existing_videos or original_quarantine_count > 0) and not args.dry_run:
        write_quarantine_file(quarantine_file, quarantined, existing_seed_videos=retained_existing_videos)

    # Summary
    done_count = sum(1 for v in videos if v.status == "done")
    fail_count = sum(1 for v in videos if v.status == "failed")
    q_count = sum(1 for v in videos if v.status == "quarantined")
    skipped_preexisting_count = sum(1 for v in videos if v.status == "skipped_preexisting_quarantine")

    print()
    print("=" * 56)
    print(f"  Pipeline Summary: {sub_id}")
    print("=" * 56)
    print(f"  Passed:      {done_count}/{len(videos)}")
    if q_count:
        print(f"  Quarantined: {q_count}")
        for v in quarantined:
            print(f"    {v.video_id}")
    if skipped_preexisting_count:
        print(f"  Skipped preexisting quarantine: {skipped_preexisting_count}")
        for v in videos:
            if v.status == "skipped_preexisting_quarantine":
                print(f"    {v.video_id}")
    if fail_count:
        print(f"  Failed:      {fail_count}")
        for v in videos:
            if v.status == "failed":
                print(f"    {v.video_id} at stage {v.error_stage}: {v.error_msg}")
    if llm_outage_event.is_set():
        print("  LLM outage:  detected during run (runtime failures were not quarantined)")
    print("=" * 56)
    print()

    validation_rc = 0
    # End-of-run validation (skip if dry run or all failed)
    if not args.dry_run and done_count > 0 and not args.skip_end_validation:
        validation_rc = await run_end_of_run_validation(sub_id, quarantine_file)
        if validation_rc != 0:
            print(f"[pipeline-runner] End-of-run validation failed (exit {validation_rc})", file=sys.stderr)

    if llm_outage_event.is_set():
        return 3
    if fail_count > 0:
        return 1
    if validation_rc != 0:
        return 2
    return 0


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Conveyor-belt pipeline runner — process videos in parallel across stages.",
    )
    parser.add_argument(
        "sub_batch",
        help="Sub-batch ID (e.g., P001.1)",
    )
    parser.add_argument(
        "--manifest",
        help="Optional manifest override (default: docs/pipeline/batches/<sub-batch>.txt)",
    )
    parser.add_argument(
        "--parallel", "-j",
        type=int,
        default=DEFAULT_PARALLEL,
        help=f"Max concurrent LLM calls (default: {DEFAULT_PARALLEL})",
    )
    parser.add_argument(
        "--from",
        dest="start_from",
        default="06",
        help="Stage to start from (default: 06)",
    )
    parser.add_argument(
        "--to",
        dest="end_at",
        default="09",
        help="Stage to end at, inclusive (default: 09)",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show commands without executing",
    )
    parser.add_argument(
        "--quarantine-file",
        help="Quarantine JSON path (default: data/validation/quarantine/<sub-batch>.json)",
    )
    parser.add_argument(
        "--skip-end-validation",
        action="store_true",
        help="Skip delegated end-of-run validation (useful for subset reruns inside larger orchestrators)",
    )
    parser.add_argument(
        "--llm-timeout-seconds",
        type=int,
        help="Optional per-call timeout override for LLM stages",
    )
    parser.add_argument(
        "--llm-retries",
        type=int,
        help="Optional per-call retry override for LLM stages",
    )
    parser.add_argument(
        "--stage-parallel-cap",
        action="append",
        default=[],
        help="Optional per-stage LLM concurrency cap (repeatable, format: STAGE=N)",
    )
    parser.add_argument(
        "--stage06b-claude-lock",
        choices=("on", "off"),
        default="on",
        help="Control Stage 06b global Claude lock (default: on). Set to 'off' to allow true parallel 06b calls.",
    )
    parser.add_argument(
        "--force-stage",
        action="append",
        default=[],
        help="Force eligible stage(s) to rebuild even when their own state cache says unchanged (repeatable).",
    )
    args = parser.parse_args()
    if args.parallel < 1:
        parser.error("--parallel must be >= 1")
    if args.llm_timeout_seconds is not None and args.llm_timeout_seconds < 1:
        parser.error("--llm-timeout-seconds must be >= 1")
    if args.llm_retries is not None and args.llm_retries < 1:
        parser.error("--llm-retries must be >= 1")
    try:
        args.stage_parallel_caps = parse_stage_parallel_caps(list(args.stage_parallel_cap or []))
    except ValueError as exc:
        parser.error(str(exc))
    requested_force_stages = [str(stage_key or "").strip() for stage_key in (args.force_stage or []) if str(stage_key or "").strip()]
    unknown_force_stages = sorted({stage_key for stage_key in requested_force_stages if stage_key not in STAGE_KEYS})
    if unknown_force_stages:
        parser.error(
            f"unknown --force-stage value(s): {', '.join(unknown_force_stages)} "
            f"(valid: {', '.join(STAGE_KEYS)})"
        )
    unsupported_force_stages = sorted(
        {stage_key for stage_key in requested_force_stages if stage_key not in STAGES_SUPPORTING_FORCE}
    )
    if unsupported_force_stages:
        parser.error(
            f"--force-stage only supports: {', '.join(sorted(STAGES_SUPPORTING_FORCE))}; "
            f"unsupported: {', '.join(unsupported_force_stages)}"
        )
    args.force_stage = sorted(set(requested_force_stages))
    rc = asyncio.run(run_pipeline(args))
    sys.exit(rc)


if __name__ == "__main__":
    main()
