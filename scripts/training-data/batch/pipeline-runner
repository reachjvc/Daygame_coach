# ── Manifest parsing ────────────────────────────────────────────────────────

def load_manifest_videos(manifest_path: Path) -> List[VideoState]:
    """Parse manifest into list of VideoState entries."""
    videos = []
    for line in manifest_path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        parts = line.split("|", 1)
        if len(parts) != 2:
            continue
        source = parts[0].strip()
        folder = parts[1].strip()
        match = VIDEO_ID_RE.search(folder)
        if not match:
            continue
        videos.append(VideoState(
            video_id=match.group(1),
            source=source,
            folder=folder,
        ))
    return videos


def _normalize_quarantine_check(raw_check: Any) -> str:
    check = str(raw_check or "").strip()
    return LEGACY_QUARANTINE_CHECK_MAP.get(check, check)


def _normalize_quarantine_reason(reason: dict) -> Optional[dict]:
    if not isinstance(reason, dict):
        return None
    check = _normalize_quarantine_check(reason.get("check"))
    if not check:
        return None
    message = str(reason.get("message", "")).strip()
    normalized = dict(reason)
    normalized["check"] = check
    if message:
        normalized["message"] = message[:300]
    return normalized


def _normalize_quarantine_row(row: dict) -> Optional[dict]:
    if not isinstance(row, dict):
        return None
    raw_vid = row.get("video_id")
    if not isinstance(raw_vid, str):
        return None
    video_id = raw_vid.strip()
    if not re.fullmatch(r"[A-Za-z0-9_-]{11}", video_id):
        return None

    normalized: dict = {"video_id": video_id}
    raw_source = row.get("source")
    if isinstance(raw_source, str) and raw_source.strip():
        normalized["source"] = raw_source.strip()

    checks: List[str] = []
    raw_checks = row.get("checks")
    if isinstance(raw_checks, list):
        checks = sorted(
            {
                _normalize_quarantine_check(item)
                for item in raw_checks
                if _normalize_quarantine_check(item)
            }
        )

    reasons: List[dict] = []
    raw_reasons = row.get("reasons")
    if isinstance(raw_reasons, list):
        for reason in raw_reasons:
            normalized_reason = _normalize_quarantine_reason(reason)
            if normalized_reason:
                reasons.append(normalized_reason)

    if not reasons and checks:
        reasons = [
            {
                "severity": "error",
                "check": check,
                "message": f"Preexisting quarantine retained ({check}).",
            }
            for check in checks
        ]

    if reasons:
        normalized["reasons"] = reasons
        normalized["checks"] = sorted({str(reason.get("check", "")).strip() for reason in reasons if str(reason.get("check", "")).strip()})
    elif checks:
        normalized["checks"] = checks

    return normalized


def load_quarantine_state(quarantine_file: Path | None) -> Tuple[Set[str], List[dict]]:
    if not quarantine_file or not quarantine_file.exists():
        return set(), []
    try:
        payload = json.loads(quarantine_file.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return set(), []
    if not isinstance(payload, dict):
        return set(), []

    rows_by_video: Dict[str, dict] = {}
    raw_rows = payload.get("videos")
    if isinstance(raw_rows, list):
        for row in raw_rows:
            normalized = _normalize_quarantine_row(row)
            if normalized:
                rows_by_video[normalized["video_id"]] = normalized

    ids: Set[str] = set()
    raw_ids = payload.get("quarantined_video_ids")
    if isinstance(raw_ids, list):
        for item in raw_ids:
            if isinstance(item, str):
                vid = item.strip()
                if re.fullmatch(r"[A-Za-z0-9_-]{11}", vid):
                    ids.add(vid)
    ids.update(rows_by_video.keys())

    for video_id in sorted(ids):
        rows_by_video.setdefault(video_id, {"video_id": video_id})

    normalized_rows = [rows_by_video[video_id] for video_id in sorted(rows_by_video)]
    return set(rows_by_video.keys()), normalized_rows


def quarantine_reason_stage(check: str) -> Optional[str]:
    normalized = _normalize_quarantine_check(check)
    for stage_key in STAGE_KEYS_BY_LENGTH:
        if normalized.startswith(f"stage{stage_key}"):
            return stage_key
    match = EMBEDDED_STAGE_CHECK_RE.search(normalized)
    if match:
        return match.group(1)
    return None


def parse_stage_parallel_caps(raw_values: List[str]) -> Dict[str, int]:
    caps: Dict[str, int] = {}
    for raw in raw_values:
        text = str(raw or "").strip()
        if not text:
            continue
        stage_key, sep, value_text = text.partition("=")
        stage_key = stage_key.strip()
        value_text = value_text.strip()
        if sep != "=" or not stage_key or not value_text:
            raise ValueError(f"invalid stage cap '{text}' (expected STAGE=N)")
        if stage_key not in STAGE_KEYS:
            raise ValueError(f"unknown stage in stage cap '{text}' (valid: {', '.join(STAGE_KEYS)})")
        if not value_text.isdigit() or int(value_text) < 1:
            raise ValueError(f"invalid stage cap '{text}' (N must be >= 1)")
        value = int(value_text)
        prev = caps.get(stage_key)
        if prev is not None and prev != value:
            raise ValueError(f"conflicting stage caps for {stage_key}: {prev} vs {value}")
        caps[stage_key] = value
    return caps


def filter_quarantine_rows_for_restart(
    rows: List[dict],
    start_stage: str,
    active_video_ids: Optional[Set[str]] = None,
) -> List[dict]:
    start_idx = STAGE_KEY_INDEX[start_stage]
    retained: List[dict] = []
    for row in rows:
        normalized = _normalize_quarantine_row(row)
        if not normalized:
            continue
        video_id = str(normalized.get("video_id", "")).strip()
        if active_video_ids is not None and video_id not in active_video_ids:
            retained.append(normalized)
            continue

        reasons = normalized.get("reasons")
        retained_reasons: List[dict] = []
        if isinstance(reasons, list):
            for reason in reasons:
                check = str(reason.get("check", "")).strip()
                if check == "preexisting_quarantine":
                    continue
                reason_stage = quarantine_reason_stage(check)
                if reason_stage is None or STAGE_KEY_INDEX[reason_stage] < start_idx:
                    retained_reasons.append(reason)
        else:
            retained_reasons = []

        checks = normalized.get("checks")
        retained_checks: List[str] = []
        if isinstance(checks, list):
            for check in checks:
                check_text = str(check).strip()
                if not check_text:
                    continue
                if check_text == "preexisting_quarantine":
                    continue
                reason_stage = quarantine_reason_stage(check_text)
                if reason_stage is None or STAGE_KEY_INDEX[reason_stage] < start_idx:
                    retained_checks.append(check_text)

        if reasons and not retained_reasons:
            continue
        if checks and not reasons and not retained_checks:
            continue

        out = dict(normalized)
        if retained_reasons:
            out["reasons"] = retained_reasons
            out["checks"] = sorted({str(reason.get("check", "")).strip() for reason in retained_reasons if str(reason.get("check", "")).strip()})
        elif retained_checks:
            out["checks"] = sorted(set(retained_checks))
            out.pop("reasons", None)
        retained.append(out)

    return retained


def write_quarantine_payload(
    quarantine_path: Path,
    videos: List[dict],
) -> None:
    quarantine_path.parent.mkdir(parents=True, exist_ok=True)
    normalized_rows = [row for row in (_normalize_quarantine_row(item) for item in videos) if row]
    ids = sorted({str(row.get("video_id", "")).strip() for row in normalized_rows if str(row.get("video_id", "")).strip()})
    out = {
        "version": 1,
        "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "quarantine_level": "error",
        "quarantined_video_count": len(ids),
        "quarantined_video_ids": ids,
        "videos": normalized_rows,
    }
    quarantine_path.write_text(
        json.dumps(out, indent=2, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )


# ── Subprocess execution ────────────────────────────────────────────────────

def build_stage_command(
    stage: Stage,
    manifest_path: str,
    quarantine_file: Path | None = None,
    *,
    llm_timeout_seconds: int | None = None,
    llm_retries: int | None = None,
    force_stages: Optional[Set[str]] = None,
) -> List[str]:
    """Build the command list to execute a stage script."""
    script_path = str(REPO_ROOT / "scripts" / "training-data" / stage.script)

    if stage.script.endswith(".ts"):
        cmd = ["node", "--import", str(TSX_LOADER), script_path]
    else:
        cmd = [VENV_PYTHON, "-u", script_path]

    cmd.extend(["--manifest", manifest_path])
    if stage.key in STAGES_SUPPORTING_OVERWRITE:
        # Single-path strictness: always recompute stage outputs so downstream
        # artifacts cannot drift from updated upstream inputs.
        cmd.append("--overwrite")
    if stage.key in STAGES_SUPPORTING_APPLY_REPAIRS:
        cmd.append("--apply-repairs")
    if stage.key in STAGES_SUPPORTING_SKIP_PREFLIGHT:
        # Avoid N-way Claude startup probes when conveyor mode fans out many LLM workers.
        cmd.append("--skip-preflight")
    if force_stages and stage.key in force_stages and stage.key in STAGES_SUPPORTING_FORCE:
        cmd.append("--force")

    # Stage 08 per-video runs are only used for immediate gating progression.
    # Canonical manifest-level Stage 08 reporting is emitted in end-of-run
    # validation, so skip per-video report files to avoid temp-manifest clutter.
    if stage.key == "08":
        cmd.append("--no-report")

    if stage.key in STAGES_SUPPORTING_QUARANTINE and quarantine_file and quarantine_file.exists():
        cmd.extend(["--quarantine-file", str(quarantine_file)])
    if stage.key in STAGES_SUPPORTING_LLM_RUNTIME_FLAGS:
        if isinstance(llm_timeout_seconds, int) and llm_timeout_seconds > 0:
            cmd.extend(["--timeout-seconds", str(llm_timeout_seconds)])
        if isinstance(llm_retries, int) and llm_retries > 0:
            cmd.extend(["--llm-retries", str(llm_retries)])

    return cmd


async def run_subprocess(
    cmd: List[str],
    stage: Stage,
    video_id: str,
    log_prefix: str,
    env: Optional[Dict[str, str]] = None,
) -> Tuple[int, Optional[str], str]:
    """Run a stage subprocess and stream its output."""
    runtime_marker: Optional[str] = None
    runtime_excerpt = ""
    proc = await asyncio.create_subprocess_exec(
        *cmd,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.STDOUT,
        env=env,
    )
    assert proc.stdout is not None
    while True:
        line = await proc.stdout.readline()
        if not line:
            break
        text = line.decode("utf-8", errors="replace").rstrip()
        print(f"{log_prefix} [{stage.key}] {text}")
        if stage.needs_llm and _contains_limit_marker(text):
            runtime_marker = "limit"
            if not runtime_excerpt:
                runtime_excerpt = _excerpt(text, limit=200)
        elif stage.needs_llm and _contains_timeout_marker(text):
            if runtime_marker is None:
                runtime_marker = "timeout"
            if not runtime_excerpt:
                runtime_excerpt = _excerpt(text, limit=200)
    await proc.wait()
    return proc.returncode or 0, runtime_marker, runtime_excerpt


