# ── Video state tracking ────────────────────────────────────────────────────

@dataclass
class VideoState:
    video_id: str
    source: str
    folder: str
    current_stage: str = ""
    status: str = "pending"   # pending | running | done | failed | quarantined
    error_stage: str = ""
    error_msg: str = ""
    quarantine_checks: Set[str] = field(default_factory=set)
    quarantine_reasons: List[dict] = field(default_factory=list)


# ── Manifest parsing ────────────────────────────────────────────────────────

def load_manifest_videos(manifest_path: Path) -> List[VideoState]:
    """Parse manifest into list of VideoState entries."""
    videos = []
    for line in manifest_path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        parts = line.split("|", 1)
        if len(parts) != 2:
            continue
        source = parts[0].strip()
        folder = parts[1].strip()
        match = VIDEO_ID_RE.search(folder)
        if not match:
            continue
        videos.append(VideoState(
            video_id=match.group(1),
            source=source,
            folder=folder,
        ))
    return videos


def _normalize_quarantine_check(raw_check: Any) -> str:
    check = str(raw_check or "").strip()
    return LEGACY_QUARANTINE_CHECK_MAP.get(check, check)


def _normalize_quarantine_reason(reason: dict) -> Optional[dict]:
    if not isinstance(reason, dict):
        return None
    check = _normalize_quarantine_check(reason.get("check"))
    if not check:
        return None
    message = str(reason.get("message", "")).strip()
    normalized = dict(reason)
    normalized["check"] = check
    if message:
        normalized["message"] = message[:300]
    return normalized


def _normalize_quarantine_row(row: dict) -> Optional[dict]:
    if not isinstance(row, dict):
        return None
    raw_vid = row.get("video_id")
    if not isinstance(raw_vid, str):
        return None
    video_id = raw_vid.strip()
    if not re.fullmatch(r"[A-Za-z0-9_-]{11}", video_id):
        return None

    normalized: dict = {"video_id": video_id}
    raw_source = row.get("source")
    if isinstance(raw_source, str) and raw_source.strip():
        normalized["source"] = raw_source.strip()

    checks: List[str] = []
    raw_checks = row.get("checks")
    if isinstance(raw_checks, list):
        checks = sorted(
            {
                _normalize_quarantine_check(item)
                for item in raw_checks
                if _normalize_quarantine_check(item)
            }
        )

    reasons: List[dict] = []
    raw_reasons = row.get("reasons")
    if isinstance(raw_reasons, list):
        for reason in raw_reasons:
            normalized_reason = _normalize_quarantine_reason(reason)
            if normalized_reason:
                reasons.append(normalized_reason)

    if not reasons and checks:
        reasons = [
            {
                "severity": "error",
                "check": check,
                "message": f"Preexisting quarantine retained ({check}).",
            }
            for check in checks
        ]

    if reasons:
        normalized["reasons"] = reasons
        normalized["checks"] = sorted({str(reason.get("check", "")).strip() for reason in reasons if str(reason.get("check", "")).strip()})
    elif checks:
        normalized["checks"] = checks

    return normalized


def load_quarantine_state(quarantine_file: Path | None) -> Tuple[Set[str], List[dict]]:
    if not quarantine_file or not quarantine_file.exists():
        return set(), []
    try:
        payload = json.loads(quarantine_file.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return set(), []
    if not isinstance(payload, dict):
        return set(), []

    rows_by_video: Dict[str, dict] = {}
    raw_rows = payload.get("videos")
    if isinstance(raw_rows, list):
        for row in raw_rows:
            normalized = _normalize_quarantine_row(row)
            if normalized:
                rows_by_video[normalized["video_id"]] = normalized

    ids: Set[str] = set()
    raw_ids = payload.get("quarantined_video_ids")
    if isinstance(raw_ids, list):
        for item in raw_ids:
            if isinstance(item, str):
                vid = item.strip()
                if re.fullmatch(r"[A-Za-z0-9_-]{11}", vid):
                    ids.add(vid)
    ids.update(rows_by_video.keys())

    for video_id in sorted(ids):
        rows_by_video.setdefault(video_id, {"video_id": video_id})

    normalized_rows = [rows_by_video[video_id] for video_id in sorted(rows_by_video)]
    return set(rows_by_video.keys()), normalized_rows


def quarantine_reason_stage(check: str) -> Optional[str]:
    normalized = _normalize_quarantine_check(check)
    for stage_key in STAGE_KEYS_BY_LENGTH:
        if normalized.startswith(f"stage{stage_key}"):
            return stage_key
    match = EMBEDDED_STAGE_CHECK_RE.search(normalized)
    if match:
        return match.group(1)
    return None


def parse_stage_parallel_caps(raw_values: List[str]) -> Dict[str, int]:
    caps: Dict[str, int] = {}
    for raw in raw_values:
        text = str(raw or "").strip()
        if not text:
            continue
        stage_key, sep, value_text = text.partition("=")
        stage_key = stage_key.strip()
        value_text = value_text.strip()
        if sep != "=" or not stage_key or not value_text:
            raise ValueError(f"invalid stage cap '{text}' (expected STAGE=N)")
        if stage_key not in STAGE_KEYS:
            raise ValueError(f"unknown stage in stage cap '{text}' (valid: {', '.join(STAGE_KEYS)})")
        if not value_text.isdigit() or int(value_text) < 1:
            raise ValueError(f"invalid stage cap '{text}' (N must be >= 1)")
        value = int(value_text)
        prev = caps.get(stage_key)
        if prev is not None and prev != value:
            raise ValueError(f"conflicting stage caps for {stage_key}: {prev} vs {value}")
        caps[stage_key] = value
    return caps


def filter_quarantine_rows_for_restart(
    rows: List[dict],
    start_stage: str,
    active_video_ids: Optional[Set[str]] = None,
) -> List[dict]:
    start_idx = STAGE_KEY_INDEX[start_stage]
    retained: List[dict] = []
    for row in rows:
        normalized = _normalize_quarantine_row(row)
        if not normalized:
            continue
        video_id = str(normalized.get("video_id", "")).strip()
        if active_video_ids is not None and video_id not in active_video_ids:
            retained.append(normalized)
            continue

        reasons = normalized.get("reasons")
        retained_reasons: List[dict] = []
        if isinstance(reasons, list):
            for reason in reasons:
                check = str(reason.get("check", "")).strip()
                if check == "preexisting_quarantine":
                    continue
                reason_stage = quarantine_reason_stage(check)
                if reason_stage is None or STAGE_KEY_INDEX[reason_stage] < start_idx:
                    retained_reasons.append(reason)
        else:
            retained_reasons = []

        checks = normalized.get("checks")
        retained_checks: List[str] = []
        if isinstance(checks, list):
            for check in checks:
                check_text = str(check).strip()
                if not check_text:
                    continue
                if check_text == "preexisting_quarantine":
                    continue
                reason_stage = quarantine_reason_stage(check_text)
                if reason_stage is None or STAGE_KEY_INDEX[reason_stage] < start_idx:
                    retained_checks.append(check_text)

        if reasons and not retained_reasons:
            continue
        if checks and not reasons and not retained_checks:
            continue

        out = dict(normalized)
        if retained_reasons:
            out["reasons"] = retained_reasons
            out["checks"] = sorted({str(reason.get("check", "")).strip() for reason in retained_reasons if str(reason.get("check", "")).strip()})
        elif retained_checks:
            out["checks"] = sorted(set(retained_checks))
            out.pop("reasons", None)
        retained.append(out)

    return retained


def write_quarantine_payload(
    quarantine_path: Path,
    videos: List[dict],
) -> None:
    quarantine_path.parent.mkdir(parents=True, exist_ok=True)
    normalized_rows = [row for row in (_normalize_quarantine_row(item) for item in videos) if row]
    ids = sorted({str(row.get("video_id", "")).strip() for row in normalized_rows if str(row.get("video_id", "")).strip()})
    out = {
        "version": 1,
        "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "quarantine_level": "error",
        "quarantined_video_count": len(ids),
        "quarantined_video_ids": ids,
        "videos": normalized_rows,
    }
    quarantine_path.write_text(
        json.dumps(out, indent=2, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )


# ── Subprocess execution ────────────────────────────────────────────────────

def build_stage_command(
    stage: Stage,
    manifest_path: str,
    quarantine_file: Path | None = None,
    *,
    llm_timeout_seconds: int | None = None,
    llm_retries: int | None = None,
    force_stages: Optional[Set[str]] = None,
) -> List[str]:
    """Build the command list to execute a stage script."""
    script_path = str(REPO_ROOT / "scripts" / "training-data" / stage.script)

    if stage.script.endswith(".ts"):
        cmd = ["node", "--import", str(TSX_LOADER), script_path]
    else:
        cmd = [VENV_PYTHON, "-u", script_path]

    cmd.extend(["--manifest", manifest_path])
    if stage.key in STAGES_SUPPORTING_OVERWRITE:
        # Single-path strictness: always recompute stage outputs so downstream
        # artifacts cannot drift from updated upstream inputs.
        cmd.append("--overwrite")
    if stage.key in STAGES_SUPPORTING_APPLY_REPAIRS:
        cmd.append("--apply-repairs")
    if stage.key in STAGES_SUPPORTING_SKIP_PREFLIGHT:
        # Avoid N-way Claude startup probes when conveyor mode fans out many LLM workers.
        cmd.append("--skip-preflight")
    if force_stages and stage.key in force_stages and stage.key in STAGES_SUPPORTING_FORCE:
        cmd.append("--force")

    # Stage 08 per-video runs are only used for immediate gating progression.
    # Canonical manifest-level Stage 08 reporting is emitted in end-of-run
    # validation, so skip per-video report files to avoid temp-manifest clutter.
    if stage.key == "08":
        cmd.append("--no-report")

    if stage.key in STAGES_SUPPORTING_QUARANTINE and quarantine_file and quarantine_file.exists():
        cmd.extend(["--quarantine-file", str(quarantine_file)])
    if stage.key in STAGES_SUPPORTING_LLM_RUNTIME_FLAGS:
        if isinstance(llm_timeout_seconds, int) and llm_timeout_seconds > 0:
            cmd.extend(["--timeout-seconds", str(llm_timeout_seconds)])
        if isinstance(llm_retries, int) and llm_retries > 0:
            cmd.extend(["--llm-retries", str(llm_retries)])

    return cmd


async def run_subprocess(
    cmd: List[str],
    stage: Stage,
    video_id: str,
    log_prefix: str,
) -> int:
    """Run a stage subprocess and stream its output."""
    proc = await asyncio.create_subprocess_exec(
        *cmd,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.STDOUT,
    )
    assert proc.stdout is not None
    while True:
        line = await proc.stdout.readline()
        if not line:
            break
        text = line.decode("utf-8", errors="replace").rstrip()
        print(f"{log_prefix} [{stage.key}] {text}")
    await proc.wait()
    return proc.returncode or 0


# ── Quarantine check ────────────────────────────────────────────────────────

def load_quarantine_video_ids(quarantine_file: Path | None) -> Set[str]:
    ids, _ = load_quarantine_state(quarantine_file)
    return ids


def add_quarantine_reason(vs: VideoState, check: str, message: str) -> None:
    check = LEGACY_QUARANTINE_CHECK_MAP.get(check.strip(), check.strip())
    if check not in vs.quarantine_checks:
        vs.quarantine_checks.add(check)
        vs.quarantine_reasons.append(
            {
                "severity": "error",
                "check": check,
                "message": message[:300],
            }
        )


async def run_contract_preflight(
    stage: Stage,
    manifest_path: str,
    quarantine_file: Path | None,
    log_prefix: str,
) -> int:
    cmd = [
        VENV_PYTHON,
        "-u",
        str(VALIDATION_DIR / "validate_stage_contract.py"),
        "--manifest",
        manifest_path,
        "--stage",
        stage.key,
    ]
    if quarantine_file and quarantine_file.exists():
        cmd.extend(["--quarantine-file", str(quarantine_file)])

    proc = await asyncio.create_subprocess_exec(
        *cmd,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.STDOUT,
    )
    assert proc.stdout is not None
    while True:
        line = await proc.stdout.readline()
        if not line:
            break
        text = line.decode("utf-8", errors="replace").rstrip()
        print(f"{log_prefix} [preflight:{stage.key}] {text}")
    await proc.wait()
    return proc.returncode or 0


def _pick_newest(paths: List[Path]) -> Optional[Path]:
    if not paths:
        return None

    def key(path: Path) -> Tuple[float, str]:
        try:
            return (path.stat().st_mtime, str(path))
        except OSError:
            return (0.0, str(path))

    return max(paths, key=key)


def find_stage_artifact(
    stage_key: str,
    source: str,
    video_id: str,
    suffix: str,
) -> Optional[Path]:
    root = STAGE_OUTPUT_DIRS.get(stage_key)
    if root is None:
        return None
    source_dir = root / source
    if not source_dir.exists():
        return None
    candidates = list(source_dir.rglob(f"*{video_id}*{suffix}"))
    return _pick_newest(candidates)


def resolve_stage07_pair(vs: VideoState) -> Tuple[Optional[Path], Optional[Path]]:
    s07_path = find_stage_artifact("07", vs.source, vs.video_id, ".enriched.json")
    s06_path = find_stage_artifact("06c", vs.source, vs.video_id, ".conversations.json")
    return s06_path, s07_path


async def run_stage_validator_errors(
    stage: Stage,
    vs: VideoState,
    manifest_path: str,
    quarantine_file: Path | None,
    log_prefix: str,
) -> Tuple[Set[str], Dict[str, List[dict]]]:
    if stage.key == "07":
        s06_path, s07_path = resolve_stage07_pair(vs)
        if not (s06_path and s07_path):
            return {
                vs.video_id,
            }, {
                vs.video_id: [
                    {
                        "check": "stage07_validator_inputs_missing",
                        "message": "Missing direct Stage 06c/07 artifacts for cross-stage validation; fail-closed block applied.",
                    }
                ]
            }
        cmd = [
            VENV_PYTHON,
            "-u",
            str(VALIDATION_DIR / "validate_cross_stage.py"),
            "--s06",
            str(s06_path),
            "--s07",
            str(s07_path),
            "--json",
        ]
    elif stage.key == "07b":
        cmd = [
            VENV_PYTHON,
            "-u",
            str(VALIDATION_DIR / "validate_stage07b.py"),
            "--source",
            vs.source,
            "--video-id",
            vs.video_id,
            "--json",
        ]
        if quarantine_file and quarantine_file.exists():
            cmd.extend(["--quarantine-file", str(quarantine_file)])
    elif stage.key == "09":
        cmd = [
            VENV_PYTHON,
            "-u",
            str(VALIDATION_DIR / "validate_chunks.py"),
            "--source",
            vs.source,
            "--video-id",
            vs.video_id,
            "--json",
        ]
    else:
        return set(), {}

    proc = await asyncio.create_subprocess_exec(
        *cmd,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.DEVNULL,
    )
    stdout, _ = await proc.communicate()
    text = stdout.decode("utf-8", errors="replace").strip()
    if not text:
        return set(), {}
    try:
        payload = json.loads(text)
    except json.JSONDecodeError:
        print(f"{log_prefix} [validate:{stage.key}] WARNING: non-JSON validator output")
        return set(), {}
    if not isinstance(payload, dict):
        return set(), {}
    quarantined_ids, quarantined_videos = extract_from_cross_stage_or_chunks(payload, stage_label=stage.key)
    reasons_by_video: Dict[str, List[dict]] = {}
    for row in quarantined_videos:
        if not isinstance(row, dict):
            continue
        vid = row.get("video_id")
        if not isinstance(vid, str) or not vid.strip():
            continue
        reasons = row.get("reasons")
        if not isinstance(reasons, list):
            continue
        for reason in reasons:
            if not isinstance(reason, dict):
                continue
            check = str(reason.get("check", "")).strip()
            message = str(reason.get("message", "")).strip()
            if not check or not message:
                continue
            reasons_by_video.setdefault(vid, []).append(
                {
                    "check": check,
                    "message": message,
                }
            )
    return quarantined_ids, reasons_by_video


def _safe_count_list(value: Any) -> int:
    if isinstance(value, list):
        return len(value)
    return 0


def _stage06b_flag_summary_counts(payload: dict) -> Dict[str, int]:
    counts: Dict[str, int] = {}
    if not isinstance(payload, dict):
        return counts
    metadata = payload.get("metadata")
    if not isinstance(metadata, dict):
        return counts
    flag_summary = metadata.get("flag_summary")
    if not isinstance(flag_summary, dict):
        return counts
    structured_counts = flag_summary.get("structured_flag_class_counts")
    if not isinstance(structured_counts, dict):
        return counts
    for key, raw_value in structured_counts.items():
        if isinstance(raw_value, bool):
            continue
        if isinstance(raw_value, int) and raw_value >= 0:
            counts[str(key)] = raw_value
    return counts


def evaluate_06b_gate(video_id: str, source: str) -> Tuple[bool, Optional[str], Optional[str]]:
    """Fail-closed gate for Stage 06b REJECT + severe FLAG outcomes."""
    verify_dir = DATA_DIR / "06b.LLM.verify" / source
    if not verify_dir.exists():
        return False, None, None
    verification_path = _pick_newest(list(verify_dir.rglob(f"*{video_id}*.verification.json")))
    if verification_path is None:
        return False, None, None
    try:
        payload = json.loads(verification_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return False, None, None

    verdict = str(
        payload.get("verdict") or payload.get("overall_verdict") or ""
    ).strip().upper()
    if verdict == "REJECT":
        return True, "stage06b_reject", "Stage 06b verdict: REJECT"
    if verdict != "FLAG":
        return False, None, None

    structured_counts = _stage06b_flag_summary_counts(payload)

    misattribution_count = _safe_count_list(payload.get("misattributions"))

    conversation_flag_count = structured_counts.get("conversation_flag")
    if not isinstance(conversation_flag_count, int):
        conversation_flag_count = 0
        conversation_verdicts = payload.get("conversation_verdicts")
        if isinstance(conversation_verdicts, list):
            for row in conversation_verdicts:
                if not isinstance(row, dict):
                    continue
                verdict_text = str(row.get("verdict", "")).strip().upper()
                if verdict_text in {"FLAG", "ISSUE"}:
                    conversation_flag_count += 1

    boundary_major_or_moderate_count = structured_counts.get("boundary_issue_major_or_moderate")
    if not isinstance(boundary_major_or_moderate_count, int):
        boundary_major_or_moderate_count = 0
        boundary_issues = payload.get("boundary_issues")
        if isinstance(boundary_issues, list):
            for row in boundary_issues:
                if not isinstance(row, dict):
                    continue
                severity = str(row.get("severity", "")).strip().lower()
                if severity in {"major", "moderate"}:
                    boundary_major_or_moderate_count += 1

    major_other_flag_count = 0
    missing_target_coverage_count = 0
    other_flags_detailed = payload.get("other_flags_detailed")
    if isinstance(other_flags_detailed, list):
        for row in other_flags_detailed:
            if not isinstance(row, dict):
                continue
            flag_class = str(row.get("flag_class", "")).strip()
            severity = str(row.get("severity", "")).strip().lower()
            if flag_class == "missing_target_coverage":
                missing_target_coverage_count += 1
            if severity == "major":
                major_other_flag_count += 1

    triggered: List[str] = []
    if misattribution_count >= STAGE06B_FLAG_MISATTRIBUTION_BLOCK_THRESHOLD:
        triggered.append(f"misattributions={misattribution_count}")
    if conversation_flag_count >= STAGE06B_FLAG_CONVERSATION_BLOCK_THRESHOLD:
        triggered.append(f"conversation_flags={conversation_flag_count}")
    if boundary_major_or_moderate_count >= STAGE06B_FLAG_BOUNDARY_BLOCK_THRESHOLD:
        triggered.append(f"boundary_major_or_moderate={boundary_major_or_moderate_count}")
    if missing_target_coverage_count >= STAGE06B_FLAG_MISSING_TARGET_COVERAGE_BLOCK_THRESHOLD:
        triggered.append(f"missing_target_coverage={missing_target_coverage_count}")
    if major_other_flag_count >= STAGE06B_FLAG_MAJOR_OTHER_BLOCK_THRESHOLD:
        triggered.append(f"major_other_flags={major_other_flag_count}")

    if not triggered:
        return False, None, None

    details = (
        f"mis={misattribution_count}, conv_flags={conversation_flag_count}, "
        f"boundary_major_or_moderate={boundary_major_or_moderate_count}, "
        f"missing_target_coverage={missing_target_coverage_count}, "
        f"major_other={major_other_flag_count}"
    )
    message = f"Stage 06b severe FLAG ({'; '.join(triggered)}). Metrics: {details}."
    return True, "stage06b_flag_severe", message


def write_quarantine_file(
    quarantine_path: Path,
    quarantined: List[VideoState],
    existing_seed_videos: Optional[List[dict]] = None,
) -> None:
    """Write quarantine file in the standard format."""
    existing_videos = (
        [row for row in (_normalize_quarantine_row(item) for item in (existing_seed_videos or [])) if row]
        if existing_seed_videos is not None
        else load_quarantine_state(quarantine_path)[1]
    )
    rows_by_video: Dict[str, dict] = {
        str(row.get("video_id", "")).strip(): dict(row)
        for row in existing_videos
        if str(row.get("video_id", "")).strip()
    }

    for vs in quarantined:
        checks = sorted(vs.quarantine_checks) if vs.quarantine_checks else ["stage06b_reject"]
        reasons = (
            vs.quarantine_reasons
            if vs.quarantine_reasons
            else [
                {
                    "severity": "error",
                    "check": "stage06b_reject",
                    "message": "Stage 06b verdict: REJECT",
                }
            ]
        )
        normalized_reasons = [row for row in (_normalize_quarantine_reason(reason) for reason in reasons) if row]
        current = rows_by_video.get(vs.video_id, {"video_id": vs.video_id})
        merged_checks = set(current.get("checks", [])) if isinstance(current.get("checks"), list) else set()
        merged_checks.update(checks)
        merged_checks.update(str(reason.get("check", "")).strip() for reason in normalized_reasons if str(reason.get("check", "")).strip())
        merged_reasons = list(current.get("reasons", [])) if isinstance(current.get("reasons"), list) else []
        existing_reason_keys = {
            (str(reason.get("check", "")).strip(), str(reason.get("message", "")).strip())
            for reason in merged_reasons
            if isinstance(reason, dict)
        }
        for reason in normalized_reasons:
            key = (str(reason.get("check", "")).strip(), str(reason.get("message", "")).strip())
            if key not in existing_reason_keys:
                merged_reasons.append(reason)
                existing_reason_keys.add(key)
        current["checks"] = sorted(check for check in merged_checks if str(check).strip())
        if merged_reasons:
            current["reasons"] = merged_reasons
        rows_by_video[vs.video_id] = current

    write_quarantine_payload(quarantine_path, list(rows_by_video.values()))


# ── Per-video pipeline ──────────────────────────────────────────────────────

async def run_video(
    vs: VideoState,
    stages: List[Stage],
    semaphore: asyncio.Semaphore,
    stage_semaphores: Dict[str, asyncio.Semaphore],
    quarantine_file: Path | None,
    preexisting_quarantine_ids: Set[str],
    dry_run: bool,
    progress: Dict[str, str],
    llm_timeout_seconds: int | None = None,
    llm_retries: int | None = None,
    force_stages: Optional[Set[str]] = None,
) -> None:
    """Run one video through all stages sequentially."""
    log_prefix = f"[{vs.video_id}]"
    if vs.video_id in preexisting_quarantine_ids:
        vs.status = "skipped_preexisting_quarantine"
        progress[vs.video_id] = "QUARANTINED"
        print(f"{log_prefix} SKIP: already quarantined before run")
        return

    for stage in stages:
        vs.current_stage = stage.key
        vs.status = "running"
        progress[vs.video_id] = stage.key

        # Create temp 1-video manifest
        fd, tmp_manifest = tempfile.mkstemp(suffix=".txt", prefix=f"manifest_{vs.video_id}_")
        try:
            with os.fdopen(fd, "w") as f:
                f.write(f"{vs.source} | {vs.folder}\n")

            cmd = build_stage_command(
                stage,
                tmp_manifest,
                quarantine_file,
                llm_timeout_seconds=llm_timeout_seconds,
                llm_retries=llm_retries,
                force_stages=force_stages,
            )

            if dry_run:
                label = "LLM" if stage.needs_llm else "DET"
                print(f"{log_prefix} [{label}] {stage.key}: {' '.join(cmd)}")
                continue

            preflight_rc = await run_contract_preflight(stage, tmp_manifest, quarantine_file, log_prefix)
            if preflight_rc != 0:
                vs.status = "quarantined"
                add_quarantine_reason(
                    vs,
                    f"stage{stage.key}_contract_preflight_fail",
                    f"Stage {stage.key} contract preflight failed (exit {preflight_rc}); fail-closed quarantine.",
                )
                print(f"{log_prefix} QUARANTINED: stage {stage.key} contract preflight failed (exit {preflight_rc})")
                progress[vs.video_id] = "QUARANTINED"
                return

            if stage.needs_llm:
                progress[vs.video_id] = f"{stage.key}(wait)"
                stage_semaphore = stage_semaphores.get(stage.key)
                async with semaphore:
                    if stage_semaphore is not None:
                        async with stage_semaphore:
                            progress[vs.video_id] = f"{stage.key}(llm)"
                            rc = await run_subprocess(cmd, stage, vs.video_id, log_prefix)
                    else:
                        progress[vs.video_id] = f"{stage.key}(llm)"
                        rc = await run_subprocess(cmd, stage, vs.video_id, log_prefix)
            else:
                rc = await run_subprocess(cmd, stage, vs.video_id, log_prefix)

            if rc != 0:
                vs.status = "quarantined"
                add_quarantine_reason(
                    vs,
                    f"stage{stage.key}_execution_error",
                    f"Stage {stage.key} exited non-zero (exit {rc}); fail-closed quarantine.",
                )
                print(f"{log_prefix} QUARANTINED: stage {stage.key} execution failure (exit {rc})")
                progress[vs.video_id] = "QUARANTINED"
                return

            # Post-06b: fail-closed gate on REJECT + severe FLAG outcomes.
            if stage.key == "06b":
                should_quarantine, check_key, message = evaluate_06b_gate(vs.video_id, vs.source)
                if should_quarantine:
                    vs.status = "quarantined"
                    add_quarantine_reason(
                        vs,
                        check_key or "stage06b_flag_severe",
                        message or "Stage 06b severe verification failure.",
                    )
                    print(f"{log_prefix} QUARANTINED: {message or 'severe 06b gate trigger'}")
                    progress[vs.video_id] = "QUARANTINED"
                    return

            if stage.key in ("07", "07b", "09"):
                error_ids, reasons_by_video = await run_stage_validator_errors(
                    stage,
                    vs,
                    tmp_manifest,
                    quarantine_file,
                    log_prefix,
                )
                if vs.video_id in error_ids:
                    vs.status = "quarantined"
                    reason_rows = reasons_by_video.get(vs.video_id, [])
                    if reason_rows:
                        for reason_row in reason_rows:
                            add_quarantine_reason(
                                vs,
                                str(reason_row.get("check", "")).strip() or f"stage{stage.key}_block",
                                str(reason_row.get("message", "")).strip() or f"Stage {stage.key} validation reported block-level issues.",
                            )
                    else:
                        if stage.key == "07":
                            add_quarantine_reason(
                                vs,
                                "stage07_cross_stage_error",
                                "Stage 07 cross-stage validation reported error severity issues.",
                            )
                        elif stage.key == "07b":
                            add_quarantine_reason(
                                vs,
                                "stage07b_gate_block",
                                "Stage 07b enrichment verification reported block-level issues.",
                            )
                        else:
                            add_quarantine_reason(
                                vs,
                                "stage09_chunk_validation_error",
                                "Stage 09 chunk validation reported error severity issues.",
                            )
                    print(f"{log_prefix} QUARANTINED: stage {stage.key} validation errors")
                    progress[vs.video_id] = "QUARANTINED"
                    return

        finally:
            try:
                os.unlink(tmp_manifest)
            except OSError:
                pass

    vs.status = "done"
    progress[vs.video_id] = "done"
    print(f"[{vs.video_id}] COMPLETE")


# ── Progress display ────────────────────────────────────────────────────────

async def progress_reporter(
    videos: List[VideoState],
    progress: Dict[str, str],
    interval: float = 5.0,
) -> None:
    """Periodically print a status summary line."""
    total = len(videos)
    while True:
        await asyncio.sleep(interval)
        done = sum(1 for v in videos if v.status in ("done", "failed", "quarantined"))
        active = []
        for vid, stage in sorted(progress.items()):
            if stage not in ("done", "QUARANTINED") and "FAIL" not in stage:
                active.append(f"{vid[:7]}:{stage}")
        summary = " ".join(active[:8])
        if len(active) > 8:
            summary += f" +{len(active) - 8}"
        print(f"\n--- [{done}/{total} done] {summary} ---\n")
        if done >= total:
            break


# ── End-of-run validation ───────────────────────────────────────────────────

async def run_end_of_run_validation(
    sub_id: str,
    quarantine_file: Path | None,
) -> int:
    """Run end-of-run validation through the same code path as sequential mode."""
    cmd = ["bash", str(SCRIPT_DIR / "sub-batch-pipeline"), sub_id, "--validate"]
    if quarantine_file and quarantine_file.exists():
        cmd.extend(["--quarantine-file", str(quarantine_file)])

    print("\n=== End-of-run validation (delegated) ===\n")
    proc = await asyncio.create_subprocess_exec(*cmd)
    await proc.wait()
    return proc.returncode or 0


# ── Main orchestrator ────────────────────────────────────────────────────────

async def run_pipeline(args: argparse.Namespace) -> int:
    sub_id = args.sub_batch
    if args.manifest:
        manifest_path = Path(args.manifest)
        if not manifest_path.is_absolute():
            manifest_path = REPO_ROOT / manifest_path
    else:
        manifest_path = BATCHES_DIR / f"{sub_id}.txt"
    if not manifest_path.exists():
        print(f"ERROR: Manifest not found: {manifest_path}", file=sys.stderr)
        return 1

    videos = load_manifest_videos(manifest_path)
    if not videos:
        print(f"ERROR: No videos found in manifest: {manifest_path}", file=sys.stderr)
        return 1

    # Determine stage range
    start_key = args.start_from
    if start_key not in STAGE_KEYS:
        print(f"ERROR: Unknown stage: {start_key} (valid: {', '.join(STAGE_KEYS)})", file=sys.stderr)
        return 1
    end_key = args.end_at
    if end_key not in STAGE_KEYS:
        print(f"ERROR: Unknown stage: {end_key} (valid: {', '.join(STAGE_KEYS)})", file=sys.stderr)
        return 1
    start_idx = STAGE_KEYS.index(start_key)
    end_idx = STAGE_KEYS.index(end_key)
    if end_idx < start_idx:
        print(f"ERROR: Invalid stage range: {start_key} → {end_key}", file=sys.stderr)
        return 1
    stages = STAGES[start_idx:end_idx + 1]

    parallel = args.parallel
    semaphore = asyncio.Semaphore(parallel)
    stage_parallel_caps = {
        stage_key: min(parallel, int(cap))
        for stage_key, cap in (args.stage_parallel_caps or {}).items()
        if isinstance(cap, int) and cap > 0
    }
    stage_semaphores = {
        stage_key: asyncio.Semaphore(cap)
        for stage_key, cap in stage_parallel_caps.items()
        if cap < parallel
    }
    if args.quarantine_file:
        quarantine_file = Path(args.quarantine_file)
        if not quarantine_file.is_absolute():
            quarantine_file = REPO_ROOT / quarantine_file
    else:
        quarantine_file = QUARANTINE_DIR / f"{sub_id}.json"

    preexisting_quarantine_ids: Set[str] = set()
    retained_existing_videos: List[dict] = []
    original_quarantine_count = 0
    if quarantine_file and quarantine_file.exists():
        original_ids, original_rows = load_quarantine_state(quarantine_file)
        original_quarantine_count = len(original_ids)
        retained_existing_videos = filter_quarantine_rows_for_restart(
            original_rows,
            start_key,
            active_video_ids={v.video_id for v in videos},
        )
        preexisting_quarantine_ids = {
            str(row.get("video_id", "")).strip()
            for row in retained_existing_videos
            if str(row.get("video_id", "")).strip()
        }
        removed_count = original_quarantine_count - len(preexisting_quarantine_ids)
        if removed_count > 0 and not args.dry_run:
            write_quarantine_payload(quarantine_file, retained_existing_videos)
        if removed_count > 0:
            print(
                f"[pipeline-runner] Restart from {start_key}: ignoring {removed_count} "
                f"same-stage/downstream quarantine entr{'y' if removed_count == 1 else 'ies'} "
                f"(retained quarantine rows: {len(preexisting_quarantine_ids)}/{original_quarantine_count})."
            )

    print()
    print("=" * 56)
    print(f"  Pipeline Runner: {sub_id}")
    print(f"  Videos: {len(videos)}")
    print(f"  Stages: {' → '.join(s.key for s in stages)}")
    print(f"  Parallel LLM calls: {parallel}")
    if stage_parallel_caps:
        caps_text = ", ".join(f"{stage_key}={stage_parallel_caps[stage_key]}" for stage_key in sorted(stage_parallel_caps))
        print(f"  Stage LLM caps: {caps_text}")
    if args.dry_run:
        print("  Mode: DRY RUN")
    print("=" * 56)
    print()

    # Shared progress tracker
    progress: Dict[str, str] = {v.video_id: "pending" for v in videos}

    # Launch all video pipelines + progress reporter
    tasks = [
        asyncio.create_task(
            run_video(
                vs,
                stages,
                semaphore,
                stage_semaphores,
                quarantine_file,
                preexisting_quarantine_ids,
                args.dry_run,
                progress,
                llm_timeout_seconds=args.llm_timeout_seconds,
                llm_retries=args.llm_retries,
                force_stages=set(args.force_stage or []),
            )
        )
        for vs in videos
    ]
    if not args.dry_run:
        reporter = asyncio.create_task(progress_reporter(videos, progress))
    else:
        reporter = None

    await asyncio.gather(*tasks)
    if reporter:
        reporter.cancel()
        try:
            await reporter
        except asyncio.CancelledError:
            pass

    # Write quarantine file for any rejected videos
    quarantined = [v for v in videos if v.status == "quarantined"]
    if quarantine_file and (quarantined or retained_existing_videos or original_quarantine_count > 0) and not args.dry_run:
        write_quarantine_file(quarantine_file, quarantined, existing_seed_videos=retained_existing_videos)

    # Summary
    done_count = sum(1 for v in videos if v.status == "done")
    fail_count = sum(1 for v in videos if v.status == "failed")
    q_count = sum(1 for v in videos if v.status == "quarantined")
    skipped_preexisting_count = sum(1 for v in videos if v.status == "skipped_preexisting_quarantine")

    print()
    print("=" * 56)
    print(f"  Pipeline Summary: {sub_id}")
    print("=" * 56)
    print(f"  Passed:      {done_count}/{len(videos)}")
    if q_count:
        print(f"  Quarantined: {q_count}")
        for v in quarantined:
            print(f"    {v.video_id}")
    if skipped_preexisting_count:
        print(f"  Skipped preexisting quarantine: {skipped_preexisting_count}")
        for v in videos:
            if v.status == "skipped_preexisting_quarantine":
                print(f"    {v.video_id}")
    if fail_count:
        print(f"  Failed:      {fail_count}")
        for v in videos:
            if v.status == "failed":
                print(f"    {v.video_id} at stage {v.error_stage}: {v.error_msg}")
    print("=" * 56)
    print()

    validation_rc = 0
    # End-of-run validation (skip if dry run or all failed)
    if not args.dry_run and done_count > 0 and not args.skip_end_validation:
        validation_rc = await run_end_of_run_validation(sub_id, quarantine_file)
        if validation_rc != 0:
            print(f"[pipeline-runner] End-of-run validation failed (exit {validation_rc})", file=sys.stderr)

    if fail_count > 0:
        return 1
    if validation_rc != 0:
        return 2
    return 0


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Conveyor-belt pipeline runner — process videos in parallel across stages.",
    )
    parser.add_argument(
        "sub_batch",
        help="Sub-batch ID (e.g., P001.1)",
    )
    parser.add_argument(
        "--manifest",
        help="Optional manifest override (default: docs/pipeline/batches/<sub-batch>.txt)",
    )
    parser.add_argument(
        "--parallel", "-j",
        type=int,
        default=DEFAULT_PARALLEL,
        help=f"Max concurrent LLM calls (default: {DEFAULT_PARALLEL})",
    )
    parser.add_argument(
        "--from",
        dest="start_from",
        default="06",
        help="Stage to start from (default: 06)",
    )
    parser.add_argument(
        "--to",
        dest="end_at",
        default="09",
        help="Stage to end at, inclusive (default: 09)",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show commands without executing",
    )
    parser.add_argument(
        "--quarantine-file",
        help="Quarantine JSON path (default: data/validation/quarantine/<sub-batch>.json)",
    )
    parser.add_argument(
        "--skip-end-validation",
        action="store_true",
        help="Skip delegated end-of-run validation (useful for subset reruns inside larger orchestrators)",
    )
    parser.add_argument(
        "--llm-timeout-seconds",
        type=int,
        help="Optional per-call timeout override for LLM stages",
    )
    parser.add_argument(
        "--llm-retries",
        type=int,
        help="Optional per-call retry override for LLM stages",
    )
    parser.add_argument(
        "--stage-parallel-cap",
        action="append",
        default=[],
        help="Optional per-stage LLM concurrency cap (repeatable, format: STAGE=N)",
    )
    parser.add_argument(
        "--force-stage",
        action="append",
        default=[],
        help="Force eligible stage(s) to rebuild even when their own state cache says unchanged (repeatable).",
    )
    args = parser.parse_args()
    if args.parallel < 1:
        parser.error("--parallel must be >= 1")
    if args.llm_timeout_seconds is not None and args.llm_timeout_seconds < 1:
        parser.error("--llm-timeout-seconds must be >= 1")
    if args.llm_retries is not None and args.llm_retries < 1:
        parser.error("--llm-retries must be >= 1")
    try:
        args.stage_parallel_caps = parse_stage_parallel_caps(list(args.stage_parallel_cap or []))
    except ValueError as exc:
        parser.error(str(exc))
    requested_force_stages = [str(stage_key or "").strip() for stage_key in (args.force_stage or []) if str(stage_key or "").strip()]
    unknown_force_stages = sorted({stage_key for stage_key in requested_force_stages if stage_key not in STAGE_KEYS})
    if unknown_force_stages:
        parser.error(
            f"unknown --force-stage value(s): {', '.join(unknown_force_stages)} "
            f"(valid: {', '.join(STAGE_KEYS)})"
        )
    unsupported_force_stages = sorted(
        {stage_key for stage_key in requested_force_stages if stage_key not in STAGES_SUPPORTING_FORCE}
    )
    if unsupported_force_stages:
        parser.error(
            f"--force-stage only supports: {', '.join(sorted(STAGES_SUPPORTING_FORCE))}; "
            f"unsupported: {', '.join(unsupported_force_stages)}"
        )
    args.force_stage = sorted(set(requested_force_stages))
    rc = asyncio.run(run_pipeline(args))
    sys.exit(rc)


if __name__ == "__main__":
    main()
